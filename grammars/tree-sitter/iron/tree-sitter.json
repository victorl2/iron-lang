{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "iron",
      "camelcase": "Iron",
      "scope": "source.iron",
      "path": ".",
      "file-types": ["iron"],
      "highlights": ["queries/highlights.scm"],
      "injections": [],
      "locals": ["queries/locals.scm"],
      "folds": ["queries/folds.scm"]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Iron programming language",
    "authors": [
      { "name": "iron-lang" }
    ],
    "links": {
      "repository": "https://github.com/iron-lang/iron-lang"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false
  }
}
