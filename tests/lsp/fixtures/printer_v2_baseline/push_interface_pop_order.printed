interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

func (mut self: Circle) init(radius: Int) {
  self.radius = radius
}

object Square impl Shape {
  var side: Int
}

func (mut self: Square) init(side: Int) {
  self.side = side
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func main() {
  var shapes = [Circle(1), Square(2)]
  shapes.push(Circle(3))
  shapes.push(Square(4))
  var a = shapes.pop()
  println("{a.area()}")
  var b = shapes.pop()
  println("{b.area()}")
  var c = shapes.pop()
  println("{c.area()}")
  var d = shapes.pop()
  println("{d.area()}")
  println("{shapes.len()}")
}
