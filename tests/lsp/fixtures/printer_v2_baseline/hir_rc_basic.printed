object Config {
  var name: String
  var value: Int
  init(name: String, value: Int) {
    self.name = name
    self.value = value
  }
}

func main() {
  val c1 = rc Config("alpha", 10)
  val c2 = rc Config("beta", 20)
  println(c1.name)
  println("{c1.value}")
  println(c2.name)
  println("{c2.value}")
}
