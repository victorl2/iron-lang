  val (null) = Net.tcp_listen("::", 34502)
  if (lerr.code != 0) {
    println("listen failed: {lerr.code}")
    return
  }
  val (null) = TcpListener.accept(listener, 50)
  if (aerr.code == 1004) {
    println("dualstack listener ok")
