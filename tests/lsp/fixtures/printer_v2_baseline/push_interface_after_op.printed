interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
  init(radius: Int) {
    self.radius = radius
  }
}

object Square impl Shape {
  var side: Int
  init(side: Int) {
    self.side = side
  }
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func main() {
  var shapes = [Circle(1), Square(2), Circle(3), Square(5)]
  var big = shapes.filter(func(s: Shape) -> Bool {
    return (s.area() > 5)
  })
  big.push(Square(10))
  var total = 0
  for s in big {
    total = (total + s.area())
  }
  println("{total}")
}
