interface Named {
  func get_id() -> Int
}

object Cat impl Named {
  var id: Int
  var lives: Int
}

func (mut self: Cat) init(id: Int, lives: Int) {
  self.id = id
  self.lives = lives
}

object Dog impl Named {
  var id: Int
  var tricks: Int
}

func (mut self: Dog) init(id: Int, tricks: Int) {
  self.id = id
  self.tricks = tricks
}

func Cat.get_id() -> Int {
  return self.id
}

func Dog.get_id() -> Int {
  return self.id
}

func main() {
  val pets = [Cat(1, 9), Dog(2, 5), Cat(3, 7)]
  var total_id = 0
  for p in pets {
    total_id = (total_id + p.get_id())
  }
  println("{total_id}")
  println("done")
}
