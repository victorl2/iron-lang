interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
  init(radius: Int) {
    self.radius = radius
  }
}

object Square impl Shape {
  var side: Int
  init(side: Int) {
    self.side = side
  }
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func main() {
  var shapes: [Shape] = []
  shapes.push(Circle(5))
  shapes.push(Square(7))
  println("{shapes.len()}")
  var a = shapes.pop()
  var b = shapes.pop()
  println("{shapes.len()}")
}
