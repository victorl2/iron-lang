func add_int32(a: Int32, b: Int32) -> Int32 {
  return (a + b)
}

func widen_to_int(x: Int32) -> Int {
  return x
}

func main() {
  val x: Int32 = 42
  println("{x}")
  val n: Int = 100
  val y: Int32 = Int32(n)
  println("{y}")
  val z: Int32 = (x + y)
  println("{z}")
  val sum: Int32 = add_int32(Int32(10), Int32(20))
  println("{sum}")
  val w: Int = z
  println("{w}")
  val wide = widen_to_int(Int32(7))
  println("{wide}")
  val limit: Int = 200
  if (z < limit) {
    println("less")
  } else {
    println("not less")
  }
  val check: Int = 42
  if (check == x) {
    println("equal")
  } else {
    println("not equal")
  }
}
