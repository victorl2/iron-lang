func main() {
  val arr = [10, 20, 30, 40, 50]
  println("{arr[0]}, {arr[2]}, {arr[4]}")
  var nums = [1, 2, 3]
  nums[0] = 100
  nums[2] = 300
  println("{nums[0]}, {nums[1]}, {nums[2]}")
  val data = [5, 10, 15, 20]
  println("len = {len(data)}")
  val items = [1, 2, 3, 4, 5]
  var sum = 0
  for x in items {
    sum = (sum + x)
  }
  println("sum = {sum}")
  var arr2 = [0, 0, 0]
  val cond = 1
  if (cond > 0) {
    arr2[0] = 10
    arr2[1] = 20
  } else {
    arr2[0] = 99
  }
  arr2[2] = 30
  println("{arr2[0]}, {arr2[1]}, {arr2[2]}")
}
