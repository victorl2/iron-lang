object Counter {
  var value: Int
}

func (mut self: Counter) init(value: Int) {
  self.value = value
}

func Counter.bump() -> Int {
  return (self.value + 1)
}

func Counter.triple() -> Int {
  return (self.value * 3)
}

func Counter.add(x: Int) -> Int {
  return (self.value + x)
}

func main() {
  val c = Counter(10)
  println("bump: {c.bump()}")
  println("triple: {c.triple()}")
  println("add: {c.add(7)}")
}
