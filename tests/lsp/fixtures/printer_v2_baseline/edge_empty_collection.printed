func main() {
  var empty = [1]
  empty.pop()
  val mapped = empty.map(func(x: Int) -> Int {
    return (x + 1)
  })
  println("{mapped.sum()}")
  val filtered = empty.filter(func(x: Int) -> Bool {
    return (x > 0)
  })
  println("{filtered.sum()}")
  val chained = empty.map(func(x: Int) -> Int {
    return (x * 2)
  }).filter(func(x: Int) -> Bool {
    return (x > 5)
  }).reduce(0, func(acc: Int, x: Int) -> Int {
    return (acc + x)
  })
  println("{chained}")
  val reduced = empty.reduce(99, func(acc: Int, x: Int) -> Int {
    return (acc + x)
  })
  println("{reduced}")
  val total = empty.sum()
  println("{total}")
}
