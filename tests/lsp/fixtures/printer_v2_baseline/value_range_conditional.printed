interface Sensor {
  func reading() -> Int
}

object Gauge impl Sensor {
  var level: Int
  var scale: Int
  var debug_id: Int
}

func (mut self: Gauge) init(level: Int, scale: Int, debug_id: Int) {
  self.level = level
  self.scale = scale
  self.debug_id = debug_id
}

object Meter impl Sensor {
  var level: Int
  var offset: Int
  var debug_id: Int
}

func (mut self: Meter) init(level: Int, offset: Int, debug_id: Int) {
  self.level = level
  self.offset = offset
  self.debug_id = debug_id
}

func Gauge.reading() -> Int {
  return (self.level * self.scale)
}

func Meter.reading() -> Int {
  return (self.level + self.offset)
}

func identity(x: Int) -> Int {
  return x
}

func clamp_value(raw: Int) -> Int {
  if (raw < 0) {
    return 0
  }
  if (raw > 100) {
    return 100
  }
  return identity(raw)
}

func main() {
  val g1 = Gauge(clamp_value(42), clamp_value(2), 800)
  val g2 = Gauge(clamp_value(85), clamp_value(3), 801)
  val m1 = Meter(clamp_value(60), clamp_value(10), 900)
  val m2 = Meter(clamp_value(75), clamp_value(5), 901)
  val sensors = [g1, g2, m1, m2]
  var total = 0
  for s in sensors {
    total = (total + s.reading())
  }
  println("{total}")
}
