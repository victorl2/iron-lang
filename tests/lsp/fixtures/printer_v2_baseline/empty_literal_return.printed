interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
  init(radius: Int) {
    self.radius = radius
  }
}

object Square impl Shape {
  var side: Int
  init(side: Int) {
    self.side = side
  }
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func make_empty_shapes() -> [Shape] {
  return []
}

func main() {
  var shapes = make_empty_shapes()
  shapes.push(Circle(2))
  println("{shapes.len()}")
}
