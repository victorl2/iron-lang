func add_one(x: Int) -> Int {
  return (x + 1)
}

func square(x: Int) -> Int {
  return (x * x)
}

func max_val(a: Int, b: Int) -> Int {
  if (a > b) {
    return a
  }
  return b
}

func main() {
  println("{add_one(5)}")
  val x = (add_one(10) + add_one(20))
  println("{x}")
  val y = add_one(add_one(3))
  println("{y}")
  println("{square(7)}")
  println("{max_val(3, 8)}")
  println("{max_val(10, 2)}")
  var sum = 0
  for i in range(5) {
    sum = (sum + add_one(i))
  }
  println("{sum}")
}
