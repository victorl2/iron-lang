interface Entity {
  func get_x() -> Int
}

object Particle impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var mass: Int
}

func (mut self: Particle) init(x: Int, y: Int, z: Int, mass: Int) {
  self.x = x
  self.y = y
  self.z = z
  self.mass = mass
}

object Bullet impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var speed: Int
}

func (mut self: Bullet) init(x: Int, y: Int, z: Int, speed: Int) {
  self.x = x
  self.y = y
  self.z = z
  self.speed = speed
}

func Particle.get_x() -> Int {
  return self.x
}

func Bullet.get_x() -> Int {
  return self.x
}

func main() {
  val entities = [Particle(10, 20, 30, 100), Bullet(5, 15, 25, 50), Particle(3, 6, 9, 200), Bullet(8, 12, 18, 75)]
  val sum_x = entities.map(func(e: Entity) -> Int {
    return e.get_x()
  }).sum()
  println("{sum_x}")
  println("soa_fusion_done")
}
