interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
  init(radius: Int) {
    self.radius = radius
  }
}

object Square impl Shape {
  var side: Int
  init(side: Int) {
    self.side = side
  }
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func main() {
  val circles = [Circle(2), Circle(3), Circle(4)]
  val doubled = circles.map(func(c: Circle) -> Circle {
    return Circle((c.radius * 2))
  })
  val total = doubled.map(func(c: Circle) -> Int {
    return c.area()
  }).sum()
  println("{total}")
}
