func main() {
  var i = 0
  var sum = 0
  while (i < 10) {
    sum = (sum + i)
    i = (i + 1)
  }
  println("sum 0..9: {sum}")
  var found = 0
  var target = 42
  var search = 0
  var hit = false
  while (search < 100) {
    if ((search * 2) == target) {
      found = search
      hit = true
    }
    if hit {
      search = 100
    } else {
      search = (search + 1)
    }
  }
  println("found at: {found}")
  var product = 1
  for n in range(5) {
    product = (product * (n + 1))
  }
  println("5! = {product}")
  var pairs = 0
  for a in range(4) {
    for b in range(4) {
      if ((a + b) == 3) {
        pairs = (pairs + 1)
      }
    }
  }
  println("pairs summing to 3: {pairs}")
  var acc = 0
  var k = 0
  while (k < 20) {
    if (k == 0) {
      k = (k + 1)
    } elif (k > 0) {
      if (((k / 3) * 3) == k) {
        k = (k + 1)
      } else {
        acc = (acc + k)
        k = (k + 1)
      }
    }
  }
  println("sum non-multiples-of-3 (1-19): {acc}")
  var countdown = 5
  var countdown_sum = 0
  while (countdown > 0) {
    countdown_sum = (countdown_sum + countdown)
    countdown = (countdown - 1)
  }
  println("countdown sum: {countdown_sum}")
  println("done")
}
