object IntWrapper {
  var value: Int
}

func (mut self: IntWrapper) init(value: Int) {
  self.value = value
}

object FloatWrapper {
  var value: Float
}

func (mut self: FloatWrapper) init(value: Float) {
  self.value = value
}

object StringWrapper {
  var value: String
}

func (mut self: StringWrapper) init(value: String) {
  self.value = value
}

func IntWrapper.doubled() -> Int {
  return (self.value * 2)
}

func FloatWrapper.doubled() -> Float {
  return (self.value * 2.0)
}

func main() {
  val iw = IntWrapper(21)
  val fw = FloatWrapper(3.14)
  val sw = StringWrapper("hello")
  println("{iw.doubled()}")
  println("{iw.value}")
  println(sw.value)
}
