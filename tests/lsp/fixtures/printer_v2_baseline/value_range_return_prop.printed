interface Particle {
  func describe() -> Int
}

object Dot impl Particle {
  var kind: Int
  var x: Int
  var y: Int
  var debug_id: Int
  init(kind: Int, x: Int, y: Int, debug_id: Int) {
    self.kind = kind
    self.x = x
    self.y = y
    self.debug_id = debug_id
  }
}

object Pixel impl Particle {
  var kind: Int
  var r: Int
  var g: Int
  var debug_id: Int
  init(kind: Int, r: Int, g: Int, debug_id: Int) {
    self.kind = kind
    self.r = r
    self.g = g
    self.debug_id = debug_id
  }
}

func Dot.describe() -> Int {
  return (((self.kind * 1000) + (self.x * 100)) + self.y)
}

func Pixel.describe() -> Int {
  return (((self.kind * 1000) + (self.r * 100)) + self.g)
}

func get_kind_dot() -> Int {
  return 1
}

func get_kind_pixel() -> Int {
  return 2
}

func get_x() -> Int {
  return 30
}

func get_y() -> Int {
  return 40
}

func get_r() -> Int {
  return 100
}

func get_g() -> Int {
  return 200
}

func build_dot() -> Dot {
  return Dot(get_kind_dot(), get_x(), get_y(), 800)
}

func build_pixel() -> Pixel {
  return Pixel(get_kind_pixel(), get_r(), get_g(), 900)
}

func main() {
  val particles = [Dot(1, 10, 20, 801), build_dot(), Pixel(2, 50, 150, 901), build_pixel()]
  var total = 0
  for p in particles {
    total = (total + p.describe())
  }
  println("{total}")
}
