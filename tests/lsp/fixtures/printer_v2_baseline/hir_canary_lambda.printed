func main() {
  val double = func(x: Int) -> Int {
    return (x * 2)
  }
  val square = func(x: Int) -> Int {
    return (x * x)
  }
  val inc = func(x: Int) -> Int {
    return (x + 1)
  }
  val a = double(5)
  val b = square(7)
  val c = inc(square(3))
  println("a: {a}")
  println("b: {b}")
  println("c: {c}")
  println("sum: {((a + b) + c)}")
}
