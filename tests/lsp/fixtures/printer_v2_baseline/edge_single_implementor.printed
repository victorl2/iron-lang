interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

func (mut self: Circle) init(radius: Int) {
  self.radius = radius
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func main() {
  val shapes = [Circle(5), Circle(3), Circle(7)]
  var total = 0
  for s in shapes {
    total = (total + s.area())
  }
  println("{total}")
  var filtered_sum = 0
  for s in shapes {
    val a = s.area()
    if (a > 30) {
      filtered_sum = (filtered_sum + a)
    }
  }
  println("{filtered_sum}")
  var count = 0
  for s in shapes {
    count = (count + 1)
  }
  println("{count}")
}
