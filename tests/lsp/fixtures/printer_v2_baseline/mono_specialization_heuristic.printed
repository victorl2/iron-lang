interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
  init(radius: Int) {
    self.radius = radius
  }
}

object Square impl Shape {
  var side: Int
  init(side: Int) {
    self.side = side
  }
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func buildMixed() -> [Shape] {
  return [Circle(5), Square(4), Circle(3)]
}

func sumCircleAreas() -> Int {
  val circles = [Circle(5), Circle(3), Circle(7)]
  var total = 0
  for s in circles {
    total = (total + s.area())
  }
  return total
}

func sumMixedAreas() -> Int {
  val shapes = buildMixed()
  var total = 0
  for s in shapes {
    total = (total + s.area())
  }
  return total
}

func bigProcess() -> Int {
  var a = 1
  var b = 2
  var c = 3
  var d = 4
  var e = 5
  a = ((a + b) + c)
  b = ((b + c) + d)
  c = ((c + d) + e)
  d = ((d + e) + a)
  e = ((e + a) + b)
  a = ((a + b) + c)
  b = ((b + c) + d)
  c = ((c + d) + e)
  d = ((d + e) + a)
  e = ((e + a) + b)
  a = (a * 2)
  b = (b * 2)
  c = (c * 2)
  d = (d * 2)
  e = (e * 2)
  a = ((a + b) + c)
  b = ((b + c) + d)
  c = ((c + d) + e)
  d = ((d + e) + a)
  e = ((e + a) + b)
  return ((((a + b) + c) + d) + e)
}

func main() {
  val r1 = sumCircleAreas()
  val r2 = sumMixedAreas()
  val r3 = bigProcess()
  println("{r1}")
  println("{r2}")
  println("{r3}")
}
