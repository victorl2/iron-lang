interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

func (mut self: Circle) init(radius: Int) {
  self.radius = radius
}

object Square impl Shape {
  var side: Int
}

func (mut self: Square) init(side: Int) {
  self.side = side
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func main() {
  val circles = [Circle(1), Circle(2), Circle(3), Circle(4), Circle(5), Circle(6), Circle(7), Circle(8), Circle(9), Circle(10)]
  val result = circles.map(func(c: Circle) -> Int {
    return c.area()
  }).filter(func(a: Int) -> Bool {
    return (a > 50)
  }).reduce(0, func(acc: Int, a: Int) -> Int {
    return (acc + a)
  })
  println("{result}")
}
