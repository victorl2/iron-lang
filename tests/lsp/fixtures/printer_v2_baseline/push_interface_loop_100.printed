interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
  init(radius: Int) {
    self.radius = radius
  }
}

object Square impl Shape {
  var side: Int
  init(side: Int) {
    self.side = side
  }
}

func Circle.area() -> Int {
  return ((self.radius * self.radius) * 3)
}

func Square.area() -> Int {
  return (self.side * self.side)
}

func main() {
  var shapes = [Circle(0), Square(0)]
  var i = 1
  while (i < 101) {
    if ((i % 2) == 0) {
      shapes.push(Circle(i))
    } else {
      shapes.push(Square(i))
    }
    i = (i + 1)
  }
  var count = 0
  var total = 0
  for s in shapes {
    count = (count + 1)
    total = (total + s.area())
  }
  println("{count}")
  println("{total}")
}
