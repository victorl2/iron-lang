--   [0] deletes ` = 100` from the field decl
--   [1] inserts `    self.health = 100` BEFORE the existing init's `}`.

object Player {
    var health: Int = 100
    var name: String
    init(name: String) {
        self.name = name
    }
}

func main() {
    val p: Player = Player(name: "Hero")
}
