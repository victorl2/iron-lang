import time

-- Concurrency Parallel Sum: parallel-for over independent ranges.
-- Each parallel iteration computes a row sum using only the loop index.
-- Verifies strength reduction doesn't break index computation in parallel body.
-- Pattern: compute sequential checksum, run parallel, recompute to verify.

func row_sum_50(row: Int) -> Int {
    -- Compute row sum for a 50x50 grid using only row index (no captures needed)
    var total = 0
    var col = 0
    while col < 50 {
        total = total + (row * 50 + col) % 1000003
        col = col + 1
    }
    return total
}

func main() {
    val rows = 50

    -- Sequential checksum (ground truth)
    var seq_total = 0
    for r in range(rows) {
        seq_total = seq_total + row_sum_50(r)
    }
    val seq_checksum = seq_total % 1000000007

    -- Parallel section: each iteration computes a row independently (no captures)
    val start = Time.now_ms()
    val iters = 3
    for iter in range(iters) {
        for r in rows parallel {
            val rs = row_sum_50(r)
        }
    }
    val elapsed = Time.now_ms() - start

    -- Recompute to verify determinism
    var par_total = 0
    for r in range(rows) {
        par_total = par_total + row_sum_50(r)
    }
    val par_checksum = par_total % 1000000007

    println("Sequential checksum: {seq_checksum}")
    println("Parallel checksum: {par_checksum}")
    var is_match = 0
    if seq_checksum == par_checksum {
        is_match = 1
    }
    println("Match: {is_match}")

    println("")
    println("=== Benchmark: Concurrency Parallel Sum ===")
    println("Grid=50x50")
    println("Total time: {elapsed} ms")
}
