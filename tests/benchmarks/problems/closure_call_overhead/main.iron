func add_direct(x: Int, y: Int) -> Int {
  return x + y
}

func main() {
  val add_closure = func(x: Int, y: Int) -> Int { return x + y }

  val iterations = 1000000

  var sum_direct = 0
  for i in range(iterations) {
    sum_direct += add_direct(i, 1)
  }

  var sum_closure = 0
  for i in range(iterations) {
    sum_closure += add_closure(i, 1)
  }

  println("direct: {sum_direct}")
  println("closure: {sum_closure}")
  if sum_direct == sum_closure {
    println("MATCH")
  }
}
