import time

-- Parallel Matrix Multiply: NxN matrix multiplication
-- Each parallel iteration computes one row of the result.
-- Matrices are generated deterministically from constants (no captures needed).

func mat_elem_a(row: Int, col: Int) -> Int {
  return ((row * 200 + col + 7) * 37 + 13) % 100
}

func mat_elem_b(row: Int, col: Int) -> Int {
  return ((row * 200 + col + 42) * 37 + 13) % 100
}

func compute_row_checksum(row: Int) -> Int {
  -- Compute row of C = A * B for N=200, return sum of row elements
  val n = 200
  var row_sum = 0
  var j = 0
  while j < n {
    var dot = 0
    var k = 0
    while k < n {
      dot = dot + mat_elem_a(row, k) * mat_elem_b(k, j)
      k = k + 1
    }
    row_sum = row_sum + dot
    j = j + 1
  }
  if row_sum == -999999999 {
    println("x")
  }
  return row_sum
}

func main() {
  val n = 200

  -- Correctness: sequential checksum
  var checksum = 0
  for i in range(n) {
    checksum = checksum + compute_row_checksum(i)
  }
  println("checksum: {checksum}")

  -- Benchmark: sequential
  val iterations = 20
  var seq_total = 0
  val start_seq = Time.now_ms()
  for iter in range(iterations) {
    for i in range(n) {
      seq_total = seq_total + compute_row_checksum(i)
    }
  }
  val elapsed_seq = Time.now_ms() - start_seq

  -- Benchmark: parallel (each iteration computes one row)
  val start_par = Time.now_ms()
  for iter in range(iterations) {
    for i in n parallel {
      val x = compute_row_checksum(i)
    }
  }
  val elapsed_par = Time.now_ms() - start_par

  println("")
  println("=== Benchmark: Parallel Matrix Multiply ===")
  println("Matrix size: {n}x{n}")
  println("Iterations: {iterations}")
  println("Sequential time: {elapsed_seq} ms")
  println("Parallel time: {elapsed_par} ms")
  println("Seq verify: {seq_total}")
  println("Total time: {elapsed_par} ms")
}
