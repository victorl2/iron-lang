import time

-- Large array operations: prefix sum, range queries, and bulk manipulation
-- Uses fill(10000, 0) to exercise large array allocation and traversal

func build_prefix_sum(arr: [Int], n: Int, prefix: [Int]) {
    prefix[0] = arr[0]
    var i = 1
    while i < n {
        prefix[i] = prefix[i - 1] + arr[i]
        i = i + 1
    }
}

func range_sum(prefix: [Int], l: Int, r: Int) -> Int {
    if l == 0 {
        return prefix[r]
    }
    return prefix[r] - prefix[l - 1]
}

func bulk_transform(arr: [Int], n: Int) {
    -- In-place transform: arr[i] = (arr[i] * 31 + 17) % 10007
    var i = 0
    while i < n {
        arr[i] = (arr[i] * 31 + 17) % 10007
        i = i + 1
    }
}

func checksum_array(arr: [Int], n: Int) -> Int {
    var sum = 0
    var i = 0
    while i < n {
        sum = sum + arr[i] * ((i % 100) + 1)
        i = i + 1
    }
    return sum % 1000000007
}

func bench_large_array(n: Int) -> Int {
    var arr = fill(n, 0)
    var i = 0
    while i < n {
        arr[i] = (i * 73 + 29) % 10007
        i = i + 1
    }

    -- Build prefix sum
    var prefix = fill(n, 0)
    build_prefix_sum(arr, n, prefix)

    -- Do range queries
    var query_sum = 0
    var q = 0
    while q < 100 {
        val l = (q * 37) % (n / 2)
        val r = l + (q * 13 + 50) % (n / 2)
        query_sum = query_sum + range_sum(prefix, l, r) % 100000
        q = q + 1
    }

    -- Bulk transform and checksum
    bulk_transform(arr, n)
    val cs = checksum_array(arr, n)

    return query_sum + cs
}

func main() {
    -- Tests with small array
    var small = [1, 2, 3, 4, 5]
    var sp = fill(5, 0)
    build_prefix_sum(small, 5, sp)
    println("Test 1 prefix[4]: {sp[4]} (expected 15)")
    println("Test 2 range(1,3): {range_sum(sp, 1, 3)} (expected 9)")
    println("Test 3 range(0,0): {range_sum(sp, 0, 0)} (expected 1)")

    -- Test with large array
    val check = bench_large_array(10000)
    println("Test 4 bench(10000): {check}")

    -- Benchmark
    val iterations = 10000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = bench_large_array(10000)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Large Array Prefix Sum ===")
    println("Array size: 10000")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
