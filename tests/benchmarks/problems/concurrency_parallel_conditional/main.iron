import time

-- Concurrency Parallel Conditional: parallel-for body has if/else branches.
-- Even indices get one computation, odd indices get another.
-- Verifies DCE doesn't remove conditional branches in parallel body.
-- Both branches do non-trivial computation.

func even_compute(idx: Int) -> Int {
    -- Even branch: multiplicative hash
    var h = idx * 37 + 1
    var k = 0
    while k < 60 {
        h = (h * 1000003 + k) % 1000000007
        k = k + 1
    }
    return h
}

func odd_compute(idx: Int) -> Int {
    -- Odd branch: additive hash
    var h = idx * 31 + 7
    var k = 0
    while k < 60 {
        h = (h + 999983 * k + idx) % 1000000007
        k = k + 1
    }
    return h
}

func conditional_elem(idx: Int) -> Int {
    var result = 0
    if idx % 2 == 0 {
        result = even_compute(idx)
    } else {
        result = odd_compute(idx)
    }
    return result
}

func main() {
    val n = 1000

    -- Sequential checksum (ground truth)
    var seq_sum = 0
    for i in range(n) {
        seq_sum = (seq_sum + conditional_elem(i)) % 1000000007
    }
    val seq_checksum = seq_sum

    -- Parallel section: each iteration uses if/else (no captures)
    val start = Time.now_ms()
    val iters = 3
    for iter in range(iters) {
        for i in n parallel {
            val elem = conditional_elem(i)
        }
    }
    val elapsed = Time.now_ms() - start

    -- Recompute to verify: DCE didn't remove either branch
    var par_sum = 0
    for i in range(n) {
        par_sum = (par_sum + conditional_elem(i)) % 1000000007
    }
    val par_checksum = par_sum

    println("Sequential checksum: {seq_checksum}")
    println("Parallel checksum: {par_checksum}")
    var is_match = 0
    if seq_checksum == par_checksum {
        is_match = 1
    }
    println("Match: {is_match}")

    println("")
    println("=== Benchmark: Concurrency Parallel Conditional ===")
    println("N={n}")
    println("Total time: {elapsed} ms")
}
