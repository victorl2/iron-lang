import time

func find_median_sorted(nums1: [Int], n1: Int, nums2: [Int], n2: Int) -> Int {
    -- Returns median * 2 to avoid float issues
    -- Precondition: n1 <= n2

    var lo = 0
    var hi = n1
    val half = (n1 + n2 + 1) / 2

    while lo <= hi {
        val i = (lo + hi) / 2
        val j = half - i

        var left1 = -1000000
        if i > 0 {
            left1 = nums1[i - 1]
        }
        var right1 = 1000000
        if i < n1 {
            right1 = nums1[i]
        }
        var left2 = -1000000
        if j > 0 {
            left2 = nums2[j - 1]
        }
        var right2 = 1000000
        if j < n2 {
            right2 = nums2[j]
        }

        if left1 <= right2 and left2 <= right1 {
            var max_left = left1
            if left2 > left1 {
                max_left = left2
            }
            var min_right = right1
            if right2 < right1 {
                min_right = right2
            }
            if (n1 + n2) % 2 == 1 {
                return max_left * 2
            }
            return max_left + min_right
        } elif left1 > right2 {
            hi = i - 1
        } else {
            lo = i + 1
        }
    }
    return 0
}

func main() {
    -- Use fill to build test arrays so compiler uses raw pointer type
    var t1a = fill(2, 0)
    t1a[0] = 1
    t1a[1] = 3
    var t1b = fill(1, 0)
    t1b[0] = 2
    var t2a = fill(2, 0)
    t2a[0] = 1
    t2a[1] = 2
    var t2b = fill(2, 0)
    t2b[0] = 3
    t2b[1] = 4

    -- Test: n1 <= n2 for direct call
    val r1 = find_median_sorted(t1b, 1, t1a, 2)
    val r2 = find_median_sorted(t2a, 2, t2b, 2)
    println("Test 1: {r1 / 2}.{(r1 % 2) * 5} (expected 2.0)")
    println("Test 2: {r2 / 2}.{(r2 % 2) * 5} (expected 2.5)")

    -- Larger test arrays (interleaved sorted) -- use fill to avoid heap list
    var a1 = fill(50, 0)
    for i in range(50) {
        a1[i] = i * 2
    }
    var a2 = fill(50, 0)
    for i in range(50) {
        a2[i] = i * 2 + 1
    }

    val iterations = 500000000
    val start = Time.now_ms()
    var result = 0
    for i in range(iterations) {
        -- Both arrays have 50 elements, so n1 == n2, no swap needed
        result = find_median_sorted(a1, 50, a2, 50)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Median of Two Sorted Arrays ===")
    println("Array sizes: 50 + 50 = 100 elements")
    println("Iterations: {iterations}")
    println("Result: {result / 2}.{(result % 2) * 5}")
    println("Total time: {elapsed} ms")
    println("Memory: (see process stats)")
}
