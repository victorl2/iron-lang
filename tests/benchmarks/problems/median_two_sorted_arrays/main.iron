import time

func find_median_sorted(nums1: [Int32], n1: Int32, nums2: [Int32], n2: Int32) -> Int32 {
    -- Returns median * 2 to avoid float issues
    -- Precondition: n1 <= n2

    var lo: Int32 = Int32(0)
    var hi: Int32 = n1
    val half: Int32 = (n1 + n2 + Int32(1)) / Int32(2)

    while lo <= hi {
        val i: Int32 = (lo + hi) / Int32(2)
        val j: Int32 = half - i

        var left1: Int32 = Int32(-1000000)
        if i > Int32(0) {
            left1 = nums1[Int(i - Int32(1))]
        }
        var right1: Int32 = Int32(1000000)
        if i < n1 {
            right1 = nums1[Int(i)]
        }
        var left2: Int32 = Int32(-1000000)
        if j > Int32(0) {
            left2 = nums2[Int(j - Int32(1))]
        }
        var right2: Int32 = Int32(1000000)
        if j < n2 {
            right2 = nums2[Int(j)]
        }

        if left1 <= right2 and left2 <= right1 {
            var max_left: Int32 = left1
            if left2 > left1 {
                max_left = left2
            }
            var min_right: Int32 = right1
            if right2 < right1 {
                min_right = right2
            }
            if (n1 + n2) % Int32(2) == Int32(1) {
                return max_left * Int32(2)
            }
            return max_left + min_right
        } elif left1 > right2 {
            hi = i - Int32(1)
        } else {
            lo = i + Int32(1)
        }
    }
    return Int32(0)
}

func main() {
    var t1a = fill(2, Int32(0))
    t1a[0] = Int32(1)
    t1a[1] = Int32(3)
    var t1b = fill(1, Int32(0))
    t1b[0] = Int32(2)
    var t2a = fill(2, Int32(0))
    t2a[0] = Int32(1)
    t2a[1] = Int32(2)
    var t2b = fill(2, Int32(0))
    t2b[0] = Int32(3)
    t2b[1] = Int32(4)

    val r1 = find_median_sorted(t1b, Int32(1), t1a, Int32(2))
    val r2 = find_median_sorted(t2a, Int32(2), t2b, Int32(2))
    println("Test 1: {Int(r1) / 2}.{(Int(r1) % 2) * 5} (expected 2.0)")
    println("Test 2: {Int(r2) / 2}.{(Int(r2) % 2) * 5} (expected 2.5)")

    var a1 = fill(50, Int32(0))
    for i in range(50) {
        a1[i] = Int32(i * 2)
    }
    var a2 = fill(50, Int32(0))
    for i in range(50) {
        a2[i] = Int32(i * 2 + 1)
    }

    val iterations = 500000000
    val start = Time.now_ms()
    var result: Int32 = Int32(0)
    for i in range(iterations) {
        result = find_median_sorted(a1, Int32(50), a2, Int32(50))
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Median of Two Sorted Arrays ===")
    println("Array sizes: 50 + 50 = 100 elements")
    println("Iterations: {iterations}")
    println("Result: {Int(result) / 2}.{(Int(result) % 2) * 5}")
    println("Total time: {elapsed} ms")
    println("Memory: (see process stats)")
}
