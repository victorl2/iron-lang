import time

-- Concurrency Parallel Fibonacci: parallel-for calls iterative fibonacci per iteration.
-- Tests that expression inlining of function calls is safe in parallel context.
-- Uses iterative fibonacci (not recursive) for deterministic performance.
-- Pattern: compute sequential checksum, run parallel, recompute to verify.

func fib_iter(n: Int) -> Int {
    if n <= 1 {
        return n
    }
    var a = 0
    var b = 1
    var i = 2
    while i <= n {
        val tmp = a + b
        a = b
        b = tmp
        i = i + 1
    }
    return b
}

func fib_for_index(idx: Int) -> Int {
    -- Map idx to fibonacci number in range fib(10)..fib(29)
    return fib_iter(idx % 20 + 10)
}

func main() {
    val n = 500

    -- Sequential checksum (ground truth)
    var seq_sum = 0
    for i in range(n) {
        seq_sum = (seq_sum + fib_for_index(i)) % 1000000007
    }
    val seq_checksum = seq_sum

    -- Parallel section: each iteration calls fib independently (no captures)
    val start = Time.now_ms()
    val iters = 3
    for iter in range(iters) {
        for i in n parallel {
            val f = fib_for_index(i)
        }
    }
    val elapsed = Time.now_ms() - start

    -- Recompute to verify: function inlining didn't break parallel calls
    var par_sum = 0
    for i in range(n) {
        par_sum = (par_sum + fib_for_index(i)) % 1000000007
    }
    val par_checksum = par_sum

    println("Sequential checksum: {seq_checksum}")
    println("Parallel checksum: {par_checksum}")
    var is_match = 0
    if seq_checksum == par_checksum {
        is_match = 1
    }
    println("Match: {is_match}")

    println("")
    println("=== Benchmark: Concurrency Parallel Fibonacci ===")
    println("N={n}")
    println("Total time: {elapsed} ms")
}
