import time

-- Find insertion point in sorted array (lower bound binary search)

func binary_search_insert(arr: [Int], n: Int, target: Int) -> Int {
    var lo = 0
    var hi = n
    while lo < hi {
        val mid = lo + (hi - lo) / 2
        if arr[mid] < target {
            lo = mid + 1
        } else {
            hi = mid
        }
    }
    return lo
}

func main() {
    val a1 = [1, 3, 5, 6]
    println("Test 1: {binary_search_insert(a1, 4, 5)} (expected 2)")
    println("Test 2: {binary_search_insert(a1, 4, 2)} (expected 1)")
    println("Test 3: {binary_search_insert(a1, 4, 7)} (expected 4)")
    println("Test 4: {binary_search_insert(a1, 4, 0)} (expected 0)")

    -- Benchmark: sorted array of 200 elements
    val n = 200
    var arr = fill(n, 0)
    for i in range(n) {
        arr[i] = i * 3
    }

    val check = binary_search_insert(arr, n, 299)
    println("Bench check: {check}")

    val iterations = 15000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        val target = (it * 7 + 13) % 600
        result = result + binary_search_insert(arr, n, target)
    }
    val elapsed = Time.now_ms() - start

    println("Bench result sum: {result}")

    println("")
    println("=== Benchmark: Binary Search Insert ===")
    println("Array size: {n}")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
