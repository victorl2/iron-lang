import time

-- Match statement: state machine simulation using match for transitions
-- States: 0=IDLE, 1=RUNNING, 2=BLOCKED, 3=READY, 4=TERMINATED

func transition(state: Int, event: Int) -> Int {
    -- event: 0=start, 1=block, 2=unblock, 3=schedule, 4=finish, 5=reset
    match state {
        0 {
            -- IDLE
            match event {
                0 { return 3 }
                5 { return 0 }
                else { return 0 }
            }
        }
        1 {
            -- RUNNING
            match event {
                1 { return 2 }
                4 { return 4 }
                else { return 1 }
            }
        }
        2 {
            -- BLOCKED
            match event {
                2 { return 3 }
                4 { return 4 }
                else { return 2 }
            }
        }
        3 {
            -- READY
            match event {
                3 { return 1 }
                4 { return 4 }
                else { return 3 }
            }
        }
        4 {
            -- TERMINATED
            match event {
                5 { return 0 }
                else { return 4 }
            }
        }
        else { return 0 }
    }
    return 0
}

func classify(v: Int) -> Int {
    -- Return a category based on value range using match
    val bucket = v % 10
    match bucket {
        0 { return 100 }
        1 { return 200 }
        2 { return 300 }
        3 { return 400 }
        4 { return 500 }
        5 { return 600 }
        6 { return 700 }
        7 { return 800 }
        8 { return 900 }
        9 { return 1000 }
        else { return 0 }
    }
    return 0
}

func simulate(steps: Int) -> Int {
    var state = 0
    var checksum = 0
    var i = 0
    while i < steps {
        val event = (i * 7 + 3) % 6
        state = transition(state, event)
        checksum = checksum + state * (i + 1)
        checksum = checksum + classify(i)
        i = i + 1
    }
    return checksum
}

func main() {
    -- Tests
    println("Test 1 transition(0,0): {transition(0, 0)} (expected 3)")
    println("Test 2 transition(3,3): {transition(3, 3)} (expected 1)")
    println("Test 3 transition(1,1): {transition(1, 1)} (expected 2)")
    println("Test 4 transition(2,2): {transition(2, 2)} (expected 3)")
    println("Test 5 transition(1,4): {transition(1, 4)} (expected 4)")
    println("Test 6 classify(7): {classify(7)} (expected 800)")

    val check = simulate(200)
    println("Test 7 simulate(200): {check}")

    -- Benchmark
    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = simulate(200)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Match State Machine ===")
    println("Steps: 200")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
