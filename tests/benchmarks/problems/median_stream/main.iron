import time

-- Running median via two heaps (max-heap for lower half, min-heap for upper half)
-- Using integer median (floor of average when even count)

func heap_up_max(heap: [Int], idx: Int) {
    var i = idx
    while i > 0 {
        val parent = (i - 1) / 2
        if heap[i] > heap[parent] {
            val temp = heap[i]
            heap[i] = heap[parent]
            heap[parent] = temp
            i = parent
        } else {
            i = 0
        }
    }
}

func heap_down_max(heap: [Int], size: Int, idx: Int) {
    var i = idx
    var cont = 1
    while cont == 1 {
        var largest = i
        val l = 2 * i + 1
        val r = 2 * i + 2
        if l < size {
            if heap[l] > heap[largest] { largest = l }
        }
        if r < size {
            if heap[r] > heap[largest] { largest = r }
        }
        if largest == i {
            cont = 0
        } else {
            val temp = heap[i]
            heap[i] = heap[largest]
            heap[largest] = temp
            i = largest
        }
    }
}

func heap_up_min(heap: [Int], idx: Int) {
    var i = idx
    while i > 0 {
        val parent = (i - 1) / 2
        if heap[i] < heap[parent] {
            val temp = heap[i]
            heap[i] = heap[parent]
            heap[parent] = temp
            i = parent
        } else {
            i = 0
        }
    }
}

func heap_down_min(heap: [Int], size: Int, idx: Int) {
    var i = idx
    var cont = 1
    while cont == 1 {
        var smallest = i
        val l = 2 * i + 1
        val r = 2 * i + 2
        if l < size {
            if heap[l] < heap[smallest] { smallest = l }
        }
        if r < size {
            if heap[r] < heap[smallest] { smallest = r }
        }
        if smallest == i {
            cont = 0
        } else {
            val temp = heap[i]
            heap[i] = heap[smallest]
            heap[smallest] = temp
            i = smallest
        }
    }
}

func median_stream(nums: [Int], n: Int) -> Int {
    -- max_heap: lower half, min_heap: upper half
    var max_heap = fill(n, 0)
    var min_heap = fill(n, 0)
    var max_size = 0
    var min_size = 0
    var last_median = 0

    for i in range(n) {
        val num = nums[i]

        -- Add to appropriate heap
        if max_size == 0 {
            max_heap[0] = num
            max_size = 1
        } else {
            if num <= max_heap[0] {
                max_heap[max_size] = num
                max_size = max_size + 1
                heap_up_max(max_heap, max_size - 1)
            } else {
                min_heap[min_size] = num
                min_size = min_size + 1
                heap_up_min(min_heap, min_size - 1)
            }
        }

        -- Balance heaps: max_heap can have at most 1 more than min_heap
        if max_size > min_size + 1 {
            -- Move top of max to min
            val top = max_heap[0]
            max_size = max_size - 1
            max_heap[0] = max_heap[max_size]
            heap_down_max(max_heap, max_size, 0)
            min_heap[min_size] = top
            min_size = min_size + 1
            heap_up_min(min_heap, min_size - 1)
        }
        if min_size > max_size {
            -- Move top of min to max
            val top = min_heap[0]
            min_size = min_size - 1
            min_heap[0] = min_heap[min_size]
            heap_down_min(min_heap, min_size, 0)
            max_heap[max_size] = top
            max_size = max_size + 1
            heap_up_max(max_heap, max_size - 1)
        }

        -- Compute median
        if (max_size + min_size) % 2 == 1 {
            last_median = max_heap[0]
        } else {
            last_median = (max_heap[0] + min_heap[0]) / 2
        }
    }
    return last_median
}

func main() {
    val a1 = [2, 1, 5, 7, 2, 0, 5]
    println("Test 1: {median_stream(a1, 7)} (expected 2)")

    val a2 = [1, 2, 3, 4]
    println("Test 2: {median_stream(a2, 4)} (expected 2)")

    val a3 = [5, 15, 1, 3]
    println("Test 3: {median_stream(a3, 4)} (expected 4)")

    -- Benchmark: 100 insertions
    val n = 100
    var nums = fill(n, 0)
    for i in range(n) {
        nums[i] = (i * 31 + 17) % 200
    }
    val check = median_stream(nums, n)
    println("Bench check: {check}")

    val iterations = 100000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = median_stream(nums, n)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Median Stream ===")
    println("Stream size: {n}")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
