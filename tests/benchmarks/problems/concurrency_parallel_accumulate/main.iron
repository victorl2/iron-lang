import time

-- Concurrency Parallel Accumulate: parallel-for writes independent results,
-- sequential aggregation after. Verifies copy-prop/DCE don't eliminate
-- parallel writes. Pattern: compute seq checksum, run parallel, recompute.

func compute_elem(idx: Int) -> Int {
    var h = idx * 37 + 1
    var k = 0
    while k < 80 {
        h = (h * 1000003 + idx * k) % 1000000007
        k = k + 1
    }
    return h
}

func accumulate_checksum(n: Int) -> Int {
    var total = 0
    var running = 0
    var i = 0
    while i < n {
        val elem = compute_elem(i)
        running = (running * 31 + elem) % 1000000007
        total = (total + running) % 1000000007
        i = i + 1
    }
    return total
}

func main() {
    val n = 2000

    -- Sequential checksum (ground truth)
    val seq_checksum = accumulate_checksum(n)

    -- Parallel section: each iteration computes element independently
    val start = Time.now_ms()
    val iters = 3
    for iter in range(iters) {
        for i in n parallel {
            val elem = compute_elem(i)
        }
    }
    val elapsed = Time.now_ms() - start

    -- Recompute to verify: parallel writes didn't corrupt memory
    val par_checksum = accumulate_checksum(n)

    println("Sequential checksum: {seq_checksum}")
    println("Parallel checksum: {par_checksum}")
    var is_match = 0
    if seq_checksum == par_checksum {
        is_match = 1
    }
    println("Match: {is_match}")

    println("")
    println("=== Benchmark: Concurrency Parallel Accumulate ===")
    println("N={n}")
    println("Total time: {elapsed} ms")
}
