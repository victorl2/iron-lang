import time

-- Palindrome Check: two-pointer approach on Int arrays (1-26 for a-z)

func is_palindrome(arr: [Int], n: Int) -> Int {
    var left = 0
    var right = n - 1
    while left < right {
        if arr[left] != arr[right] {
            return 0
        }
        left = left + 1
        right = right - 1
    }
    return 1
}

func main() {
    -- Test 1: "racecar" -> [18,1,3,5,3,1,18]
    val t1 = [18, 1, 3, 5, 3, 1, 18]
    println("Test 1: {is_palindrome(t1, 7)} (expected 1)")

    -- Test 2: "hello" -> [8,5,12,12,15]
    val t2 = [8, 5, 12, 12, 15]
    println("Test 2: {is_palindrome(t2, 5)} (expected 0)")

    -- Test 3: "abba" -> [1,2,2,1]
    val t3 = [1, 2, 2, 1]
    println("Test 3: {is_palindrome(t3, 4)} (expected 1)")

    -- Test 4: single element
    val t4 = [5]
    println("Test 4: {is_palindrome(t4, 1)} (expected 1)")

    -- Build benchmark: 100-element palindrome
    var bench = fill(100, 0)
    for i in range(50) {
        val v = i % 26 + 1
        bench[i] = v
        bench[99 - i] = v
    }
    println("Test 5: {is_palindrome(bench, 100)} (expected 1)")

    val iterations = 10000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = is_palindrome(bench, 100)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Palindrome Check ===")
    println("Array size: 100")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
