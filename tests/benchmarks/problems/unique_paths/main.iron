import time

func unique_paths(m: Int, n: Int) -> Int {
    var dp = fill(m * n, 0)
    var i = 0
    while i < m {
        var j = 0
        while j < n {
            if i == 0 {
                dp[i * n + j] = 1
            } elif j == 0 {
                dp[i * n + j] = 1
            } else {
                dp[i * n + j] = dp[(i - 1) * n + j] + dp[i * n + (j - 1)]
            }
            j = j + 1
        }
        i = i + 1
    }
    return dp[(m - 1) * n + (n - 1)]
}

func main() {
    println("Test 1: {unique_paths(3, 7)} (expected 28)")
    println("Test 2: {unique_paths(15, 15)} (expected 40116600)")

    val iterations = 1000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = unique_paths(15, 15)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Unique Paths ===")
    println("Grid: 15x15")
    println("Iterations: {iterations}")
    println("Result: {result}")
    println("Total time: {elapsed} ms")
}
