import time

-- Jump Game II: Min jumps to reach end (greedy BFS-style)

func jump_game_ii(arr: [Int], n: Int) -> Int {
    if n <= 1 {
        return 0
    }
    var jumps = 0
    var current_end = 0
    var farthest = 0
    var i = 0
    while i < n - 1 {
        val reach = i + arr[i]
        if reach > farthest {
            farthest = reach
        }
        if i == current_end {
            jumps = jumps + 1
            current_end = farthest
            if current_end >= n - 1 {
                return jumps
            }
        }
        i = i + 1
    }
    return jumps
}

func main() {
    val a1 = [2, 3, 1, 1, 4]
    println("Test 1: {jump_game_ii(a1, 5)} (expected 2)")

    val a2 = [2, 3, 0, 1, 4]
    println("Test 2: {jump_game_ii(a2, 5)} (expected 2)")

    val a3 = [1, 1, 1, 1, 1]
    println("Test 3: {jump_game_ii(a3, 5)} (expected 4)")

    -- Benchmark: array of 100
    val n = 100
    var bench = fill(n, 0)
    for i in range(n) {
        bench[i] = (i * 3 + 7) % 10 + 1
    }
    val check = jump_game_ii(bench, n)
    println("Bench check: {check}")

    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = jump_game_ii(bench, n)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Jump Game II ===")
    println("Array size: {n}")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
