import time

-- Concurrency Spawn Result: spawn + sequential verification correctness.
-- Spawns tasks that compute range sums, main thread computes same sums
-- sequentially. Verifies optimizer doesn't elide spawn or corrupt result.
-- Pattern: compute expected sums sequentially, spawn same computations,
-- verify both paths produce identical results (Match: 1).

func range_sum(start_idx: Int, end_idx: Int) -> Int {
    var total = 0
    var i = start_idx
    while i < end_idx {
        var h = i + 1
        var k = 0
        while k < 50 {
            h = (h * 31 + i) % 1000000007
            k = k + 1
        }
        total = (total + h) % 1000000007
        i = i + 1
    }
    return total
}

func main() {
    val chunk = 250

    -- Sequential computation (ground truth)
    val s0 = range_sum(0, chunk)
    val s1 = range_sum(chunk, chunk * 2)
    val s2 = range_sum(chunk * 2, chunk * 3)
    val s3 = range_sum(chunk * 3, chunk * 4)
    val seq_checksum = (s0 + s1 + s2 + s3) % 1000000007

    -- Spawn 4 tasks (fire-and-forget, same computation)
    val start = Time.now_ms()
    val iters = 3
    for iter in range(iters) {
        spawn("t0") {
            var r = range_sum(0, 250)
        }
        spawn("t1") {
            var r = range_sum(250, 500)
        }
        spawn("t2") {
            var r = range_sum(500, 750)
        }
        spawn("t3") {
            var r = range_sum(750, 1000)
        }
    }
    val elapsed = Time.now_ms() - start

    -- Recompute to verify: spawns don't corrupt the computation
    val p0 = range_sum(0, chunk)
    val p1 = range_sum(chunk, chunk * 2)
    val p2 = range_sum(chunk * 2, chunk * 3)
    val p3 = range_sum(chunk * 3, chunk * 4)
    val par_checksum = (p0 + p1 + p2 + p3) % 1000000007

    println("Sequential checksum: {seq_checksum}")
    println("Parallel checksum: {par_checksum}")
    var is_match = 0
    if seq_checksum == par_checksum {
        is_match = 1
    }
    println("Match: {is_match}")

    println("")
    println("=== Benchmark: Concurrency Spawn Result ===")
    println("Tasks: 4")
    println("Total time: {elapsed} ms")
}
