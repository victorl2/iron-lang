import time

func partition_equal_subset(nums: [Int], n: Int) -> Int {
    var total = 0
    for i in range(n) {
        total = total + nums[i]
    }
    if total % 2 != 0 {
        return 0
    }
    val target = total / 2
    var dp = fill(target + 1, 0)
    dp[0] = 1
    var i = 0
    while i < n {
        var s = target
        while s >= nums[i] {
            if dp[s - nums[i]] == 1 {
                dp[s] = 1
            }
            s = s - 1
        }
        i = i + 1
    }
    return dp[target]
}

func main() {
    val a1 = [1, 5, 11, 5]
    println("Test 1: {partition_equal_subset(a1, 4)} (expected 1)")
    val a2 = [1, 2, 3, 5]
    println("Test 2: {partition_equal_subset(a2, 4)} (expected 0)")

    var bench = fill(20, 0)
    for i in range(20) {
        bench[i] = (i * 3 + 1) % 10 + 1
    }
    println("Test 3: {partition_equal_subset(bench, 20)} (expected 1)")

    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = partition_equal_subset(bench, 20)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Partition Equal Subset Sum ===")
    println("Array size: 20")
    println("Iterations: {iterations}")
    println("Result: {result}")
    println("Total time: {elapsed} ms")
}
