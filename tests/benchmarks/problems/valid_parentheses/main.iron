import time

-- Valid Parentheses: check if sequence of encoded brackets is balanced
-- Encoding: ( = 1, ) = 2, [ = 3, ] = 4, { = 5, } = 6

func is_open(c: Int) -> Int {
    if c == 1 { return 1 }
    if c == 3 { return 1 }
    if c == 5 { return 1 }
    return 0
}

func matches(open: Int, close: Int) -> Int {
    if open == 1 and close == 2 { return 1 }
    if open == 3 and close == 4 { return 1 }
    if open == 5 and close == 6 { return 1 }
    return 0
}

func is_valid(arr: [Int], n: Int) -> Int {
    var stack = fill(100, 0)
    var top = 0
    for i in range(n) {
        val c = arr[i]
        if is_open(c) == 1 {
            stack[top] = c
            top = top + 1
        } else {
            if top == 0 {
                return 0
            }
            top = top - 1
            if matches(stack[top], c) == 0 {
                return 0
            }
        }
    }
    if top == 0 { return 1 }
    return 0
}

func main() {
    -- Test 1: "()" -> [1, 2] => valid
    val t1 = [1, 2]
    println("Test 1: {is_valid(t1, 2)} (expected 1)")

    -- Test 2: "()[]{}" -> [1, 2, 3, 4, 5, 6] => valid
    val t2 = [1, 2, 3, 4, 5, 6]
    println("Test 2: {is_valid(t2, 6)} (expected 1)")

    -- Test 3: "(]" -> [1, 4] => invalid
    val t3 = [1, 4]
    println("Test 3: {is_valid(t3, 2)} (expected 0)")

    -- Test 4: "({[]})" -> [1, 5, 3, 4, 6, 2] => valid
    val t4 = [1, 5, 3, 4, 6, 2]
    println("Test 4: {is_valid(t4, 6)} (expected 1)")

    -- Build benchmark array: 50 balanced parens "((((...))))" pattern
    var bench = fill(50, 0)
    for i in range(25) {
        bench[i] = 1
    }
    for i in range(25) {
        bench[25 + i] = 2
    }
    println("Test 5: {is_valid(bench, 50)} (expected 1)")

    val iterations = 1000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = is_valid(bench, 50)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Valid Parentheses ===")
    println("Sequence length: 50")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
