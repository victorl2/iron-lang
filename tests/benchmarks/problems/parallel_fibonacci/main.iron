import time

-- Parallel Fibonacci: compute recursive fibonacci for many values in parallel.
-- Recursive fibonacci is inherently resistant to compiler optimization.
-- Each parallel iteration independently computes fib(N) for varying N.

func fib(n: Int) -> Int {
  if n <= 1 {
    return n
  }
  return fib(n - 1) + fib(n - 2)
}

func compute_fib_for_index(idx: Int) -> Int {
  -- Map idx to a fibonacci number to compute: fib(28 + idx % 6)
  -- This gives fib values from fib(28) to fib(33), varying difficulty
  return fib(28 + idx % 6)
}

func main() {
  val n = 150

  -- Correctness: sequential checksum
  var checksum = 0
  for i in range(n) {
    checksum = checksum + compute_fib_for_index(i)
  }
  println("checksum: {checksum}")

  -- Benchmark: sequential
  val iterations = 1
  var seq_total = 0
  val start_seq = Time.now_ms()
  for iter in range(iterations) {
    for i in range(n) {
      seq_total = seq_total + compute_fib_for_index(i)
    }
  }
  val elapsed_seq = Time.now_ms() - start_seq

  -- Benchmark: parallel (each iteration computes fib independently)
  val start_par = Time.now_ms()
  for iter in range(iterations) {
    for i in n parallel {
      val x = compute_fib_for_index(i)
    }
  }
  val elapsed_par = Time.now_ms() - start_par

  println("")
  println("=== Benchmark: Parallel Fibonacci ===")
  println("Work items: {n}")
  println("Iterations: {iterations}")
  println("Sequential time: {elapsed_seq} ms")
  println("Parallel time: {elapsed_par} ms")
  println("Seq verify: {seq_total}")
  println("Total time: {elapsed_par} ms")
}
