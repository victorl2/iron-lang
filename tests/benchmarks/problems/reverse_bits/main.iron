import time

-- Reverse Bits of a 32-bit integer using arithmetic (mod/div)
-- Since Iron lacks bitwise operators, use result*2 + (x%2) and x/2

func reverse_bits(n: Int) -> Int {
    var result = 0
    var x = n
    for i in range(32) {
        result = result * 2 + (x % 2)
        x = x / 2
    }
    return result
}

func run_reverse_bits_batch() -> Int {
    var total = 0
    for i in range(1000000) {
        total = total + reverse_bits(i)
    }
    return total
}

func main() {
    println("Test 1: {reverse_bits(43261596)} (expected 964176192)")
    println("Test 2: {reverse_bits(1)} (expected 2147483648)")
    println("Test 3: {reverse_bits(0)} (expected 0)")

    -- Correctness check: sum of reverse_bits for 1M values
    val check = run_reverse_bits_batch()
    println("Test 4: {check} (expected 2147474564972544)")

    -- Benchmark: repeat 6 times for stable C time > 200ms
    val iterations = 6
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = run_reverse_bits_batch()
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Reverse Bits ===")
    println("Values: 6000000")
    println("Total time: {elapsed} ms")
}
