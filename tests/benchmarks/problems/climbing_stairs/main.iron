import time

func climb_stairs(n: Int) -> Int {
    if n <= 2 {
        return n
    }
    var prev2 = 1
    var prev1 = 2
    var i = 3
    while i <= n {
        val curr = prev1 + prev2
        prev2 = prev1
        prev1 = curr
        i = i + 1
    }
    return prev1
}

func main() {
    println("Test 1: {climb_stairs(5)} (expected 8)")
    println("Test 2: {climb_stairs(10)} (expected 89)")
    println("Test 3: {climb_stairs(35)} (expected 14930352)")

    val iterations = 250000000
    val start_ns = Time.now_ns()
    var result = 0
    for it in range(iterations) {
        result = result + climb_stairs(30 + (it % 6))
    }
    val elapsed_ns = Time.now_ns() - start_ns
    val elapsed_ms = elapsed_ns / 1000000

    println("")
    println("=== Benchmark: Climbing Stairs ===")
    println("n=35")
    println("Iterations: {iterations}")
    println("Result: {result}")
    println("Total time: {elapsed_ns} ns")
    println("Total time: {elapsed_ms} ms")
}
