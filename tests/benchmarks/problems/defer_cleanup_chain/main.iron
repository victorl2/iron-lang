import time

-- Multi-exit functions: exercises multiple early returns, condition branching,
-- and function call overhead with various code paths

func classify(n: Int) -> Int {
    if n < 0 { return 0 }
    if n == 0 { return 1 }
    if n % 7 == 0 { return 7 }
    if n % 5 == 0 { return 5 }
    if n % 3 == 0 { return 3 }
    if n % 2 == 0 { return 2 }
    return n % 100
}

func process(idx: Int, depth: Int) -> Int {
    if depth <= 0 {
        return idx % 997
    }
    val v = (idx * 31 + 17) % 10007
    if v % 3 == 0 {
        return v
    }
    if v % 5 == 0 {
        return v + 1
    }
    return v + process(v, depth - 1) % 1000
}

func bench_multi_exit(n: Int) -> Int {
    var checksum = 0
    var i = 0
    while i < n {
        checksum = checksum + classify(i)
        checksum = checksum + process(i * 73 + 29, 4) % 10000
        i = i + 1
    }
    return checksum
}

func main() {
    println("Test 1 classify(0): {classify(0)} (expected 1)")
    println("Test 2 classify(14): {classify(14)} (expected 7)")
    println("Test 3 classify(10): {classify(10)} (expected 5)")
    println("Test 4 classify(9): {classify(9)} (expected 3)")
    println("Test 5 process(100,0): {process(100, 0)} (expected 100)")

    val check = bench_multi_exit(200)
    println("Test 6 bench(200): {check}")

    val iterations = 200000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = bench_multi_exit(200)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Multi-Exit Functions ===")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
