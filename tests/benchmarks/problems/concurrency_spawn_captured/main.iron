import time

-- Concurrency Spawn Captured: spawn uses precomputed values (no captures).
-- Verifies expression inlining doesn't skip values across spawn boundary.
-- Pattern: compute using a fixed seed, spawn tasks with same seed constant,
-- verify both paths produce identical checksums (Match: 1).

func compute_with_seed(seed: Int, n: Int) -> Int {
    var h = seed
    var i = 0
    while i < n {
        h = (h * 1000003 + i * 37) % 1000000007
        i = i + 1
    }
    return h
}

-- Compute the precomputed seed (same constant each call)
func get_seed() -> Int {
    return compute_with_seed(42, 100)
}

func main() {
    val n = 50000

    -- Sequential computation using a fixed seed (ground truth)
    val seed = get_seed()
    val r0 = compute_with_seed(seed, n)
    val r1 = compute_with_seed(seed + 1, n)
    val r2 = compute_with_seed(seed + 2, n)
    val seq_checksum = (r0 + r1 + r2) % 1000000007

    -- Spawn tasks: each recomputes the seed inside the spawn (no captures)
    val start = Time.now_ms()
    val iters = 100
    for iter in range(iters) {
        spawn("s0") {
            val s = get_seed()
            var x = compute_with_seed(s, 50000)
        }
        spawn("s1") {
            val s = get_seed()
            var x = compute_with_seed(s + 1, 500)
        }
        spawn("s2") {
            val s = get_seed()
            var x = compute_with_seed(s + 2, 500)
        }
    }
    val elapsed = Time.now_ms() - start

    -- Recompute to verify: same seed, same results
    val p_seed = get_seed()
    val p0 = compute_with_seed(p_seed, n)
    val p1 = compute_with_seed(p_seed + 1, n)
    val p2 = compute_with_seed(p_seed + 2, n)
    val par_checksum = (p0 + p1 + p2) % 1000000007

    println("Sequential checksum: {seq_checksum}")
    println("Parallel checksum: {par_checksum}")
    var is_match = 0
    if seq_checksum == par_checksum {
        is_match = 1
    }
    println("Match: {is_match}")

    println("")
    println("=== Benchmark: Concurrency Spawn Captured ===")
    println("Seed={seed}")
    println("Total time: {elapsed} ms")
}
