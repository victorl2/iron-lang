import time

func reverse_range(arr: [Int], lo_in: Int, hi_in: Int) -> Int {
    var lo = lo_in
    var hi = hi_in
    while lo < hi {
        val tmp = arr[lo]
        arr[lo] = arr[hi]
        arr[hi] = tmp
        lo = lo + 1
        hi = hi - 1
    }
    return 0
}

func rotate_array(arr: [Int], n: Int, k: Int) -> Int {
    val kk = k % n
    if kk > 0 {
        val d1 = reverse_range(arr, 0, n - 1)
        val d2 = reverse_range(arr, 0, kk - 1)
        val d3 = reverse_range(arr, kk, n - 1)
    }
    var sum = 0
    for i in range(n) {
        sum = sum + arr[i] * (i + 1)
    }
    return sum
}

func main() {
    var a1 = [1, 2, 3, 4, 5, 6, 7]
    println("Test 1: {rotate_array(a1, 7, 3)}")

    var a2 = [10, 20, 30, 40, 50]
    println("Test 2: {rotate_array(a2, 5, 2)}")

    -- Benchmark: 100 elements, arr[i] = i, rotate by 37
    var bench_orig = fill(100, 0)
    for i in range(100) {
        bench_orig[i] = i
    }

    var bench = fill(100, 0)
    for i in range(100) {
        bench[i] = bench_orig[i]
    }
    println("Test 3: {rotate_array(bench, 100, 37)}")

    val iterations = 1000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        var tmp = fill(100, 0)
        for i in range(100) {
            tmp[i] = bench_orig[i]
        }
        result = rotate_array(tmp, 100, 37)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Rotate Array ===")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
