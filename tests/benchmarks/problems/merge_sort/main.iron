import time

func merge(arr: [Int], tmp: [Int], lo: Int, mid: Int, hi: Int) -> Int {
    var x = lo
    while x <= hi {
        tmp[x] = arr[x]
        x = x + 1
    }
    var i = lo
    var j = mid + 1
    var k = lo
    while i <= mid {
        if j <= hi {
            if tmp[i] <= tmp[j] {
                arr[k] = tmp[i]
                i = i + 1
            } else {
                arr[k] = tmp[j]
                j = j + 1
            }
        } else {
            arr[k] = tmp[i]
            i = i + 1
        }
        k = k + 1
    }
    while j <= hi {
        arr[k] = tmp[j]
        j = j + 1
        k = k + 1
    }
    return 0
}

func merge_sort_rec(arr: [Int], tmp: [Int], lo: Int, hi: Int) -> Int {
    if lo < hi {
        val mid = lo + (hi - lo) / 2
        val d1 = merge_sort_rec(arr, tmp, lo, mid)
        val d2 = merge_sort_rec(arr, tmp, mid + 1, hi)
        val d3 = merge(arr, tmp, lo, mid, hi)
    }
    return 0
}

func merge_sort_checksum(orig: [Int], n: Int) -> Int {
    var arr = fill(n, 0)
    var tmp = fill(n, 0)
    for i in range(n) {
        arr[i] = orig[i]
    }
    val dummy = merge_sort_rec(arr, tmp, 0, n - 1)
    var sum = 0
    for i in range(n) {
        sum = sum + arr[i] * (i + 1)
    }
    return sum
}

func main() {
    val a1 = [3, 6, 8, 10, 1, 2, 1]
    println("Test 1: {merge_sort_checksum(a1, 7)}")

    val a2 = [5, 4, 3, 2, 1]
    println("Test 2: {merge_sort_checksum(a2, 5)} (expected 55)")

    val a3 = [1, 1, 1, 1]
    println("Test 3: {merge_sort_checksum(a3, 4)} (expected 10)")

    -- Benchmark: 200 elements
    var bench = fill(200, 0)
    for i in range(200) {
        bench[i] = (i * 37 + 13) % 1000
    }
    println("Test 4: {merge_sort_checksum(bench, 200)}")

    val iterations = 100000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = merge_sort_checksum(bench, 200)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Merge Sort ===")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
