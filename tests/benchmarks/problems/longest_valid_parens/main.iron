import time

-- Simplified DP approach using Two-Pass O(1) space algorithm
-- '(' encoded as 1, ')' as 0
func longest_valid(s: [Int], n: Int) -> Int {
    var left = 0
    var right = 0
    var max_len = 0

    -- Left to right pass
    var i = 0
    while i < n {
        if s[i] == 1 {
            left = left + 1
        } else {
            right = right + 1
        }
        if left == right {
            if left + right > max_len {
                max_len = left + right
            }
        }
        if right > left {
            left = 0
            right = 0
        }
        i = i + 1
    }

    -- Right to left pass
    left = 0
    right = 0
    i = n - 1
    while i >= 0 {
        if s[i] == 1 {
            left = left + 1
        } else {
            right = right + 1
        }
        if left == right {
            if left + right > max_len {
                max_len = left + right
            }
        }
        if left > right {
            left = 0
            right = 0
        }
        i = i - 1
    }
    return max_len
}

func main() {
    val t1 = [1, 0]
    val t2 = [1, 0, 0, 1]
    println("Test 1: {longest_valid(t1, 2)} (expected 2)")
    println("Test 2: {longest_valid(t2, 4)} (expected 2)")

    -- 100 '(' followed by 100 ')' => longest valid = 200
    var s = fill(200, 0)
    for i in range(100) {
        s[i] = 1
    }
    println("Test 3: {longest_valid(s, 200)} (expected 200)")

    val iterations = 200000
    val start_ns = Time.now_ns()
    var result = 0
    for it in range(iterations) {
        result = result + longest_valid(s, 190 + (it % 11))
    }
    val elapsed_ns = Time.now_ns() - start_ns
    val elapsed_ms = elapsed_ns / 1000000

    println("")
    println("=== Benchmark: Longest Valid Parentheses ===")
    println("String length: 200")
    println("Iterations: {iterations}")
    println("Total time: {elapsed_ns} ns")
    println("Total time: {elapsed_ms} ms")
    println("Memory: (see process stats)")
    println("Result: {result}")
}
