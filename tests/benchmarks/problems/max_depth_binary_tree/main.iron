import time

-- Maximum depth of binary tree stored as array
-- Iterative approach using stack with (node, depth) pairs

func max_depth(vals: [Int], size: Int) -> Int {
    if size == 0 {
        return 0
    }
    var stack_node = fill(64, 0)
    var stack_depth = fill(64, 0)
    var top = 0
    stack_node[top] = 0
    stack_depth[top] = 1
    top = top + 1
    var max_d = 0

    while top > 0 {
        top = top - 1
        val node = stack_node[top]
        val depth = stack_depth[top]
        if depth > max_d {
            max_d = depth
        }

        val lc = 2 * node + 1
        val rch = 2 * node + 2
        if lc < size {
            stack_node[top] = lc
            stack_depth[top] = depth + 1
            top = top + 1
        }
        if rch < size {
            stack_node[top] = rch
            stack_depth[top] = depth + 1
            top = top + 1
        }
    }
    return max_d
}

func main() {
    val tree_vals = [50, 25, 75, 12, 37, 62, 87, 6, 18, 31, 43, 56, 68, 81, 93,
                     3, 9, 15, 21, 28, 34, 40, 46, 53, 59, 65, 71, 78, 84, 90, 96]
    val tree_size = 31

    println("Test 1: {max_depth(tree_vals, tree_size)} (expected 5)")

    val small = [2, 1, 3]
    println("Test 2: {max_depth(small, 3)} (expected 2)")

    val single = [42]
    println("Test 3: {max_depth(single, 1)} (expected 1)")

    -- 7-node tree (3 levels)
    val tree7 = [10, 5, 15, 3, 7, 12, 20]
    println("Test 4: {max_depth(tree7, 7)} (expected 3)")

    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = max_depth(tree_vals, tree_size)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Max Depth Binary Tree ===")
    println("Tree size: {tree_size}")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
