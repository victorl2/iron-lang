import time

func max_subarray(nums: [Int], n: Int) -> Int {
    var max_sum = nums[0]
    var cur_sum = nums[0]
    var i = 1
    while i < n {
        if cur_sum < 0 {
            cur_sum = nums[i]
        } else {
            cur_sum = cur_sum + nums[i]
        }
        if cur_sum > max_sum {
            max_sum = cur_sum
        }
        i = i + 1
    }
    return max_sum
}

func main() {
    val a1 = [-2, 1, -3, 4, -1, 2, 1, -5, 4]
    println("Test 1: {max_subarray(a1, 9)} (expected 6)")

    val a2 = [1]
    println("Test 2: {max_subarray(a2, 1)} (expected 1)")

    val a3 = [5, 4, -1, 7, 8]
    println("Test 3: {max_subarray(a3, 5)} (expected 23)")

    -- Benchmark: 100 elements
    var bench = fill(100, 0)
    for i in range(100) {
        bench[i] = ((i * 17 + 11) % 201) - 100
    }
    println("Test 4: {max_subarray(bench, 100)}")

    val iterations = 10000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = max_subarray(bench, 100)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Maximum Subarray ===")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
