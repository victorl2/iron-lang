import time

func max_repeated_subarray(a: [Int], na: Int, b: [Int], nb: Int) -> Int {
    val cols = nb + 1
    var dp = fill((na + 1) * cols, 0)
    var best = 0
    var i = 1
    while i <= na {
        var j = 1
        while j <= nb {
            if a[i - 1] == b[j - 1] {
                dp[i * cols + j] = dp[(i - 1) * cols + (j - 1)] + 1
                if dp[i * cols + j] > best {
                    best = dp[i * cols + j]
                }
            } else {
                dp[i * cols + j] = 0
            }
            j = j + 1
        }
        i = i + 1
    }
    return best
}

func main() {
    val a1 = [1, 2, 3, 2, 1]
    val b1 = [3, 2, 1, 4, 7]
    println("Test 1: {max_repeated_subarray(a1, 5, b1, 5)} (expected 3)")

    var a2 = fill(30, 0)
    var b2 = fill(30, 0)
    for i in range(30) {
        a2[i] = i % 8
        b2[i] = (i + 3) % 8
    }
    println("Test 2: {max_repeated_subarray(a2, 30, b2, 30)} (expected 27)")

    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = max_repeated_subarray(a2, 30, b2, 30)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Max Length Repeated Subarray ===")
    println("Array sizes: 30, 30")
    println("Iterations: {iterations}")
    println("Result: {result}")
    println("Total time: {elapsed} ms")
}
