import time

-- Sentinel-based optional patterns (simulates nullable without Int? return issues)
-- Uses -1 sentinel for "not found" / "error", exercises conditional branches heavily

func find_index(arr: [Int], n: Int, target: Int) -> Int {
    var i = 0
    while i < n {
        if arr[i] == target {
            return i
        }
        i = i + 1
    }
    return -1
}

func safe_divide(a: Int, b: Int) -> Int {
    if b == 0 {
        return -1
    }
    return a / b
}

func optional_chain(x: Int) -> Int {
    var result = -1
    if x % 2 == 0 {
        result = x * 3
    }
    if result != -1 {
        val v = result + 10
        val div = safe_divide(v, x % 7 + 1)
        if div != -1 {
            return div
        }
        return v
    }
    return 0
}

func bench_optional(n: Int, arr: [Int], arr_len: Int) -> Int {
    var checksum = 0
    var i = 0
    while i < n {
        val idx = find_index(arr, arr_len, i % (arr_len + 5))
        if idx != -1 {
            checksum = checksum + idx
        } else {
            checksum = checksum + 999
        }
        val d = safe_divide(i * 17 + 3, i % 5)
        if d != -1 {
            checksum = checksum + d % 1000
        }
        checksum = checksum + optional_chain(i)
        i = i + 1
    }
    return checksum
}

func main() {
    val arr = [10, 20, 30, 40, 50]
    println("Test 1 found: {find_index(arr, 5, 30)} (expected 2)")
    println("Test 2 not found: {find_index(arr, 5, 99)} (expected -1)")
    println("Test 3 divide: {safe_divide(100, 3)} (expected 33)")
    println("Test 4 div-by-zero: {safe_divide(100, 0)} (expected -1)")
    println("Test 5 chain(4): {optional_chain(4)} (expected 4)")
    println("Test 6 chain(3): {optional_chain(3)} (expected 0)")

    var bench_arr = fill(50, 0)
    for i in range(50) {
        bench_arr[i] = i
    }
    val check = bench_optional(200, bench_arr, 50)
    println("Test 7 bench(200): {check}")

    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = bench_optional(200, bench_arr, 50)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Nullable Types ===")
    println("Elements: 200")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
