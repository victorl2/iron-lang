import time

-- Nullable types: exercises Int? nullable declarations, null checks, and null propagation
-- Uses nullable variables for optional lookup results and conditional arithmetic

func find_index(arr: [Int], n: Int, target: Int) -> Int? {
    var i = 0
    while i < n {
        if arr[i] == target {
            return i
        }
        i = i + 1
    }
    return null
}

func safe_divide(a: Int, b: Int) -> Int? {
    if b == 0 {
        return null
    }
    return a / b
}

func nullable_chain(x: Int) -> Int {
    -- Chain of nullable operations: simulate optional lookups
    var result: Int? = null
    if x % 2 == 0 {
        result = x * 3
    }
    if result != null {
        val v = result + 10
        val div = safe_divide(v, x % 7 + 1)
        if div != null {
            return div
        }
        return v
    }
    return 0
}

func bench_nullable(n: Int, arr: [Int], arr_len: Int) -> Int {
    var checksum = 0
    var i = 0
    while i < n {
        -- Nullable find
        val idx = find_index(arr, arr_len, i % (arr_len + 5))
        if idx != null {
            checksum = checksum + idx
        } else {
            checksum = checksum + 999
        }

        -- Nullable divide
        val d = safe_divide(i * 17 + 3, i % 5)
        if d != null {
            checksum = checksum + d % 1000
        }

        -- Nullable chain
        checksum = checksum + nullable_chain(i)

        i = i + 1
    }
    return checksum
}

func main() {
    -- Tests
    val arr = [10, 20, 30, 40, 50]
    val found = find_index(arr, 5, 30)
    if found != null {
        println("Test 1 found: {found} (expected 2)")
    }
    val not_found = find_index(arr, 5, 99)
    if not_found == null {
        println("Test 2 not found: null (expected null)")
    }

    val div1 = safe_divide(100, 3)
    if div1 != null {
        println("Test 3 divide: {div1} (expected 33)")
    }
    val div0 = safe_divide(100, 0)
    if div0 == null {
        println("Test 4 div-by-zero: null (expected null)")
    }

    println("Test 5 chain(4): {nullable_chain(4)} (expected 4)")
    println("Test 6 chain(3): {nullable_chain(3)} (expected 0)")

    -- Build benchmark array
    var bench_arr = fill(50, 0)
    for i in range(50) {
        bench_arr[i] = i
    }
    val check = bench_nullable(200, bench_arr, 50)
    println("Test 7 bench(200): {check}")

    -- Benchmark
    val iterations = 500000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = bench_nullable(200, bench_arr, 50)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Nullable Types ===")
    println("Elements: 200")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
}
