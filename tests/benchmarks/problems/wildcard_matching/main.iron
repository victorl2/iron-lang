import time

-- Greedy approach with backtracking
-- Chars: 'a'-'z' = 1-26, '?' = 100, '*' = 101
func is_match(s: [Int], sn: Int, p: [Int], pn: Int) -> Int {
    var si = 0
    var pi = 0
    var star_idx = -1
    var match_idx = 0

    while si < sn {
        if pi < pn {
            if p[pi] == 100 or p[pi] == s[si] {
                si = si + 1
                pi = pi + 1
            } else {
                if p[pi] == 101 {
                    star_idx = pi
                    pi = pi + 1
                    match_idx = si
                } else {
                    if star_idx != -1 {
                        pi = star_idx + 1
                        match_idx = match_idx + 1
                        si = match_idx
                    } else {
                        return 0
                    }
                }
            }
        } else {
            if star_idx != -1 {
                pi = star_idx + 1
                match_idx = match_idx + 1
                si = match_idx
            } else {
                return 0
            }
        }
    }
    while pi < pn {
        if p[pi] == 101 {
            pi = pi + 1
        } else {
            return 0
        }
    }
    return 1
}

func main() {
    val r1 = is_match([1, 1], 2, [1], 1)
    val r2 = is_match([1, 1], 2, [101], 1)
    val r3 = is_match([3, 2], 2, [100, 1], 2)
    val r4 = is_match([1, 4, 3, 5, 2], 5, [101, 1, 101, 2], 4)
    println("Test 1: {r1} (expected 0)")
    println("Test 2: {r2} (expected 1)")
    println("Test 3: {r3} (expected 0)")
    println("Test 4: {r4} (expected 1)")

    val s5 = [1, 2, 3, 1, 2, 3, 1, 2, 3, 1, 2, 3, 1, 2, 3, 1, 2, 3, 1, 2]
    val p5 = [101, 1, 101, 2, 101, 3, 101]

    val iterations = 5000000
    val start = Time.now_ms()
    var result = 0
    for it in range(iterations) {
        result = is_match(s5, 20, p5, 7)
    }
    val elapsed = Time.now_ms() - start

    println("")
    println("=== Benchmark: Wildcard Matching ===")
    println("String: 20 chars, Pattern: 7 chars")
    println("Iterations: {iterations}")
    println("Total time: {elapsed} ms")
    println("Memory: (see process stats)")
}
