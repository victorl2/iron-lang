import time

-- Hamming Distance: count differing bits between two integers
-- Uses arithmetic (mod/div) since Iron lacks bitwise operators

func hamming(a: Int, b: Int) -> Int {
    var x = a
    var y = b
    var count = 0
    while x > 0 or y > 0 {
        if (x % 2) != (y % 2) {
            count = count + 1
        }
        x = x / 2
        y = y / 2
    }
    return count
}

func main() {
    println("Test 1: {hamming(1, 4)} (expected 2)")
    println("Test 2: {hamming(3, 1)} (expected 1)")
    println("Test 3: {hamming(0, 0)} (expected 0)")

    -- Benchmark: sum hamming distances for 1M pairs
    var total = 0
    val start = Time.now_ms()
    for i in range(1000000) {
        val a = (i * 31 + 17) % 100000
        val b = (i * 37 + 23) % 100000
        total = total + hamming(a, b)
    }
    val elapsed = Time.now_ms() - start

    println("Test 4: {total} (expected 8217960)")

    println("")
    println("=== Benchmark: Hamming Distance ===")
    println("Pairs: 1000000")
    println("Total time: {elapsed} ms")
}
