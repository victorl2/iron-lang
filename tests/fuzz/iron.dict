# tests/fuzz/iron.dict -- libFuzzer dictionary for Iron keywords, types,
# operators, and punctuation. Loaded via `-dict=tests/fuzz/iron.dict` by
# .github/workflows/fuzz.yml (Plan 07). Format: one token per line,
# double-quoted. '#' starts a comment.
#
# Keyword list is kept in sync with src/lexer/lexer.h's Iron_TokenKind
# enum (the 38 keywords enumerated there plus extends/extern/comptime/
# await/pool/private which the enum lists as additional keywords).

# -- Keywords ----------------------------------------------------------
"val"
"var"
"if"
"elif"
"else"
"while"
"for"
"in"
"match"
"enum"
"object"
"interface"
"impl"
"extends"
"extern"
"func"
"return"
"true"
"false"
"null"
"spawn"
"parallel_for"
"defer"
"heap"
"rc"
"leak"
"free"
"super"
"self"
"is"
"not"
"and"
"or"
"import"
"comptime"
"await"
"pool"
"private"

# -- Built-in types ----------------------------------------------------
"Int"
"Int64"
"Float"
"Float64"
"Bool"
"String"
"Void"

# -- Compound operators ------------------------------------------------
"=="
"!="
"<="
">="
"->"
".."
"+="
"-="
"*="
"/="
"<<"
">>"
"<<="
">>="
"&="
"|="
"^="

# -- Punctuation / single-char operators ------------------------------
"("
")"
"{"
"}"
"["
"]"
":"
";"
","
"."
"+"
"-"
"*"
"/"
"%"
"="
"<"
">"
"?"
"@"
"&"
"|"
"^"
"~"
