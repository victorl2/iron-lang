-- @compile-only — raylib/ABI smoke; runtime needs a GUI/audio/display CI can't supply.
-- tests/manual/draw3d_smoke.iron
-- Phase 69 canonical regression test. Walks DRAW3D-01..04 via tagged
-- sections (grep-countable for traceability).
--
-- Invocation: ./build/ironc build tests/manual/draw3d_smoke.iron
--             ./draw3d_smoke
-- Expected:   exit 0 with the final PHASE 69 SMOKE confirmation line.
--
-- Plan progression: 69-02 creates this file with DRAW3D-01..03 sections.
--   Plans 69-03 and 69-04 append DRAW3D-04 primitive call sites +
--   keep-alive bindings + the final PHASE 69 SMOKE print line.
--
-- Call style: all Camera3D instance methods use the static form
-- Camera3D.method(cam, ...) per Plan 68-05 Rule-3 precedent.
--
-- Canonical template: tests/manual/audio_smoke.iron (Phase 68-05).

import raylib

func main() -> Int32 {
    Window.init(Int32(800), Int32(600), "Phase 69 draw3d_smoke")

    -- Camera3D setup — shared across all four DRAW3D-NN sections.
    -- Pitfall 9: 5 fields — position, target, up, fovy, projection (Int32).
    -- [Rule 3 Blocking fix — Plan 69-04] The documented Pitfall 10 form
    -- `CameraProjection.PERSPECTIVE.ordinal` fails at ironc codegen with
    -- "member reference base type 'Iron_CameraProjection' is not a
    -- structure or union" because ironc lowers enum variants to a C
    -- enum typedef (not a struct with .ordinal). The struct field is
    -- already Int32, so pass Int32(0) directly for PERSPECTIVE and
    -- Int32(1) for ORTHOGRAPHIC. Deferred to a Phase 73 ironc fix.
    val cam = Camera3D(
        Vector3(Float32(10.0), Float32(10.0), Float32(10.0)),  -- position
        Vector3(Float32(0.0),  Float32(0.0),  Float32(0.0)),   -- target
        Vector3(Float32(0.0),  Float32(1.0),  Float32(0.0)),   -- up (Y-up)
        Float32(45.0),                                          -- fovy (degrees)
        Int32(0)                                                -- projection = PERSPECTIVE
    )

-- ── DRAW3D-01: begin/end 3D mode ─────────────────────────────
    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)
    Draw.end_mode_3d()
    Draw.end()
    print("DRAW3D-01: Draw.begin_mode_3d / end_mode_3d exercised")

-- ── DRAW3D-02: camera update — all 5 modes + update_pro ─────
    -- Pitfall 2: CameraMode.CUSTOM is a no-op; we exercise it for
    -- call-site coverage only (not a field-diff assertion).
    val cam_free   = Camera3D.update(cam, CameraMode.FREE)
    val cam_orb    = Camera3D.update(cam, CameraMode.ORBITAL)
    val cam_fp     = Camera3D.update(cam, CameraMode.FIRST_PERSON)
    val cam_tp     = Camera3D.update(cam, CameraMode.THIRD_PERSON)
    val cam_custom = Camera3D.update(cam, CameraMode.CUSTOM)
    val zero_v     = Vector3(Float32(0.0), Float32(0.0), Float32(0.0))
    val cam_pro    = Camera3D.update_pro(cam, zero_v, zero_v, Float32(0.0))
    print("DRAW3D-02: Camera3D.update (5 modes) + update_pro exercised")

-- ── DRAW3D-03: screen↔world + view matrix ────────────────────
    val mouse  = Vector2(Float32(400.0), Float32(300.0))
    val ray    = Camera3D.screen_to_world_ray(cam, mouse)
    val ray_ex = Camera3D.screen_to_world_ray_ex(cam, mouse,
                                                 Int32(800), Int32(600))
    val world     = Vector3(Float32(0.0), Float32(0.0), Float32(-5.0))
    val screen    = Camera3D.world_to_screen(cam, world)
    val screen_ex = Camera3D.world_to_screen_ex(cam, world,
                                                Int32(800), Int32(600))
    val view_m    = Camera3D.matrix(cam)
    print("DRAW3D-03: screen_to_world_ray + _ex / world_to_screen + _ex / matrix exercised")

-- ── DRAW3D-04: 3D primitives (batch 1 — line / point / circle /
    --              triangle / triangle-strip / cube (4) / sphere (3))
    -- Plan 69-04 appends batch 2 (cylinder / capsule / plane / ray / grid)
    -- and the final keep-alive + PHASE 69 SMOKE confirmation line.
    val origin = Vector3(Float32(0.0), Float32(0.0), Float32(0.0))
    val p1     = Vector3(Float32(1.0), Float32(0.0), Float32(0.0))
    val p2     = Vector3(Float32(0.0), Float32(1.0), Float32(0.0))
    val p3     = Vector3(Float32(0.0), Float32(0.0), Float32(1.0))
    val axis_y = Vector3(Float32(0.0), Float32(1.0), Float32(0.0))
    val size3  = Vector3(Float32(2.0), Float32(2.0), Float32(2.0))
    val strip: [Vector3] = [p1, p2, p3]

    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)

    Draw.line_3d(origin, p1, RED)
    Draw.point_3d(origin, BLACK)
    Draw.circle_3d(origin, Float32(1.0), axis_y, Float32(0.0), BLUE)
    Draw.triangle_3d(p1, p2, p3, GREEN)
    Draw.triangle_strip_3d(strip, Int32(3), YELLOW)

    Draw.cube(origin, Float32(2.0), Float32(2.0), Float32(2.0), RED)
    Draw.cube_v(origin, size3, RED)
    Draw.cube_wires(origin, Float32(2.0), Float32(2.0), Float32(2.0), BLACK)
    Draw.cube_wires_v(origin, size3, BLACK)

    Draw.sphere(origin, Float32(1.0), PURPLE)
    Draw.sphere_ex(origin, Float32(1.0), Int32(16), Int32(16), PURPLE)
    Draw.sphere_wires(origin, Float32(1.0), Int32(8), Int32(8), BLACK)

    Draw.end_mode_3d()
    Draw.end()
    print("DRAW3D-04 batch 1: line_3d / point_3d / circle_3d / triangle_3d / triangle_strip_3d / cube (4) / sphere (3) exercised")

-- ── DRAW3D-04 (batch 2): cylinder (4) / capsule (2) / plane / ray / grid
    val size2 = Vector2(Float32(10.0), Float32(10.0))

    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)

    Draw.cylinder(origin, Float32(1.0), Float32(1.0), Float32(2.0),
                  Int32(16), ORANGE)
    Draw.cylinder_ex(origin, p2, Float32(0.5), Float32(1.0),
                     Int32(16), ORANGE)
    Draw.cylinder_wires(origin, Float32(1.0), Float32(1.0), Float32(2.0),
                        Int32(16), BLACK)
    Draw.cylinder_wires_ex(origin, p2, Float32(0.5), Float32(1.0),
                           Int32(16), BLACK)

    Draw.capsule(origin, p2, Float32(0.5), Int32(8), Int32(8), DARKGREEN)
    Draw.capsule_wires(origin, p2, Float32(0.5), Int32(8), Int32(8), BLACK)

    Draw.plane(origin, size2, LIGHTGRAY)         -- Pitfall 4: size is Vector2
    Draw.ray(ray, MAGENTA)                        -- First Ray INPUT
    Draw.grid(Int32(10), Float32(1.0))           -- Pitfall 6: no Color

    Draw.end_mode_3d()
    Draw.end()
    print("DRAW3D-04 batch 2: cylinder (4) / capsule (2) / plane / ray / grid exercised")


    Window.close()

    -- Keep values alive (DCE guard; Phase 68 precedent).
    val _k0 = cam_free
    val _k1 = cam_orb
    val _k2 = cam_fp
    val _k3 = cam_tp
    val _k4 = cam_custom
    val _k5 = cam_pro
    val _k6 = ray
    val _k7 = ray_ex
    val _k8 = screen
    val _k9 = screen_ex
    val _k10 = view_m

    print("PHASE 69 SMOKE: ALL DRAW3D-01..04 CALL SITES EXERCISED")
    return Int32(0)
}