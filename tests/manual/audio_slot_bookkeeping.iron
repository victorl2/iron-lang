-- @compile-only — Phase 81 AUDIO-06 canonical registry test; audible verification is manual (GUI/audio hardware CI can't supply).
-- tests/manual/audio_slot_bookkeeping.iron
-- Exercises AUDIO-01..05 contracts end-to-end from Iron source:
--   AUDIO-01: deterministic non-drop under the 16-slot cap
--   AUDIO-02: stop releases slot
--   AUDIO-03: restart reuses freed slot
--   AUDIO-04: typed Err(AudioError.NoFreeSlot) at saturation
--   AUDIO-05: Audio.detach_all() sweep
--
-- Invocation: ./build/ironc build tests/manual/audio_slot_bookkeeping.iron
-- Expected:   exit 0. Runtime side effects (active_slot_count == 16, == 8,
--             == 0, etc.) are numeric under CI but require an actual audio
--             device to audibly exercise. Compile-only mode is sufficient
--             under tests/run_tests.sh manual (GUI/audio CI can't supply).
--
-- Canonical 10-step body per Phase 81-CONTEXT.md:
--   1. Init audio + window
--   2. Load 16 Sound aliases from one bounce.wav source
--   3. For each: call Sound.play — all 16 should return Result.Ok
--   4. Assert Audio.active_slot_count() == 16
--   5. Try a 17th play — assert Result.Err(AudioError.NoFreeSlot)
--   6. Stop 8 sounds — assert count drops to 8
--   7. Play 8 more — reuse freed slots
--   8. Audio.detach_all() — count == 0
--   9. Post-detach play from slot 0 succeeds
--  10. Teardown

import raylib

func main() -> Int32 {
    -- Step 1: init window + audio (audio_smoke.iron precedent).
    Window.init(Int32(800), Int32(600), "Phase 81 audio_slot_bookkeeping")
    Audio.init()
    val ready = Audio.is_ready()

    -- Step 2: load 16 Sound aliases from one bounce.wav source.
    -- Sound.alias(src) creates a new Sound with its own AudioBuffer —
    -- each alias occupies a DISTINCT registry slot (verified in
    -- Plan 81-01 summary; alias buffer pointers are distinct).
    val src: Sound = Sound.load("tests/assets/bounce.wav")
    val s00: Sound = Sound.alias(src)
    val s01: Sound = Sound.alias(src)
    val s02: Sound = Sound.alias(src)
    val s03: Sound = Sound.alias(src)
    val s04: Sound = Sound.alias(src)
    val s05: Sound = Sound.alias(src)
    val s06: Sound = Sound.alias(src)
    val s07: Sound = Sound.alias(src)
    val s08: Sound = Sound.alias(src)
    val s09: Sound = Sound.alias(src)
    val s10: Sound = Sound.alias(src)
    val s11: Sound = Sound.alias(src)
    val s12: Sound = Sound.alias(src)
    val s13: Sound = Sound.alias(src)
    val s14: Sound = Sound.alias(src)
    val s15: Sound = Sound.alias(src)

    -- Step 3: call Sound.play on all 16 aliases. Bind each Result so DCE
    -- doesn't elide the call sites (ironc discards unused values at
    -- call sites, but binding to a val forces evaluation).
    val r00 = Sound.play(s00)
    val r01 = Sound.play(s01)
    val r02 = Sound.play(s02)
    val r03 = Sound.play(s03)
    val r04 = Sound.play(s04)
    val r05 = Sound.play(s05)
    val r06 = Sound.play(s06)
    val r07 = Sound.play(s07)
    val r08 = Sound.play(s08)
    val r09 = Sound.play(s09)
    val r10 = Sound.play(s10)
    val r11 = Sound.play(s11)
    val r12 = Sound.play(s12)
    val r13 = Sound.play(s13)
    val r14 = Sound.play(s14)
    val r15 = Sound.play(s15)

    -- Step 4: Audio.active_slot_count() == 16 (runtime-only assertion;
    -- compile-only in CI — the typed return signature still exercises
    -- the binding shape).
    val count_after_16 = Audio.active_slot_count()

    -- Step 5: try to play a 17th sound — assert Result.Err(NoFreeSlot).
    -- The match arm below binds the Err payload but discards it via
    -- wildcard; the compile-time guarantee is that Result[Void, AudioError]
    -- destructures into Ok(_) / Err(_) with the registered variant tags.
    val s16: Sound = Sound.alias(src)
    val r16 = Sound.play(s16)
    match r16 {
        Result.Ok(_) -> { print("UNEXPECTED: 17th play returned Ok (runtime)") }
        Result.Err(_) -> { print("Step 5: 17th play returned Err (expected NoFreeSlot)") }
    }

    -- Step 6: stop 8 sounds — assert Audio.active_slot_count() drops to 8.
    Sound.stop(s00)
    Sound.stop(s01)
    Sound.stop(s02)
    Sound.stop(s03)
    Sound.stop(s04)
    Sound.stop(s05)
    Sound.stop(s06)
    Sound.stop(s07)
    val count_after_stop_8 = Audio.active_slot_count()

    -- Step 7: play 8 MORE aliases — freed slots should be reused.
    val s16b: Sound = Sound.alias(src)
    val s17b: Sound = Sound.alias(src)
    val s18b: Sound = Sound.alias(src)
    val s19b: Sound = Sound.alias(src)
    val s20b: Sound = Sound.alias(src)
    val s21b: Sound = Sound.alias(src)
    val s22b: Sound = Sound.alias(src)
    val s23b: Sound = Sound.alias(src)
    val r16b = Sound.play(s16b)
    val r17b = Sound.play(s17b)
    val r18b = Sound.play(s18b)
    val r19b = Sound.play(s19b)
    val r20b = Sound.play(s20b)
    val r21b = Sound.play(s21b)
    val r22b = Sound.play(s22b)
    val r23b = Sound.play(s23b)
    val count_after_replay_8 = Audio.active_slot_count()

    -- Step 8: Audio.detach_all() — assert count == 0.
    Audio.detach_all()
    val count_after_detach = Audio.active_slot_count()

    -- Step 9: post-detach_all play from slot 0 succeeds.
    val s_final: Sound = Sound.alias(src)
    val r_final = Sound.play(s_final)
    match r_final {
        Result.Ok(_) -> { print("Step 9: post-detach_all play succeeded (expected)") }
        Result.Err(_) -> { print("UNEXPECTED: post-detach_all play failed") }
    }

    -- Step 10: teardown.
    Sound.stop(s_final)
    Audio.detach_all()
    Sound.unload(src)
    Audio.close()
    Window.close()

    -- Keep values alive so DCE doesn't elide the exercised call sites.
    val _k_ready          = ready
    val _k_count16        = count_after_16
    val _k_count_stop     = count_after_stop_8
    val _k_count_replay   = count_after_replay_8
    val _k_count_detach   = count_after_detach
    val _k_r00            = r00
    val _k_r01            = r01
    val _k_r02            = r02
    val _k_r03            = r03
    val _k_r04            = r04
    val _k_r05            = r05
    val _k_r06            = r06
    val _k_r07            = r07
    val _k_r08            = r08
    val _k_r09            = r09
    val _k_r10            = r10
    val _k_r11            = r11
    val _k_r12            = r12
    val _k_r13            = r13
    val _k_r14            = r14
    val _k_r15            = r15
    val _k_r16b           = r16b
    val _k_r17b           = r17b
    val _k_r18b           = r18b
    val _k_r19b           = r19b
    val _k_r20b           = r20b
    val _k_r21b           = r21b
    val _k_r22b           = r22b
    val _k_r23b           = r23b

    print("PHASE 81 audio_slot_bookkeeping: 16 plays + NoFreeSlot + stop 8 + replay 8 + detach_all + replay 1 EXERCISED")
    return Int32(0)
}
