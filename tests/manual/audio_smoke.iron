-- tests/manual/audio_smoke.iron
-- Phase 68 canonical regression test. Walks AUDIO-01..12 via tagged
-- sections (grep-countable for traceability). Plus 3 ABI probe sections
-- covering the ABI-FLOAT32, ABI-UINT8, and ABI-CALLBACK surfaces from
-- Plan 68-01.
--
-- Invocation: ./build/ironc build tests/manual/audio_smoke.iron
--             ./audio_smoke
-- Expected:   exit 0 with the final PHASE 68 SMOKE confirmation line.
--
-- Pitfall 7 (68-RESEARCH.md): InitAudioDevice may fail on headless
-- systems. We guard playback calls with `if Audio.is_ready() { ... }`
-- so the smoke builds AND runs (with warning) on macOS CI.
--
-- Note on call style: all instance-like methods use the static form
-- `Namespace.method(receiver, ...)` (matches Phase 66 Image.* / Phase
-- 67 Font.* precedent). The Phase 68 PLAN drafts originally used the
-- lowercase-receiver-bound form (wave.is_valid()) but ironc rejects
-- those with E0200; Plan 68-05 execution converted them all to the
-- static form, which is what this smoke exercises.
--
-- Test assets (`tests/assets/bounce.wav` and `tests/assets/loop.ogg`)
-- are regenerated from scratch via `tests/assets/generate-audio.sh`
-- which uses ffmpeg sine-wave synth. Both are under 20 KB and CC0 /
-- public-domain (programmatically generated, no copyright concern).
--
-- Canonical template: tests/manual/text_smoke.iron (Phase 67-04).

import raylib

func main() -> Int32 {
    -- Prerequisite: Window.init (raylib audio backend piggybacks on GLFW
    -- on macOS; safe to init audio after window).
    Window.init(Int32(800), Int32(600), "Phase 68 audio_smoke")

-- ── AUDIO-01: Audio device lifecycle ─────────────────────────
    Audio.init()
    val ready = Audio.is_ready()
    Audio.set_master_volume(Float32(0.8))
    val master = Audio.get_master_volume()
    print("AUDIO-01: Audio.init / is_ready / master_volume exercised")

-- ── AUDIO-02: Wave load/unload + memory variant ──────────────
    val w = Wave.load("tests/assets/bounce.wav")
    val w_valid = Wave.is_valid(w)
    print("AUDIO-02: Wave.load + Wave.is_valid exercised")

-- ── AUDIO-03: Wave manipulation (copy / crop / format / samples) ─
    val w_copy = Wave.copy(w)
    val w_crop = Wave.crop(w, Int32(0), Int32(500))
    val w_fmt = Wave.format(w, Int32(22050), Int32(16), Int32(1))
    val samples = Wave.load_samples(w)
    print("AUDIO-03: Wave.copy / crop / format / load_samples exercised")

-- ── AUDIO-04: Wave export (to /tmp to avoid polluting repo) ──
    val exp_ok = Wave.export(w, "/tmp/iron_phase68_export.wav")
    val exp_code = Wave.export_as_code(w, "/tmp/iron_phase68_export.h")
    print("AUDIO-04: Wave.export / export_as_code exercised")

-- ── AUDIO-05: Sound load + from_wave + alias ─────────────────
    val s = Sound.load("tests/assets/bounce.wav")
    val s_from_wave = Sound.from_wave(w)
    val s_to_sound = Wave.to_sound(w)
    val s_alias = Sound.alias(s)
    val s_valid = Sound.is_valid(s)
    print("AUDIO-05: Sound.load / from_wave / alias / is_valid exercised")

-- ── AUDIO-06: Sound management (play / stop / pause / resume) ─
    if ready { Sound.play(s) }
    val playing = Sound.is_playing(s)
    if ready { Sound.pause(s) }
    if ready { Sound.resume(s) }
    if ready { Sound.stop(s) }
    print("AUDIO-06: Sound.play / is_playing / pause / resume / stop exercised")

-- ── AUDIO-07: Sound configure (volume / pitch / pan) ─────────
    Sound.set_volume(s, Float32(0.9))
    Sound.set_pitch(s, Float32(1.0))
    Sound.set_pan(s, Float32(0.5))
    print("AUDIO-07: Sound.set_volume / pitch / pan exercised")

-- ── AUDIO-08: Sound.update (1st live ABI-FLOAT32 INPUT) ──────
    val pcm: [Float32] = [Float32(0.0), Float32(0.1), Float32(0.2), Float32(0.1), Float32(0.0)]
    Sound.update(s, pcm, Int32(5))
    print("AUDIO-08: Sound.update (ABI-FLOAT32 INPUT) exercised")

-- ── AUDIO-09: Music load/unload ──────────────────────────────
    val m = Music.load("tests/assets/loop.ogg")
    val m_valid = Music.is_valid(m)
    val m_loop = Music.set_looping(m, true)
    print("AUDIO-09: Music.load / is_valid / set_looping exercised")

-- ── AUDIO-10: Music management ───────────────────────────────
    if ready { Music.play(m_loop) }
    val m_playing = Music.is_playing(m_loop)
    if ready { Music.update(m_loop) }
    if ready { Music.pause(m_loop) }
    if ready { Music.resume(m_loop) }
    if ready { Music.stop(m_loop) }
    print("AUDIO-10: Music.play / update / pause / resume / stop exercised")

-- ── AUDIO-11: Music configure + query ────────────────────────
    Music.seek(m_loop, Float32(1.0))
    Music.set_volume(m_loop, Float32(0.7))
    Music.set_pitch(m_loop, Float32(1.0))
    Music.set_pan(m_loop, Float32(0.5))
    val m_len = Music.get_time_length(m_loop)
    val m_played = Music.get_time_played(m_loop)
    print("AUDIO-11: Music.seek / set_volume / pitch / pan / get_time_* exercised")

-- ── AUDIO-12: AudioStream (14 of 19 bound; 5 callbacks deferred) ─
    val astream = AudioStream.load(UInt32(22050), UInt32(16), UInt32(1))
    val astream_valid = AudioStream.is_valid(astream)
    if ready { AudioStream.play(astream) }
    val astream_playing = AudioStream.is_playing(astream)
    AudioStream.set_volume(astream, Float32(0.8))
    AudioStream.set_pitch(astream, Float32(1.0))
    AudioStream.set_pan(astream, Float32(0.5))
    if ready { AudioStream.pause(astream) }
    if ready { AudioStream.resume(astream) }
    if ready { AudioStream.stop(astream) }
    val processed = AudioStream.is_processed(astream)
    AudioStream.set_buffer_size_default(Int32(4096))
    print("AUDIO-12: AudioStream.load / is_valid / play / pause / stop / set_* exercised (14 of 19; 5 callbacks deferred)")

-- ── ABI-FLOAT32: [Float32] input + return paths ──────────────
    -- INPUT: Sound.update + AudioStream.update both take [Float32] data.
    AudioStream.update(astream, pcm, Int32(1))
    -- RETURN: Wave.load_samples returned `samples: [Float32]` above.
    print("ABI-FLOAT32: [Float32] INPUT (Sound.update + AudioStream.update) + RETURN (Wave.load_samples) exercised")

-- ── ABI-UINT8: [UInt8] input path ────────────────────────────
    -- Small inlined byte buffer to exercise the ABI without a full
    -- decoder round-trip. raylib will TraceLog-warn and return an
    -- invalid Wave/Music for the placeholder bytes -- expected.
    val bytes: [UInt8] = [UInt8(0), UInt8(0), UInt8(0), UInt8(0)]
    val w_mem = Wave.load_from_memory(".wav", bytes, Int32(4))
    val m_mem = Music.load_from_memory(".ogg", bytes, Int32(4))
    val w_mem_valid = Wave.is_valid(w_mem)
    val m_mem_valid = Music.is_valid(m_mem)
    print("ABI-UINT8: Wave/Music.load_from_memory exercised")

-- ── ABI-CALLBACK: Iron closure → trampoline (DEFERRED) ───────
    -- The 5 callback-accepting AUDIO-12 entries are deferred pending
    -- Iron lambda → Iron_Closure FFI. Runtime trampoline infrastructure
    -- is shipped and ready (iron_raylib.c:4497-4599 — 16-slot pool with
    -- audio_cb_alloc / audio_cb_free / g_audio_cb_fns dispatch table);
    -- consumer Iron bindings land in a future cleanup plan.
    --
    -- Happy-path example (will compile once the FFI binding lands):
    --   val cb: func(data: Int, frames: UInt32) = func(d, f) { }
    --   AudioStream.set_callback(astream, cb)
    --   AudioStream.detach_processor(astream, cb)
    --
    -- Until then, users generate audio via AudioStream.update() from
    -- the main loop (already exercised above) — functionally equivalent
    -- for non-threaded workloads, no trampoline needed.
    --
    -- Deferred entries (5 of 19 AUDIO-12 entries):
    --   1. AudioStream.set_callback(stream, cb)        SetAudioStreamCallback
    --   2. AudioStream.attach_processor(stream, cb)    AttachAudioStreamProcessor
    --   3. AudioStream.detach_processor(stream, cb)    DetachAudioStreamProcessor
    --   4. Audio.attach_mixed_processor(cb)            AttachAudioMixedProcessor
    --   5. Audio.detach_mixed_processor(cb)            DetachAudioMixedProcessor
    print("ABI-CALLBACK: trampoline registry available (5 AUDIO-12 callbacks deferred at Iron FFI boundary)")

    -- Teardown
    Wave.unload(w)
    Wave.unload(w_copy)
    Wave.unload(w_crop)
    Wave.unload(w_fmt)
    Sound.unload(s)
    Sound.unload_alias(s_alias)
    Music.unload(m_loop)
    AudioStream.unload(astream)
    Wave.unload(w_mem)
    Music.unload(m_mem)

    Audio.close()
    Window.close()

    -- Keep values alive so the compiler doesn't DCE the call sites.
    val _k0  = master
    val _k1  = w_valid
    val _k2  = samples
    val _k3  = s_from_wave
    val _k4  = s_to_sound
    val _k5  = exp_ok
    val _k6  = exp_code
    val _k7  = s_valid
    val _k8  = playing
    val _k9  = m_valid
    val _k10 = m_playing
    val _k11 = m_len
    val _k12 = m_played
    val _k13 = astream_valid
    val _k14 = astream_playing
    val _k15 = processed
    val _k16 = w_mem_valid
    val _k17 = m_mem_valid
    val _k18 = ready

    print("PHASE 68 SMOKE: ALL AUDIO-01..12 CALL SITES EXERCISED")
    return Int32(0)
}
