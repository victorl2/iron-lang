-- tests/manual/models_smoke.iron
-- Phase 70 canonical regression — 10 tagged MODEL-NN sections covering
-- every MODEL-NN requirement end-to-end. Follows Phase 67/68/69 smoke
-- file conventions: Window.init + tagged sections + PHASE 70 SMOKE
-- confirmation + Window.close. On headless CI, Window.init may succeed
-- without display; all draw calls no-op safely.
--
-- Every section prints a `MODEL-NN: …` status line; the final
-- `PHASE 70 SMOKE` line confirms full pass.
--
-- Static-form calls throughout (Model.draw(model, ...) not model.draw(...))
-- per Rule-3 convention established Phase 68-05 / 69-04.

import raylib

func main() -> Int32 {
    Window.init(Int32(800), Int32(600), "Phase 70 models_smoke")
    Window.set_target_fps(Int32(60))

    var cam = Camera3D(
        Vector3(Float32(10.0), Float32(10.0), Float32(10.0)),
        Vector3(Float32(0.0),  Float32(0.0),  Float32(0.0)),
        Vector3(Float32(0.0),  Float32(1.0),  Float32(0.0)),
        Float32(45.0),
        Int32(0)
    )

    val origin = Vector3(Float32(0.0), Float32(0.0), Float32(0.0))
    val axis_y = Vector3(Float32(0.0), Float32(1.0), Float32(0.0))
    val unit_scale = Vector3(Float32(1.0), Float32(1.0), Float32(1.0))

-- ── MODEL-01: Model load / from_mesh / is_valid / unload ─────────
    val cube_mesh = Mesh.cube(Float32(1.0), Float32(1.0), Float32(1.0))
    val model_a = Model.from_mesh(cube_mesh)
    val m01_valid = Model.is_valid(model_a)
    val _k_m01 = m01_valid
    print("MODEL-01: from_mesh + is_valid exercised")

-- ── MODEL-02: Bounding box ───────────────────────────────────────
    val bbox = Model.bounding_box(model_a)
    val _k_bb_min = bbox.min.x
    val _k_bb_max = bbox.max.x
    print("MODEL-02: bounding_box exercised")

-- ── MODEL-03: Draw variants (6) inside Draw.begin_mode_3d ────────
    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)

    Model.draw(model_a, origin, Float32(1.0), WHITE)
    Model.draw_ex(model_a, origin, axis_y, Float32(45.0), unit_scale, RED)
    Model.draw_wires(model_a, origin, Float32(1.0), BLACK)
    Model.draw_wires_ex(model_a, origin, axis_y, Float32(45.0), unit_scale, DARKGREEN)
    Model.draw_points(model_a, origin, Float32(1.0), BLUE)
    Model.draw_points_ex(model_a, origin, axis_y, Float32(45.0), unit_scale, PURPLE)

    Draw.end_mode_3d()
    Draw.end()
    print("MODEL-03: all 6 draw variants exercised")

-- ── MODEL-04: Mesh operations ────────────────────────────────────
    var work_mesh = Mesh.sphere(Float32(1.0), Int32(16), Int32(32))
    work_mesh = Mesh.upload(work_mesh, true)
    val mbbox = Mesh.bounding_box(work_mesh)
    val _k_mbb = mbbox.min.x
    work_mesh = Mesh.gen_tangents(work_mesh)
    val export_ok = Mesh.export(work_mesh, "/tmp/phase70_mesh.obj")
    val _k_exp = export_ok
    val export_code_ok = Mesh.export_as_code(work_mesh, "/tmp/phase70_mesh.h")
    val _k_exp_code = export_code_ok
    print("MODEL-04: mesh upload + bbox + gen_tangents + export + export_as_code exercised")

-- ── MODEL-05: Mesh draw (2) ──────────────────────────────────────
    val mat_default = Material.default()
    val ident = Matrix.identity()

    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)
    Mesh.draw(work_mesh, mat_default, ident)
    -- draw_instanced with a single transform (edge case; proves [Matrix] wiring)
    val transforms = [ident]
    Mesh.draw_instanced(work_mesh, mat_default, transforms, Int32(1))
    Draw.end_mode_3d()
    Draw.end()
    print("MODEL-05: draw + draw_instanced exercised")

-- ── MODEL-06: Mesh generation (11) ───────────────────────────────
    val m_poly     = Mesh.poly(Int32(6), Float32(1.0))
    val m_plane    = Mesh.plane(Float32(10.0), Float32(10.0), Int32(5), Int32(5))
    val m_cube2    = Mesh.cube(Float32(1.0), Float32(1.0), Float32(1.0))
    val m_sphere   = Mesh.sphere(Float32(1.0), Int32(16), Int32(32))
    val m_hemi     = Mesh.hemi_sphere(Float32(1.0), Int32(16), Int32(32))
    val m_cyl      = Mesh.cylinder(Float32(1.0), Float32(2.0), Int32(16))
    val m_cone     = Mesh.cone(Float32(1.0), Float32(2.0), Int32(16))
    val m_torus    = Mesh.torus(Float32(0.25), Float32(1.0), Int32(16), Int32(32))
    val m_knot     = Mesh.knot(Float32(0.25), Float32(1.0), Int32(16), Int32(32))
    -- heightmap + cubicmap require a live Image — generate a tiny procedural
    -- noise image so raylib has pixel data to read during Gen
    val hm_img     = Image.white_noise(Int32(16), Int32(16), Float32(0.5))
    val size3      = Vector3(Float32(10.0), Float32(2.0), Float32(10.0))
    val m_height   = Mesh.heightmap(hm_img, size3)
    val cube_size  = Vector3(Float32(1.0), Float32(1.0), Float32(1.0))
    val m_cubic    = Mesh.cubicmap(hm_img, cube_size)
    print("MODEL-06: all 11 procedural generators returned meshes")

-- ── MODEL-07: Materials ─────────────────────────────────────────
    var mat = Material.default()
    val mat_valid = Material.is_valid(mat)
    val _k_mat_valid = mat_valid
    -- set_texture: use a procedural 2x2 placeholder texture
    val place_img = Image.color(Int32(2), Int32(2), RED)
    val place_tex = Image.to_texture(place_img)
    mat = Material.set_texture(mat, MaterialMapIndex.ALBEDO, place_tex)
    -- set_mesh_material: reassign mesh 0's material index on model_a
    var model_b = model_a
    model_b = Model.set_mesh_material(model_b, Int32(0), Int32(0))
    print("MODEL-07: set_texture + set_mesh_material exercised")

-- ── MODEL-08: Model animations ──────────────────────────────────
    -- Attempt to load a nonexistent .iqm — expect empty list (see RESEARCH.md
    -- Claude's Discretion: no .iqm asset vendored; ABI-level smoke only).
    val anims = ModelAnimation.load("/tmp/phase70_nonexistent.iqm")
    val _k_count = anims.count
    -- If the list is non-empty, exercise update_animation + animation_valid;
    -- on empty list (expected), we skip those calls safely.
    ModelAnimation.unload_all(anims)
    print("MODEL-08: ModelAnimation.load + unload_all exercised")

-- ── MODEL-09: Billboards ─────────────────────────────────────────
    val label_src = Rectangle(Float32(0.0), Float32(0.0),
                              Float32(2.0), Float32(2.0))
    val label_size = Vector2(Float32(2.0), Float32(2.0))
    val label_origin = Vector2(Float32(1.0), Float32(1.0))

    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)
    Draw.billboard(cam, place_tex, origin, Float32(2.0), WHITE)
    Draw.billboard_rec(cam, place_tex, label_src, origin, label_size, WHITE)
    Draw.billboard_pro(cam, place_tex, label_src, origin, axis_y,
                       label_size, label_origin, Float32(0.0), WHITE)
    Draw.end_mode_3d()
    Draw.end()
    print("MODEL-09: 3 billboard variants exercised")

-- ── MODEL-10: Bounding box draw ──────────────────────────────────
    Draw.begin()
    Draw.clear(RAYWHITE)
    Draw.begin_mode_3d(cam)
    Draw.bounding_box(bbox, GREEN)
    Draw.end_mode_3d()
    Draw.end()
    print("MODEL-10: Draw.bounding_box exercised")

    -- Keep-alive block — prevents DCE of procedural artifacts (Phase 68 precedent)
    val _k0  = m_poly
    val _k1  = m_plane
    val _k2  = m_cube2
    val _k3  = m_sphere
    val _k4  = m_hemi
    val _k5  = m_cyl
    val _k6  = m_cone
    val _k7  = m_torus
    val _k8  = m_knot
    val _k9  = m_height
    val _k10 = m_cubic
    val _k11 = model_b
    val _k12 = mat

    -- Cleanup
    Mesh.unload(work_mesh)
    Model.unload(model_a)

    print("PHASE 70 SMOKE: ALL MODEL-01..10 SECTIONS EXERCISED")

    Window.close()
    return Int32(0)
}
