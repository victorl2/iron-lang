-- url_percent.iron — Phase 59 P05 percent-encode / decode integration test.
-- Covers the common "hello world" roundtrip plus a deliberately-bad "%2"
-- decode that must surface IRON_ERR_URL_BAD_PERCENT (2007) and a reserved
-- encoding check where reserved_ok=false rewrites / ? = & as %XX.
import url

func main() {
    println(Url.percent_encode("hello world", false))

    val (d1, e1) = Url.percent_decode("hello%20world")
    if e1.code == 0 {
        println(d1)
    } else {
        println("decode failed")
    }

    val (d2, e2) = Url.percent_decode("bad%2")
    if e2.code == 2007 { println("bad percent ok") }

    println(Url.percent_encode("a/b?c=d&e=f", false))
}
