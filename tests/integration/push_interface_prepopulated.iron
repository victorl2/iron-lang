-- push_interface_prepopulated.iron: Push into an already-populated collection
-- Verifies that existing elements are preserved and new ones are appended
-- correctly across both per-type sub-arrays.
--
-- Phase 56 Plan 02 audit: the 4-element [Circle, Square, Circle, Square]
-- initial literal + interleaved Circle/Square/Circle pushes are LOAD-BEARING,
-- not a mono-collapse workaround. The test's purpose is "existing elements
-- preserved across both per-type sub-arrays" — it only makes sense when
-- BOTH sub-arrays start non-empty and receive additional elements. A
-- single-type rewrite would degenerate to a plain Iron_List append test.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  var shapes = [Circle(1), Square(2), Circle(3), Square(4)]
  shapes.push(Circle(5))
  shapes.push(Square(6))
  shapes.push(Circle(7))

  -- Expected element count: 4 initial + 3 pushed = 7
  -- Areas: Circle(1)=3, Square(2)=4, Circle(3)=27, Square(4)=16,
  --        Circle(5)=75, Square(6)=36, Circle(7)=147
  -- Total = 3+4+27+16+75+36+147 = 308
  var count = 0
  var total = 0
  for s in shapes {
    count = count + 1
    total = total + s.area()
  }
  println("{count}")
  println("{total}")
}
