-- layout_annotation_warn.iron: Warning when annotation contradicts analysis
-- Tests Phase 48: layout: soa annotation honored with warning

interface Pair {
  func sum() -> Int
}

object IntPair impl Pair {
  var a: Int
  var b: Int

    init(a: Int, b: Int) {
        self.a = a
        self.b = b
    }
}

object FloatPair impl Pair {
  var a: Int
  var b: Int

    init(a: Int, b: Int) {
        self.a = a
        self.b = b
    }
}

patch object IntPair {
    readonly func sum() -> Int {
      return self.a + self.b
    }
}

patch object FloatPair {
    readonly func sum() -> Int {
      return self.a + self.b
    }
}

func main() {
  -- Force SoA even though loop accesses all fields (a and b = 100%)
  val pairs: [Pair, layout: soa] = [IntPair(3, 4), FloatPair(5, 6)]
  var total = 0
  for p in pairs {
    total = total + p.sum()
  }
  -- (3+4) + (5+6) = 18
  println("{total}")
  println("done")
}
