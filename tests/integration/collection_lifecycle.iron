-- collection_lifecycle.iron - Test collection lifecycle: create, use, auto-free.
-- Verifies that heap arrays are properly created and that scope-based
-- cleanup does not corrupt live data.

func main() {
  -- Test 1: Array literal (heap) — create, index, len
  val arr = [10, 20, 30, 40, 50]
  println("len = {len(arr)}")
  println("{arr[0]}, {arr[2]}, {arr[4]}")

  -- Test 2: Mutable array — heap allocated, modify, read back
  var data = [1, 2, 3, 4]
  data[0] = 100
  data[3] = 400
  println("{data[0]}, {data[1]}, {data[2]}, {data[3]}")

  -- Test 3: Multiple arrays in same scope — ensure independent lifetimes
  val a = [1, 2, 3]
  val b = [4, 5, 6]
  var sum_a = 0
  var sum_b = 0
  for x in a {
    sum_a = sum_a + x
  }
  for x in b {
    sum_b = sum_b + x
  }
  println("sum_a = {sum_a}, sum_b = {sum_b}")

  -- Test 4: fill() produces heap array with correct lifecycle
  val filled = fill(5, 7)
  var total = 0
  for x in filled {
    total = total + x
  }
  println("fill total = {total}")

  -- Test 5: Array survives conditional branches
  var nums = [0, 0, 0]
  val flag = 1
  if flag > 0 {
    nums[0] = 10
    nums[1] = 20
    nums[2] = 30
  } else {
    nums[0] = 99
  }
  println("{nums[0]}, {nums[1]}, {nums[2]}")

  println("lifecycle ok")
}
