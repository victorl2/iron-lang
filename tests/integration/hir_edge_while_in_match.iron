func run_case(n: Int) -> Int {
  var result = 0
  match n {
    1 {
      var i = 0
      while i < 3 {
        result = result + 1
        i = i + 1
      }
    }
    2 {
      var i = 0
      while i < 5 {
        result = result + 2
        i = i + 1
      }
    }
    else {
      result = 99
    }
  }
  return result
}

func main() {
  println("{run_case(1)}")
  println("{run_case(2)}")
  println("{run_case(3)}")
}
