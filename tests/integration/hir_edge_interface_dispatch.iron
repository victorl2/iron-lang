interface Shape {
  func area() -> Int
}

object Rect {
  var width: Int
  var height: Int
    init(width: Int, height: Int) {
        self.width = width
        self.height = height
    }
}

object Square {
  var side: Int
    init(side: Int) {
        self.side = side
    }
}

patch object Rect {
    readonly func area() -> Int {
      return self.width * self.height
    }
}

patch object Square {
    readonly func area() -> Int {
      return self.side * self.side
    }
}

func main() {
  val r = Rect(4, 5)
  val s = Square(6)
  println("{r.area()}")
  println("{s.area()}")
}
