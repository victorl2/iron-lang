-- compose_soa_fusion.iron: Composition test for SoA layout + split collection dispatch
-- Tests that SoA layout selection and split collection iteration coexist:
--   (1) SoA is selected because only x is accessed (<50% of fields)
--   (2) Split collection per-type unordered loops read from SoA per-field arrays
--   (3) Dead field elimination removes y, z, mass/speed from Stor structs
-- Exercises both SoA and split dispatch on same collection with 4 elements

interface Entity {
  func get_x() -> Int
}

object Particle impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var mass: Int

    init(x: Int, y: Int, z: Int, mass: Int) {
        self.x = x
        self.y = y
        self.z = z
        self.mass = mass
    }
}

object Bullet impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var speed: Int

    init(x: Int, y: Int, z: Int, speed: Int) {
        self.x = x
        self.y = y
        self.z = z
        self.speed = speed
    }
}

patch object Particle {
    readonly func get_x() -> Int {
      return self.x
    }
}

patch object Bullet {
    readonly func get_x() -> Int {
      return self.x
    }
}

func main() {
  val entities = [Particle(10, 20, 30, 100), Bullet(5, 15, 25, 50), Particle(3, 6, 9, 200), Bullet(8, 12, 18, 75)]
  -- Only accesses x (1 of 4 fields = 25% < 50% threshold -> SoA layout)
  -- SoA generates per-field arrays: particle_x, bullet_x
  -- Dead field elimination removes y, z, mass/speed from storage
  --
  -- Phase 57 restoration: this test originally used a for-loop workaround because
  -- Phase 54 documented an SoA+fusion interaction bug (Iron_*_Stor / Iron_* type
  -- mismatch in the fused element wrap). Plan 01 of Phase 57 added the sibling
  -- _from_<Type>_Stor constructors and branched emit_fusion.c on is_soa, so the
  -- fused form now compiles and runs correctly.
  val sum_x = entities.map(func(e: Entity) -> Int { return e.get_x() }).sum()
  -- get_x values: [10, 5, 3, 8]  (fused per-type loops: Particles then Bullets)
  -- sum_x = 10 + 5 + 3 + 8 = 26
  println("{sum_x}")
  println("soa_done")
}
