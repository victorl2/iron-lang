-- push_interface_after_op.iron: Push after filter() on an interface collection
-- Filter returns another split collection. Push onto the filtered result
-- proves .push() composes with the higher-order collection methods.
--
-- Phase 56 Plan 02 audit: the 4-element [Circle, Square, Circle, Square]
-- initial literal is LOAD-BEARING, not a mono-collapse workaround. The
-- filter predicate `s.area() > 5` removes one Circle (Circle(1)=3) and one
-- Square (Square(2)=4), keeping Circle(3)=27 and Square(5)=25; then
-- Square(10)=100 is pushed. The final sum 152 directly depends on the
-- filter result containing BOTH implementor types, which only happens with
-- a genuinely multi-type starting literal.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}

patch object Circle {
    readonly func area() -> Int {
      return self.radius * self.radius * 3
    }
}

patch object Square {
    readonly func area() -> Int {
      return self.side * self.side
    }
}

func main() {
  var shapes = [Circle(1), Square(2), Circle(3), Square(5)]
  -- Keep only shapes with area > 5: Circle(3)=27, Square(5)=25
  -- (filtered out: Circle(1)=3, Square(2)=4)
  var big = shapes.filter(func(s: Shape) -> Bool { return s.area() > 5 })
  big.push(Square(10))   -- Square(10)=100
  var total = 0
  for s in big {
    total = total + s.area()
  }
  -- 27 + 25 + 100 = 152
  println("{total}")
}
