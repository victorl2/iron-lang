func binary_search(arr: [Int], n: Int, target: Int) -> Int {
  var low = 0
  var high = n - 1
  while low <= high {
    val mid = (low + high) / 2
    val midval = arr[mid]
    if midval == target {
      return mid
    }
    if midval < target {
      low = mid + 1
    } else {
      high = mid - 1
    }
  }
  return -1
}

func main() {
  val arr = [1, 3, 5, 7, 9, 11, 13]
  println("{binary_search(arr, 7, 7)}")
  println("{binary_search(arr, 7, 1)}")
  println("{binary_search(arr, 7, 13)}")
  println("{binary_search(arr, 7, 4)}")
}
