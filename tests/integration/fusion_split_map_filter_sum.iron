-- fusion_split_map_filter_sum.iron: Split collection map+filter+sum fusion (FUSE-01/02)
interface Shape {
  func area() -> Int
}
object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}
object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}
func Circle.area() -> Int {
  return self.radius * self.radius * 3
}
func Square.area() -> Int {
  return self.side * self.side
}
func main() {
  val shapes = [Circle(2), Square(3), Circle(4), Square(5)]
  val result = shapes.map(func(s: Shape) -> Int { return s.area() }).filter(func(a: Int) -> Bool { return a > 10 }).sum()
  println("{result}")
}
