-- edge_single_implementor.iron: Single-implementor interface edge case
-- Tests that an interface with only one implementor triggers monomorphic
-- collapse (no SplitList needed) and produces correct results
-- Note: uses for-loop approach since monomorphic collapse path does not
-- yet support .map() chain methods (pre-existing limitation)

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

patch object Circle {
    readonly func area() -> Int {
      return self.radius * self.radius * 3
    }
}

func main() {
  -- Single implementor: should collapse to monomorphic path
  val shapes = [Circle(5), Circle(3), Circle(7)]

  -- Test 1: for-loop sum on single-implementor collection
  -- Circle(5)=75, Circle(3)=27, Circle(7)=147. Total=249
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  println("{total}")

  -- Test 2: for-loop with conditional (manual filter >30)
  -- Circle(5)=75, Circle(3)=27, Circle(7)=147. Filter >30: 75+147=222
  var filtered_sum = 0
  for s in shapes {
    val a = s.area()
    if a > 30 {
      filtered_sum = filtered_sum + a
    }
  }
  println("{filtered_sum}")

  -- Test 3: count elements (verifies iteration count)
  var count = 0
  for s in shapes {
    count = count + 1
  }
  println("{count}")
}
