interface Entity {
  func get_x() -> Int
}

object Particle impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var mass: Int
  init(x: Int, y: Int, z: Int, mass: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.mass = mass
  }
  readonly func get_x() -> Int {
    return self.x
  }
  init(x: Int, y: Int, z: Int, mass: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.mass = mass
  }
  readonly func get_x() -> Int {
    return self.x
  }
}

object Bullet impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var speed: Int
  init(x: Int, y: Int, z: Int, speed: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.speed = speed
  }
  readonly func get_x() -> Int {
    return self.x
  }
  init(x: Int, y: Int, z: Int, speed: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.speed = speed
  }
  readonly func get_x() -> Int {
    return self.x
  }
}

patch object Particle {
  init(x: Int, y: Int, z: Int, mass: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.mass = mass
  }
  readonly func get_x() -> Int {
    return self.x
  }
  init(x: Int, y: Int, z: Int, mass: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.mass = mass
  }
  readonly func get_x() -> Int {
    return self.x
  }
}

patch object Bullet {
  init(x: Int, y: Int, z: Int, speed: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.speed = speed
  }
  readonly func get_x() -> Int {
    return self.x
  }
  init(x: Int, y: Int, z: Int, speed: Int) {
    self.x = x
    self.y = y
    self.z = z
    self.speed = speed
  }
  readonly func get_x() -> Int {
    return self.x
  }
}

func main() {
  val entities = [Particle(10, 20, 30, 100), Bullet(5, 15, 25, 50), Particle(3, 6, 9, 200), Bullet(8, 12, 18, 75)]
  val sum_x = entities.map(func(e: Entity) -> Int {
    return e.get_x()
  }).sum()
  println("{sum_x}")
  println("soa_fusion_done")
}
