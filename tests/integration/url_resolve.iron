-- url_resolve.iron — Phase 59 P05 RFC 3986 §5.4 reference resolution vectors.
-- Exercises 4 representative vectors against base "http://a/b/c/d;p?q".
import url

func check_resolve(base_str: String, ref: String, expected: String) {
    val (base, err) = Url.parse(base_str)
    if err.code != 0 {
        println("base parse failed")
        return
    }
    val (result, rerr) = Url.resolve(base, ref)
    if rerr.code != 0 {
        println("resolve failed")
        return
    }
    val built = Url.build(result)
    if built == expected {
        println("ok {ref}")
    } else {
        println("FAIL {ref}: got {built}")
    }
}

func main() {
    val base = "http://a/b/c/d;p?q"
    check_resolve(base, "g",        "http://a/b/c/g")
    check_resolve(base, "/g",       "http://a/g")
    check_resolve(base, "../../g",  "http://a/g")
    check_resolve(base, "#s",       "http://a/b/c/d;p?q#s")
}
