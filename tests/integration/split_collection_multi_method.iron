-- split_collection_multi_method.iron: Split collection with multiple interface methods

interface Vehicle {
  func speed() -> Int
  func fuel() -> Int
}

object Car impl Vehicle {
  var max_speed: Int
  var tank: Int

    init(max_speed: Int, tank: Int) {
        self.max_speed = max_speed
        self.tank = tank
    }
}

object Bike impl Vehicle {
  var max_speed: Int

    init(max_speed: Int) {
        self.max_speed = max_speed
    }
}

patch object Car {
    readonly func speed() -> Int {
      return self.max_speed
    }
    readonly func fuel() -> Int {
      return self.tank
    }
}


patch object Bike {
    readonly func speed() -> Int {
      return self.max_speed
    }
    readonly func fuel() -> Int {
      return 0
    }
}


func main() {
  val vehicles = [Car(120, 50), Bike(25), Car(200, 80)]
  var total_speed = 0
  var total_fuel = 0
  for v in vehicles {
    total_speed = total_speed + v.speed()
    total_fuel = total_fuel + v.fuel()
  }
  println("total_speed={total_speed}")
  println("total_fuel={total_fuel}")
  println("done")
}
