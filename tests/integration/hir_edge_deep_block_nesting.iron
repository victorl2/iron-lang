func deep7(x: Int) -> Int {
  if x > 0 {
    if x > 1 {
      if x > 2 {
        if x > 3 {
          if x > 4 {
            if x > 5 {
              if x > 6 {
                return 7
              } else {
                return 6
              }
            } else {
              return 5
            }
          } else {
            return 4
          }
        } else {
          return 3
        }
      } else {
        return 2
      }
    } else {
      return 1
    }
  } else {
    return 0
  }
  return -1
}

func main() {
  for i in range(9) {
    println("{deep7(i)}")
  }
}
