func partition(arr: [Int], low: Int, high: Int) -> Int {
  val pivot = arr[high]
  var i = low - 1
  var j = low
  while j < high {
    if arr[j] <= pivot {
      i = i + 1
      val tmp = arr[i]
      arr[i] = arr[j]
      arr[j] = tmp
    }
    j = j + 1
  }
  val tmp = arr[i + 1]
  arr[i + 1] = arr[high]
  arr[high] = tmp
  return i + 1
}

func quicksort(arr: [Int], low: Int, high: Int) {
  if low < high {
    val p = partition(arr, low, high)
    quicksort(arr, low, p - 1)
    quicksort(arr, p + 1, high)
  }
}

func main() {
  var arr = [5, 3, 8, 1, 9, 2, 7, 4, 6]
  quicksort(arr, 0, 8)
  for x in arr {
    println("{x}")
  }
}
