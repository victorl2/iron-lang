-- mono_specialization_heuristic.iron: Parameter-based specialization heuristic
-- Tests ANAL-01: the specialization heuristic tracks call-site types and
-- applies size/dispatch constraints. This test verifies that the heuristic
-- infrastructure does not break existing monomorphic detection or introduce
-- regressions. Two separate single-type collections are processed, each
-- via a local loop, and the heuristic tracking collects information without
-- altering output.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  val circles = [Circle(5), Circle(3), Circle(7)]
  var total1 = 0
  for s in circles {
    total1 = total1 + s.area()
  }

  val mixed = [Circle(2), Square(3), Circle(4)]
  var total2 = 0
  for s in mixed {
    total2 = total2 + s.area()
  }

  println("{total1}")
  println("{total2}")
}
