-- coll_split_filter.iron: Collection filter on interface-typed split collection
interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  val shapes = [Circle(5), Square(4), Circle(3), Square(10)]
  val big = shapes.filter(func(s: Shape) -> Bool { return s.area() > 20 })
  for s in big {
    println("{s.area()}")
  }
}
