-- layout_annotation.iron: Layout annotation parsing
-- Tests Phase 48: [T, unordered] syntax

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  val shapes: [Shape, unordered] = [Circle(5), Square(4), Circle(3)]
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  -- Circle(5)=75, Square(4)=16, Circle(3)=27 = 118
  println("{total}")
  println("done")
}
