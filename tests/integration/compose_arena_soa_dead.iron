-- compose_arena_soa_dead.iron: Triple composition test: arena + SoA + dead field elimination
-- Tests three optimizations working together:
--   (1) Arena allocation: >8 elements triggers geometric growth beyond initial capacity
--   (2) SoA layout: only x is accessed (1 of 5 fields = 20% < 50% threshold)
--   (3) Dead field elimination: debug field never accessed through collection -> removed from Stor

interface Entity {
  func get_x() -> Int
}

object Particle impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var mass: Int
  var debug: Int

    init(x: Int, y: Int, z: Int, mass: Int, debug: Int) {
        self.x = x
        self.y = y
        self.z = z
        self.mass = mass
        self.debug = debug
    }
}

object Bullet impl Entity {
  var x: Int
  var y: Int
  var z: Int
  var speed: Int
  var debug: Int

    init(x: Int, y: Int, z: Int, speed: Int, debug: Int) {
        self.x = x
        self.y = y
        self.z = z
        self.speed = speed
        self.debug = debug
    }
}

func Particle.get_x() -> Int {
  return self.x
}

func Bullet.get_x() -> Int {
  return self.x
}

func main() {
  -- 14 elements: triggers arena reallocation beyond initial capacity of 8
  -- Only get_x() is called: 1/5 fields accessed -> SoA layout
  -- debug field never accessed through collection -> dead field eliminated
  val entities = [
    Particle(10, 20, 30, 100, 900),
    Bullet(5, 15, 25, 50, 901),
    Particle(3, 6, 9, 200, 902),
    Bullet(8, 12, 18, 75, 903),
    Particle(15, 25, 35, 110, 904),
    Bullet(20, 10, 5, 60, 905),
    Particle(7, 14, 21, 150, 906),
    Bullet(12, 8, 16, 90, 907),
    Particle(1, 2, 3, 300, 908),
    Bullet(25, 30, 35, 40, 909),
    Particle(4, 8, 12, 250, 910),
    Bullet(11, 22, 33, 55, 911),
    Particle(9, 18, 27, 180, 912),
    Bullet(6, 9, 15, 70, 913)
  ]

  var sum_x = 0
  for e in entities {
    sum_x = sum_x + e.get_x()
  }
  -- x values: [10, 5, 3, 8, 15, 20, 7, 12, 1, 25, 4, 11, 9, 6]
  -- sum = 10+5+3+8+15+20+7+12+1+25+4+11+9+6 = 136
  println("{sum_x}")
}
