object Vec {
  var x: Int
  var y: Int
    init(x: Int, y: Int) {
        self.x = x
        self.y = y
    }
}

patch object Vec {
    readonly func dot(other: Vec) -> Int {
      return self.x * other.x + self.y * other.y
    }
    readonly func mag_sq() -> Int {
      return self.x * self.x + self.y * self.y
    }
}


func main() {
  val a = Vec(3, 4)
  val b = Vec(1, 2)
  println("{a.mag_sq()}")
  println("{a.dot(b)}")
  println("{b.mag_sq()}")
}
