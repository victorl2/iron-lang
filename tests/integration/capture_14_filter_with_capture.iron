func filter(items: [Int], predicate: func(Int) -> Bool) -> [Int] {
  var out: [Int] = []
  for item in items {
    if predicate(item) {
      out.push(item)
    }
  }
  return out
}

func main() {
  val threshold = 5
  val nums = [1, 3, 5, 7, 9]
  val big = filter(nums, func(n: Int) -> Bool { return n > threshold })
  println("{big.length()}")
}
