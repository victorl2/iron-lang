-- push_interface_pop_order.iron: LIFO order verification for .pop() on
-- interface split collections.
-- Pushes a sequence of distinct shapes and pops them all, verifying that
-- each .pop() returns the most recently pushed element (reverse-push order).
--
-- Push sequence: Circle(1), Square(2), Circle(3), Square(4)
-- Pop sequence must be: Square(4), Circle(3), Square(2), Circle(1)
-- Areas (in pop order): 16, 27, 4, 3
-- After popping all four, .len() must be 0.
--
-- 2-element initial literal with both implementors avoids the Phase 56
-- monomorphic-collapse limitation.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}

patch object Circle {
    readonly func area() -> Int {
      return self.radius * self.radius * 3
    }
}

patch object Square {
    readonly func area() -> Int {
      return self.side * self.side
    }
}

func main() {
  var shapes = [Circle(1), Square(2)]
  shapes.push(Circle(3))
  shapes.push(Square(4))

  -- Pop all four in LIFO order.
  var a = shapes.pop()
  println("{a.area()}")
  var b = shapes.pop()
  println("{b.area()}")
  var c = shapes.pop()
  println("{c.area()}")
  var d = shapes.pop()
  println("{d.area()}")

  -- Collection is now empty.
  println("{shapes.len()}")
}
