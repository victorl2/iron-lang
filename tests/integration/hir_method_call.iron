object Counter {
  var count: Int
    init(count: Int) {
        self.count = count
    }
}

patch object Counter {
    readonly func increment() -> Int {
      return self.count + 1
    }
    readonly func value() -> Int {
      return self.count
    }
}


func main() {
  val c = Counter(0)
  println("{c.value()}")
  println("{c.increment()}")
  val c2 = Counter(10)
  println("{c2.value()}")
  println("{c2.increment()}")
}
