-- url_parse_basic.iron — Phase 59 P05 basic URL parse + default_port integration test.
-- Exercises the Iron-side Url.parse wrapper + Url.default_port static method.
import url

func main() {
    val (u1, e1) = Url.parse("https://example.com/path?q=1#frag")
    if e1.code != 0 {
        println("parse failed")
        return
    }
    println(u1.scheme)
    println(u1.host)
    println(u1.path)
    println(u1.query)
    println(u1.fragment)

    val (u2, e2) = Url.parse("")
    if e2.code == 2000 { println("empty ok") }

    println("{Url.default_port(\"http\")}")
    println("{Url.default_port(\"https\")}")
    println("{Url.default_port(\"bogus\")}")
}
