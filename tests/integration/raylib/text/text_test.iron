-- tests/integration/raylib/text/text_test.iron
-- TEXT category compile-and-link integration test (API-12 coverage).
-- Compile-only: exercises Font / Draw.text / Text.format_i FFI.
-- Window.init required: default font bootstraps inside raylib's InitWindow.
-- Assertion: `./build/ironc build` exits 0.

import raylib

func main() -> Int32 {
    Window.init(Int32(320), Int32(240), "text_test")

    val f = Font.default()
    val valid = Font.is_valid(f)

    Draw.begin()
    Draw.clear(BLACK)
    Draw.fps(Int32(10), Int32(10))
    Draw.text("text_test", Int32(10), Int32(40), Int32(20), WHITE)
    val w_def = Text.measure("text_test", Int32(20))
    val v_ex = Font.measure_ex(f, "text_test", Float32(20.0), Float32(1.0))

    val fmt_i = Text.format_i("%d", Int32(42))
    val fmt_f = Text.format_f("%.2f", Float32(3.14))
    val fmt_s = Text.format_s("[%s]", "hi")
    Draw.end()

    Window.close()

    val _k0 = valid
    val _k1 = w_def
    val _k2 = v_ex
    val _k3 = fmt_i
    val _k4 = fmt_f
    val _k5 = fmt_s

    return Int32(0)
}
