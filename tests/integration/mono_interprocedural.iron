-- mono_interprocedural.iron: Interprocedural monomorphic detection
-- Tests ANAL-01: cross-function return type tracking through chained calls.
-- buildMixed() returns [Circle, Square] -> wrapShapes() calls buildMixed()
-- and returns the result -> main calls wrapShapes() and iterates.
-- Exercises Phase 0 return type collection AND Phase A CALL-to-coll_types wiring.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func buildMixed() -> [Shape] {
  return [Circle(5), Square(4), Circle(3)]
}

func wrapShapes() -> [Shape] {
  val inner = buildMixed()
  return inner
}

func main() {
  val shapes = wrapShapes()
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  println("{total}")
}
