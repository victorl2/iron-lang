-- mono_interprocedural.iron: Interprocedural monomorphic detection
-- Tests ANAL-01: a helper function that constructs and returns a multi-type
-- interface collection where the caller still gets correct results through
-- cross-function return type tracking. The helper returns [Shape] containing
-- Circle and Square; the return type tracking collects {Circle, Square} and
-- propagates to the call site so the split collection is properly handled.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func buildShapes() -> [Shape] {
  return [Circle(5), Square(4), Circle(3)]
}

func main() {
  val shapes = buildShapes()
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  println("{total}")
}
