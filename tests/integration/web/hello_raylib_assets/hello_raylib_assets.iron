import raylib

func main() {
    InitWindow(800, 600, "Hello Raylib Assets")
    // LoadTexture inside main — NOT at module level.
    // Plan 03 bans top-level LoadTexture on web; here we prove
    // the in-function call is fine and the preload flag is emitted.
    let tex = LoadTexture("assets/missing.png")
    while not WindowShouldClose() {
        BeginDrawing()
        ClearBackground(WHITE)
        EndDrawing()
    }
    CloseWindow()
}
