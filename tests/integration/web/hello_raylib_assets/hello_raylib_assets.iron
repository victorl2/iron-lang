import raylib

-- Phase 10 WEB-ASSET-01/02/04/05 smoke fixture. The build-side assertion
-- is that ironc, when fed an iron.toml with [web].assets = "assets/",
-- forwards --preload-file <abs>@/assets to emcc. The Iron source only
-- needs to be a valid raylib program that compiles + links on the web
-- target; no asset API call is required.
--
-- Mirrors the Phase 60 placeholder shape used by hello_raylib.iron —
-- single init / draw-frame / close sequence, no main-loop — so emit_web
-- takes the "no canonical loop" branch and produces a valid WASM module.
func main() {
    val title: String = "Hello Raylib Assets"
    Window.init(800, 600, title)
    val _should: Bool = Window.should_close()
    Draw.begin()
    Draw.clear(WHITE)
    Draw.end()
    Window.close()
    val _unused_title = title
}
