-- mono_multi_type_no_collapse.iron: Multi-type collection remains split
-- Negative test: collections with multiple concrete types must NOT collapse.
-- The split collection dispatch path handles Circle and Square sub-arrays
-- separately, producing the same result as ordered iteration.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  val shapes = [Circle(5), Square(4), Circle(3)]
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  println("{total}")
}
