object Vec2 {
  var x: Int
  var y: Int
    init(x: Int, y: Int) {
        self.x = x
        self.y = y
    }
}

patch object Vec2 {
    readonly func length_sq() -> Int {
      return self.x * self.x + self.y * self.y
    }
    readonly func manhattan() -> Int {
      return self.x + self.y
    }
}


func main() {
  val v1 = Vec2(3, 4)
  val v2 = Vec2(5, 12)
  println("{v1.length_sq()}")
  println("{v1.manhattan()}")
  println("{v2.length_sq()}")
  println("{v2.manhattan()}")
}
