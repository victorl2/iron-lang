-- tests/integration/mut_receiver_static_twin.iron
-- Phase 79 MUT-05 twin of mut_receiver_grammar.iron.
-- Same object, same method name, same receiver type, same param types,
-- same return type, same body -- ONLY the `mut` keyword is removed from
-- the Counter.bump receiver binding.
--
-- Phase 79 role (when it shipped): byte-identical C signature vs
-- mut_receiver_grammar.iron — proving `mut` was purely a surface grammar
-- annotation with zero lowering effect. Both .expected files were
-- byte-identical (`0\n500000`).
--
-- Phase 80 role (current): pure-superset control. `mut` is now a
-- behavior switch — user-type mut-receiver methods fire self_by_addr
-- and persist mutation (MUT-07). This twin (no `mut`) continues to use
-- the by-value ABI, so c.bump() mutations are lost and c.n stays 0.
-- That's the negative-space contract for existing Iron code: adding
-- Phase 80's enforcement does NOT retroactively change semantics for
-- receiver-form methods that don't carry `mut` — pre-Phase-80 files
-- compile with identical runtime behavior.
--
-- Expected output stays `0\n500000`. The sister file
-- mut_receiver_grammar.expected is now `3\n500000` (Phase 80 MUT-07).

import time

object Counter {
    var n: Int
}

-- No `mut` keyword -- v2.1 receiver-form (val-default binding).
-- Byte-identical C signature expected vs mut_receiver_grammar.iron.
func (c: Counter) bump() {
    c.n = c.n + 1
}

func (c: Counter) get() -> Int {
    return c.n
}

func main() {
    val c = Counter(0)
    c.bump()
    c.bump()
    c.bump()
    println("{c.get()}")

    val timer = Time.Timer(1000.0)
    timer.update(500.0)
    println("{timer.elapsed_ms}")
}
