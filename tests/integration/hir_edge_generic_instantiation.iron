-- Generic-style: multiple concrete type instantiations
object IntWrapper {
  var value: Int
    init(value: Int) {
        self.value = value
    }
}

object FloatWrapper {
  var value: Float
    init(value: Float) {
        self.value = value
    }
}

object StringWrapper {
  var value: String
    init(value: String) {
        self.value = value
    }
}

patch object IntWrapper {
    readonly func doubled() -> Int {
      return self.value * 2
    }
}

patch object FloatWrapper {
    readonly func doubled() -> Float {
      return self.value * 2.0
    }
}

func main() {
  val iw = IntWrapper(21)
  val fw = FloatWrapper(3.14)
  val sw = StringWrapper("hello")
  println("{iw.doubled()}")
  println("{iw.value}")
  println(sw.value)
}
