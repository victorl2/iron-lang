-- ADT wildcard pattern test: _ suppresses binding in pattern

enum Pair {
  Both(Int, Int),
}

func first(p: Pair) -> Int {
  match p {
    Pair.Both(a, _) -> a
  }
}

func second(p: Pair) -> Int {
  match p {
    Pair.Both(_, b) -> b
  }
}

func main() {
  val p = Pair.Both(42, 99)
  println("first: {first(p)}")
  println("second: {second(p)}")
}
