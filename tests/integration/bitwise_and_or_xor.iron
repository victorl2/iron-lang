-- Tests &, |, ^ with values chosen to distinguish results.

func main() {
    val a = 12   -- 0b1100
    val b = 10   -- 0b1010

    println("{a & b}")   -- 0b1000 = 8
    println("{a | b}")   -- 0b1110 = 14
    println("{a ^ b}")   -- 0b0110 = 6

    -- XOR with self = 0, XOR with 0 = self
    println("{a ^ a}")   -- 0
    println("{a ^ 0}")   -- 12

    -- AND with 0 = 0, OR with 0 = self
    println("{a & 0}")   -- 0
    println("{a | 0}")   -- 12
}
