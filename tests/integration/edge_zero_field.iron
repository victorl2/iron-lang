-- edge_zero_field.iron: Zero-field struct edge case
-- Tests that split collections work correctly with zero-payload implementors
-- (only tag byte in Stor struct, no data fields)

interface Marker {
  func tag() -> Int
}

object TypeA impl Marker {
}

object TypeB impl Marker {
}

func TypeA.tag() -> Int {
  return 1
}

func TypeB.tag() -> Int {
  return 2
}

func main() {
  -- Create split collection with zero-field implementors
  val markers = [TypeA(), TypeB(), TypeA(), TypeB(), TypeA()]

  -- Test 1: map+sum on zero-field split collection
  -- 1+2+1+2+1 = 7
  val result1 = markers.map(func(m: Marker) -> Int { return m.tag() }).sum()
  println("{result1}")

  -- Test 2: filter+reduce on zero-field split collection
  -- Filter tag==1: TypeA, TypeA, TypeA -> map to 1,1,1 -> sum = 3
  val result2 = markers.filter(func(m: Marker) -> Bool { return m.tag() == 1 }).map(func(m: Marker) -> Int { return m.tag() }).sum()
  println("{result2}")
}
