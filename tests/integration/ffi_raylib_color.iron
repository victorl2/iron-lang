-- ffi_raylib_color.iron — regression test for FFI ABI mismatch fix
-- Verifies that extern func parameters with Iron types (Int, Color, String)
-- are correctly cast to C types (int, Color struct, const char*) at call sites.

import raylib

func main() {
    InitWindow(800, 600, "FFI Test")
    SetTargetFPS(60)
    BeginDrawing()
    ClearBackground(BLACK)
    DrawText("Hello FFI", 10, 10, 20, WHITE)
    DrawRectangle(100, 100, 50, 50, RED)
    EndDrawing()
    CloseWindow()
}
