func classify(n: Int) -> String {
  if n < 0 {
    return "negative"
  } elif n == 0 {
    return "zero"
  } elif n < 10 {
    return "small"
  } elif n < 100 {
    return "medium"
  } else {
    return "large"
  }
  return "unknown"
}

func main() {
  println(classify(-5))
  println(classify(0))
  println(classify(7))
  println(classify(42))
  println(classify(200))
}
