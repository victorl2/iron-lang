-- push_interface_multi_type.iron: Push with both interface implementors
-- Exercises per-type dispatch for both alive implementors via .push()
-- and sums areas (order-independent) to verify correctness.
-- Initial literal includes both Circle and Square to prevent the
-- monomorphic-collapse path (that issue is scoped to Phase 56).

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}

patch object Circle {
    readonly func area() -> Int {
      return self.radius * self.radius * 3
    }
}

patch object Square {
    readonly func area() -> Int {
      return self.side * self.side
    }
}

func main() {
  var shapes = [Circle(1), Square(2)]
  shapes.push(Circle(3))
  shapes.push(Square(4))
  shapes.push(Circle(5))

  -- Circle(1)=3, Square(2)=4, Circle(3)=27, Square(4)=16, Circle(5)=75
  -- Total = 125
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  println("{total}")
}
