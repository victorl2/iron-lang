-- Regression test: VLA (dynamic fill) after early return must not
-- produce C code where a goto jumps over the VLA declaration.

func search(arr: [Int], n: Int, target: Int) -> Int {
    if n == 0 {
        return -1
    }
    var counts = fill(n, 0)
    for i in range(n) {
        counts[i] = arr[i]
    }
    var result = 0
    for i in range(n) {
        if counts[i] == target {
            result = result + 1
        }
    }
    return result
}

func main() {
    val arr = [1, 2, 3, 2, 1]
    println("empty: {search(arr, 0, 1)}")
    println("found: {search(arr, 5, 2)}")
    println("none: {search(arr, 5, 99)}")
}
