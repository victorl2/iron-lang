-- Generic-style: Using multiple concrete types to verify type system
object IntBox {
  var value: Int
    init(value: Int) {
        self.value = value
    }
}

object StringBox {
  var value: String
    init(value: String) {
        self.value = value
    }
}

func main() {
  val ib = IntBox(42)
  val sb = StringBox("hello")
  println("{ib.value}")
  println(sb.value)
}
