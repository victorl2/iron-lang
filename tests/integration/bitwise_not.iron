-- Tests unary ~ (bitwise NOT) on Int.
-- ~x == -x - 1 in two's complement for signed int64.

func main() {
    println("{~0}")     -- -1
    println("{~1}")     -- -2
    println("{~(-1)}")  -- 0
    println("{~5}")     -- -6
    println("{~(-6)}")  -- 5

    -- Double negation identity
    val a = 42
    println("{~~a}")    -- 42
}
