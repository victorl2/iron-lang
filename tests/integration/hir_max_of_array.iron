func max_of(arr: [Int], n: Int) -> Int {
  var max = arr[0]
  var i = 1
  while i < n {
    if arr[i] > max {
      max = arr[i]
    }
    i = i + 1
  }
  return max
}

func main() {
  val arr = [3, 7, 1, 9, 4, 2]
  println("{max_of(arr, 6)}")
  val arr2 = [100, 50, 200, 150]
  println("{max_of(arr2, 4)}")
}
