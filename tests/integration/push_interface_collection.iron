-- push_interface_collection.iron: Main regression for PUSH-01
-- Reproduction from .planning/debug/push-split-collection.md
-- Previously produced undeclared Iron_List_Iron_Shape_push in generated C.
-- Phase 55 fix: split-collection interception block now dispatches .push()
-- to the correct per-type Iron_SplitList_<Iface>_push_<Type> function.

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  var shapes = [Circle(1), Square(2)]
  shapes.push(Circle(3))
  -- Split iteration groups by type (all Circles, then all Squares).
  -- Circle(1)=3, Circle(3)=27, Square(2)=4
  for s in shapes {
    println("{s.area()}")
  }
}
