-- ffi_extern_int_cast.iron — verifies int64_t → int casting at extern call sites.
-- Tests that Iron's uniform Int (int64_t) is narrowed to C's int when calling
-- foreign-method stubs whose LIR param types are Int32.
--
-- Migrated from the old camelCase raylib API (InitWindow / SetTargetFPS /
-- CloseWindow) to the namespaced Phase 60+ surface. Window.init / .set_target_fps
-- still take Int32, so the int64→int narrowing path exercised here is unchanged.

import raylib

func main() {
    Window.init(640, 480, "Int Cast Test")
    Window.set_target_fps(30)
    Window.close()
}
