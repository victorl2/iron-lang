-- Integration test: TIME-01..05
-- time.since() returns Float — do not print directly.
-- Timer.update / Timer.reset now compile (post-Phase-73 residual D-coll fix
-- in hir_to_lir.c: pointer-receiver calls carry a structured self_by_addr
-- flag on the LIR call instruction, replacing the earlier prefix-strncmp
-- heuristic). The TIME-04 / TIME-05 assertions below exercise both sites.
import time

func main() {
    -- TIME-01: time.since
    val start = Time.now()
    val elapsed = Time.since(start)
    println("since ok")

    -- TIME-02: Timer constructor with duration and elapsed fields
    val t = Time.Timer(5.0)
    println("{t.duration_ms}")
    println("{t.elapsed_ms}")

    -- TIME-03: timer.done (false — elapsed=0, duration=5000ms)
    val d1 = Timer.done(t)
    println("{d1}")

    -- TIME-04: Timer.update — the static-style call is the form compiled by
    -- the existing lexer; it exercises the self_by_addr path on the
    -- general method-call branch in hir_to_lir.c. dt is in seconds; the
    -- shim accumulates dt * 1000 into t.elapsed_ms. 1.5 s → 1500 ms.
    Timer.update(t, 1.5)

    -- TIME-05: Timer.reset — zeroes t.elapsed_ms.
    Timer.reset(t)
    println("update+reset ok")
}
