-- coll_split_reduce.iron: Collection reduce on interface-typed split collection
interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int

    init(radius: Int) {
        self.radius = radius
    }
}

object Square impl Shape {
  var side: Int

    init(side: Int) {
        self.side = side
    }
}

patch object Circle {
    readonly func area() -> Int {
      return self.radius * self.radius * 3
    }
}

patch object Square {
    readonly func area() -> Int {
      return self.side * self.side
    }
}

func main() {
  val shapes = [Circle(5), Square(4), Circle(3)]
  val total = shapes.reduce(0, func(acc: Int, s: Shape) -> Int { return acc + s.area() })
  println("{total}")
}
