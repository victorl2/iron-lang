-- split_collection_basic.iron: Interface-typed arrays with split collection
-- Tests Phase 41: per-type homogeneous arrays with ordered iteration

interface Shape {
  func area() -> Int
}

object Circle impl Shape {
  var radius: Int
}

object Square impl Shape {
  var side: Int
}

func Circle.area() -> Int {
  return self.radius * self.radius * 3
}

func Square.area() -> Int {
  return self.side * self.side
}

func main() {
  -- Create interface-typed array — internally stored as split collection
  val shapes = [Circle(5), Square(4), Circle(3), Square(2)]
  var total = 0
  for s in shapes {
    total = total + s.area()
  }
  -- Circle(5)=75, Square(4)=16, Circle(3)=27, Square(2)=4 → 122
  println("{total}")
  println("done")
}
