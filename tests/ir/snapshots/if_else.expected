; Module: module

func @choose(c: Bool) -> Int {
entry:
  %2 = alloca Bool
  store %2, %1
  %3 = alloca Int
  %4 = const_int 0 : Int
  store %3, %4
  %5 = load %2 : Bool
  branch %5, if_then, if_else
if_merge:
  %8 = load %3 : Int
  ret %8
if_then:
  %6 = const_int 1 : Int
  store %3, %6
  jump if_merge
if_else:
  %7 = const_int 2 : Int
  store %3, %7
  jump if_merge
}
