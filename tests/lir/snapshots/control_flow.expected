while_header_3:
  %12 = phi [%2: if_merge_1, %11: while_body_4] : Int
  %6 = load %1 : Int
  %7 = const_int 0 : Int
  %8 = gt %6, %7 : Bool
  branch %8, while_body_4, while_exit_5
while_body_4:
  %9 = load %1 : Int
