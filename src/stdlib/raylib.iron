-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- Text & Fonts (Phase 67) вЂ” Font loading surface (TEXT-01..06, Plan 67-01)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--
-- Font loading, lifecycle, and data probes. Font struct-by-value crossing
-- the FFI (48 B) proven at Phase 60-03 _Static_assert grid; memcpy
-- patterns reuse Phase 66-04 Texture/RenderTexture templates.
--
-- Instance methods follow the existing stdlib convention:
-- `func TypeName.method(receiver: TypeName, ...)` with explicit receiver
-- parameter вЂ” matching Texture.unload / RenderTexture.unload and every
-- other instance method in raylib.iron. (The plan's initial draft used
-- lowercase receivers `func font.is_valid()`, but the analyzer resolves
-- method type_names via global scope lookup вЂ” lowercase `font` is not a
-- declared type and would fail with E0101 / "method declared on
-- undeclared type". Rule 1 auto-fix applied.)
--
-- PITFALLS (see 67-RESEARCH.md for full detail):
-- вЂў Font.default requires Window.init() first вЂ” raylib loads the default
--   atlas inside InitWindow via rtext.c:LoadFontDefault.
-- вЂў Font.load returns a Font with baseSize=0 on failure; no exception.
--   Callers MUST check with Font.is_valid before drawing.
-- вЂў Font.unload invalidates the Font's _recs / _glyphs pointers (and the
--   embedded texture); do not use the value after unload.
--
-- DEFERRED (awaiting [UInt8] FFI / Iron_List_uint8_t in iron_runtime.h):
-- вЂў Font.from_memory вЂ” takes `[UInt8] fileData`. Same blocker as Phase 66
--   LoadImageFromMemory / LoadImageAnimFromMemory (5 existing deferrals).
-- вЂў Font.load_data вЂ” takes `[UInt8] fileData`, returns `[GlyphInfo]`.
--   Re-bind once Iron_List_uint8_t lands alongside the above.

-- TEXT-01..03 static constructors
func Font.default() -> Font {}
func Font.load(filePath: String) -> Font {}
func Font.load_ex(filePath: String, fontSize: Int32, codepoints: [Int32]) -> Font {}
func Font.from_image(image: Image, keyColor: Color, firstChar: Int32) -> Font {}

-- TEXT-02 / TEXT-04 / TEXT-06 lifecycle + validity + export
func Font.is_valid(font: Font) -> Bool {}
func Font.unload(font: Font) {}
func Font.export_as_code(font: Font, filePath: String) -> Bool {}

-- TEXT-05 Font data operations. gen_image_atlas bakes an atlas Image +
-- per-glyph source Rectangles from an input [GlyphInfo] array, returning
-- both as a tuple. unload_data releases a [GlyphInfo] array allocated by
-- raylib (Font.load_data, deferred). First (Image, [Rectangle]) tuple
-- RETURN and first [GlyphInfo] INPUT in the raylib binding.
func Font.gen_image_atlas(glyphs: [GlyphInfo], fontSize: Int32, padding: Int32, packMethod: Int32) -> (Image, [Rectangle]) {}
func Font.unload_data(glyphs: [GlyphInfo]) {}

-- в”Ђв”Ђ Plan 67-02 Task 1: Text.* default-font utilities (TEXT-09, TEXT-10 default)
--
-- Text.measure: width in pixels of `text` at `fontSize` using raylib's
-- embedded default font. Requires Window.init() (same Pitfall 1 as
-- Draw.text above). For custom-font measurement use Font.measure_ex
-- (Plan 67-02 Task 2 below).
--
-- Text.set_line_spacing: vertical gap in pixels between lines when
-- raylib draws multi-line text. Applies to every draw (default and
-- custom font) that follows. Mutates raylib's internal global state.
func Text.measure(text: String, fontSize: Int32) -> Int32 {}
func Text.set_line_spacing(spacing: Int32) {}

-- в”Ђв”Ђ Plan 67-02 Task 2: Font.* instance methods вЂ” custom-font draws (TEXT-08)
--
-- Explicit-receiver convention: `func Font.method(font: Font, ...)`
-- matches Font.is_valid / Font.unload above + Texture.unload /
-- RenderTexture.unload (Phases 66-04/05) + every other instance method
-- in this file. Lowercase-receiver form (e.g. `func font.draw_ex(...)`)
-- would fail analyzer resolution because `font` is not a declared type.
-- Rule 1 auto-fix carried over from Plan 67-01.

-- draw_ex: axis-aligned custom-font draw at `position` with horizontal
-- glyph spacing.
func Font.draw_ex(font: Font, text: String, position: Vector2, fontSize: Float32, spacing: Float32, tint: Color) {}

-- draw_pro: same as draw_ex but rotates the baseline around `origin`.
-- `rotation` is in degrees (raylib convention).
func Font.draw_pro(font: Font, text: String, position: Vector2, origin: Vector2, rotation: Float32, fontSize: Float32, spacing: Float32, tint: Color) {}

-- draw_codepoint: render a single codepoint at an exact pixel position.
-- Use for manual glyph layout (kerning pairs, baseline alignment, ...).
func Font.draw_codepoint(font: Font, codepoint: Int32, position: Vector2, fontSize: Float32, tint: Color) {}

-- draw_codepoints: render an explicit sequence of codepoints with
-- fixed `spacing` between each glyph (no kerning, no line breaks).
-- Second Iron_List_int32_t INPUT call site in the raylib binding.
func Font.draw_codepoints(font: Font, codepoints: [Int32], position: Vector2, fontSize: Float32, spacing: Float32, tint: Color) {}

-- в”Ђв”Ђ Plan 67-02 Task 2: Font.* custom-font measure (TEXT-10 custom variant)
--
-- Returns exact text bounds as Vector2(width, height) вЂ” height
-- includes line spacing. Unlike Text.measure, accepts Float32 sizes
-- and per-glyph `spacing`.
func Font.measure_ex(font: Font, text: String, fontSize: Float32, spacing: Float32) -> Vector2 {}

-- в”Ђв”Ђ Plan 67-02 Task 2: Font.* glyph lookup (TEXT-11)
--
-- get_glyph_index: 0-based atlas slot for `codepoint`; returns the `?`
-- fallback index on miss.
-- get_glyph_info: FIRST GlyphInfo struct-by-value RETURN in the
-- binding. WARNING: the returned GlyphInfo.image.data aliases the
-- parent Font's heap glyph array вЂ” do NOT read after Font.unload.
-- (Pitfall 7, 67-RESEARCH.md.)
-- get_glyph_atlas_rec: source Rectangle inside the font's atlas
-- texture; useful for manual Texture.draw_rec uploads of a single
-- glyph bitmap.
func Font.get_glyph_index(font: Font, codepoint: Int32) -> Int32 {}
func Font.get_glyph_info(font: Font, codepoint: Int32) -> GlyphInfo {}
func Font.get_glyph_atlas_rec(font: Font, codepoint: Int32) -> Rectangle {}

-- в”Ђв”Ђ UTF-8 / codepoint utilities (TEXT-12) вЂ” Plan 67-03 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
--
-- Task 1 probe: [Int32] RETURN from a foreign-method stub. Iron_List_int32_t
-- is pre-declared in iron_runtime.h:826, so no compiler scan extension is
-- needed вЂ” the primitive-element list bypasses emit_structs.c Scan B
-- (which only fires for IRON_TYPE_OBJECT elements) and relies on the
-- runtime pre-declaration that's already in every TU.

-- Text.load_codepoints: extract codepoints from a UTF-8 string. Shim
-- owns raylib's buffer lifecycle (calls UnloadCodepoints after memcpy) вЂ”
-- no user-facing unload needed.
func Text.load_codepoints(text: String) -> [Int32] {}

-- Task 2 probe: Iron String allocation from raylib's 6-byte static
-- char buffer (CodepointToUTF8 writes into `static char utf8[6]` at
-- rtext.c:1914 and zeroes it BEFORE the next call). Shim copies the
-- bytes into a fresh Iron String immediately вЂ” Phase 61
-- Iron_window_get_clipboard_text pattern extended to a second static
-- buffer site.
--
-- Text.codepoint_to_utf8: convert a single codepoint to its UTF-8 byte
-- sequence (1-4 bytes for valid codepoints). Shim copies raylib's
-- 6-byte static buffer into a fresh Iron String.
func Text.codepoint_to_utf8(codepoint: Int32) -> String {}

-- Text.load_utf8: build a UTF-8 string from an array of codepoints.
-- Shim owns raylib's caller-must-free char* (LoadUTF8 allocates;
-- UnloadUTF8 frees) вЂ” no user-facing unload.
func Text.load_utf8(codepoints: [Int32]) -> String {}

-- Text.codepoint_count: count codepoints (not bytes) in a UTF-8 string.
func Text.codepoint_count(text: String) -> Int32 {}

-- Text.codepoint_at: read codepoint at byte-offset. Returns
-- (codepoint, byteSize). Invalid UTF-8 returns (0x3F, 1) вЂ” the '?'
-- fallback (raylib convention).
func Text.codepoint_at(text: String, offset: Int32) -> (Int32, Int32) {}

-- Text.codepoint_next: read next codepoint from byte-offset. Returns
-- (codepoint, byteSize). Typical iteration pattern:
--   val (cp, step) = Text.codepoint_next(s, pos); pos = pos + step
func Text.codepoint_next(text: String, offset: Int32) -> (Int32, Int32) {}

-- Text.codepoint_previous: read previous codepoint from byte-offset.
-- Returns (codepoint, byteSize). byteSize is the size of the PREVIOUS
-- codepoint (the one ending at `offset`); caller decrements by that
-- many bytes to step backward.
func Text.codepoint_previous(text: String, offset: Int32) -> (Int32, Int32) {}

-- в”Ђв”Ђ TEXT-13 string utilities (20 methods; Text.append OMITTED) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
--
-- 17 Text.* utilities + 3 TextFormat overloads. Iron has no varargs FFI,
-- so TextFormat is exposed as three fixed-arity shims (format_i /
-- format_f / format_s). Each overload covers the most common single-
-- scalar interpolation pattern вЂ” for multi-argument formats, compose
-- multiple Text.format_* calls or use Iron's built-in `"{x}"` interp
-- outside the Text.* API.
--
-- NOTE: Text.append OMITTED вЂ” raylib's TextAppend mutates a caller
-- buffer and advances int *position (no clean Iron mapping since Iron
-- Strings are immutable). Use Text.insert for the same semantics with
-- a cleaner API. See 67-RESEARCH.md Open Question 3.
--
-- NOTE: Text.copy is a PURE-FUNCTIONAL alternative to raylib's mutating
-- TextCopy вЂ” returns a fresh String copy of the source. Mainly useful
-- for FFI parity; Iron Strings are already immutable + copy-on-reference
-- so this is rarely needed at the Iron level.
--
-- NOTE: Text.join + Text.split use Iron_List_Iron_String on both sides
-- of the FFI (first [String] INPUT + [String] RETURN in the raylib
-- binding). Runtime helpers at iron_string.c:434-491.

func Text.copy(source: String) -> String {}
func Text.is_equal(a: String, b: String) -> Bool {}
func Text.length(text: String) -> Int32 {}

-- TextFormat -> 3 fixed-arity overloads (scalar-only). Pick the
-- overload matching the single interpolated value's type:
--   format_i for %d / %u / %x / %o integer formats
--   format_f for %f / %.Nf float formats (promoted to double internally)
--   format_s for %s string formats
func Text.format_i(fmt: String, value: Int32) -> String {}
func Text.format_f(fmt: String, value: Float32) -> String {}
func Text.format_s(fmt: String, value: String) -> String {}

func Text.subtext(text: String, position: Int32, length: Int32) -> String {}
func Text.replace(text: String, replace: String, by: String) -> String {}
func Text.insert(text: String, insert: String, position: Int32) -> String {}

-- [String] INPUT / RETURN вЂ” first Iron_List_Iron_String crossing the
-- raylib FFI boundary.
func Text.join(parts: [String], delimiter: String) -> String {}
func Text.split(text: String, delimiter: String) -> [String] {}

func Text.find_index(text: String, find: String) -> Int32 {}

-- Case conversion + identifier-shape transforms.
func Text.to_upper(text: String) -> String {}
func Text.to_lower(text: String) -> String {}
func Text.to_pascal(text: String) -> String {}
func Text.to_snake(text: String) -> String {}
func Text.to_camel(text: String) -> String {}
func Text.to_integer(text: String) -> Int32 {}
func Text.to_float(text: String) -> Float32 {}

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- raylib 5.5 canonical 26-color palette (TEX-14 closed Phase 66 Plan 01)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--
-- RGBA values copied verbatim from src/vendor/raylib/raylib.h lines 175-201.
-- Integer literals only вЂ” Iron narrows to UInt8 via typecheck.c:1326.
-- DO NOT add float suffixes (would trigger E0217 per Phase 66 RESEARCH
-- Pitfall 2). All 6 Plan 60-08 rescue palette names (RED/BLUE/GREEN/
-- WHITE/BLACK/DARKGRAY) are preserved in the canonical 26-color set;
-- existing consumers (pong.iron, game_raylib.iron, hello_raylib.iron)
-- compile unchanged.

val LIGHTGRAY  = Color(200, 200, 200, 255)
val GRAY       = Color(130, 130, 130, 255)
val DARKGRAY   = Color(80,  80,  80,  255)
val YELLOW     = Color(253, 249, 0,   255)
val GOLD       = Color(255, 203, 0,   255)
val ORANGE     = Color(255, 161, 0,   255)
val PINK       = Color(255, 109, 194, 255)
val RED        = Color(230, 41,  55,  255)
val MAROON     = Color(190, 33,  55,  255)
val GREEN      = Color(0,   228, 48,  255)
val LIME       = Color(0,   158, 47,  255)
val DARKGREEN  = Color(0,   117, 44,  255)
val SKYBLUE    = Color(102, 191, 255, 255)
val BLUE       = Color(0,   121, 241, 255)
val DARKBLUE   = Color(0,   82,  172, 255)
val PURPLE     = Color(200, 122, 255, 255)
val VIOLET     = Color(135, 60,  190, 255)
val DARKPURPLE = Color(112, 31,  126, 255)
val BEIGE      = Color(211, 176, 131, 255)
val BROWN      = Color(127, 106, 79,  255)
val DARKBROWN  = Color(76,  63,  47,  255)
val WHITE      = Color(255, 255, 255, 255)
val BLACK      = Color(0,   0,   0,   255)
val BLANK      = Color(0,   0,   0,   0)
val MAGENTA    = Color(255, 0,   255, 255)
val RAYWHITE   = Color(245, 245, 245, 255)

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- Window & System (Phase 61)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--
-- Phase 61 binds raylib's `rcore.c` window / system functions to the
-- `Window` namespace type declared in Plan 60-06. Every empty-body
-- stub below lowers to `Iron_window_<name>(...)` in C, implemented by
-- src/stdlib/iron_raylib.c. Shim-only pattern per 60-CONTEXT.md.
--
-- Phase 61 Plan 01 locked in the pattern with lifecycle + state queries.
-- Subsequent plans (61-02..04) completed state toggles, runtime properties,
-- screen geometry, monitor enumeration, clipboard, screenshot, config
-- flags, trace log, event waiting, cursor, frame loop, URL, wait_time.
-- Struct-by-value returns validated via GetWindowPosition, GetMonitorPosition,
-- GetWindowScaleDPI, GetClipboardImage, and LoadImageFromScreen.

-- Window lifecycle (WIN-01)
--
-- `Window.init` MUST be called before any other Window.* method
-- except `Window.set_config_flags` / `Window.set_trace_log_level`
-- (those are pre-init-only and live in Plan 61-04). Calling anything
-- else before init is undefined behavior вЂ” raylib will crash or
-- silently no-op. Iron does not enforce this at runtime; trust the
-- user to follow the lifecycle.
func Window.init(w: Int32, h: Int32, title: String) {}
func Window.close() {}
func Window.should_close() -> Bool {}

-- Window state queries (WIN-02)
func Window.is_ready() -> Bool {}
func Window.is_fullscreen() -> Bool {}
func Window.is_hidden() -> Bool {}
func Window.is_minimized() -> Bool {}
func Window.is_maximized() -> Bool {}
func Window.is_focused() -> Bool {}
func Window.is_resized() -> Bool {}

-- Window state toggles (WIN-03)
--
-- `set_state` / `clear_state` / `is_state` take a ConfigFlags bitmask.
-- raylib uses the SAME ConfigFlags enum for both pre-init SetConfigFlags
-- and post-init SetWindowState. Pass a single bit like
-- `ConfigFlags.WINDOW_RESIZABLE` or a caller-combined mask вЂ” Iron has
-- no native enum OR operator yet, so multi-flag calls currently require
-- one call per bit. Combining is a Phase 73 concern.
func Window.toggle_fullscreen() {}
func Window.toggle_borderless_windowed() {}
func Window.maximize() {}
func Window.minimize() {}
func Window.restore() {}
func Window.set_state(flags: ConfigFlags) {}
func Window.clear_state(flags: ConfigFlags) {}
func Window.is_state(flag: ConfigFlags) -> Bool {}

-- Window runtime properties (WIN-04)
--
-- `set_icon` takes a single Image by value. raylib also exposes
-- SetWindowIcons(Image *images, int count) for animated icons;
-- Iron has no `Array<Image>` type yet, so the plural form is
-- DEFERRED to Phase 73 (API polish).
func Window.set_icon(image: Image) {}
func Window.set_title(title: String) {}
func Window.set_position(x: Int32, y: Int32) {}
func Window.set_monitor(monitor: Int32) {}
func Window.set_min_size(w: Int32, h: Int32) {}
func Window.set_max_size(w: Int32, h: Int32) {}
func Window.set_size(w: Int32, h: Int32) {}
func Window.set_opacity(opacity: Float32) {}
func Window.set_focused() {}

-- Screen and window geometry (WIN-05)
func Window.get_screen_width() -> Int32 {}
func Window.get_screen_height() -> Int32 {}
func Window.get_render_width() -> Int32 {}
func Window.get_render_height() -> Int32 {}
func Window.get_window_position() -> Vector2 {}
func Window.get_window_scale_dpi() -> Vector2 {}

-- Monitor enumeration (WIN-06)
func Window.get_monitor_count() -> Int32 {}
func Window.get_current_monitor() -> Int32 {}
func Window.get_monitor_position(monitor: Int32) -> Vector2 {}
func Window.get_monitor_width(monitor: Int32) -> Int32 {}
func Window.get_monitor_height(monitor: Int32) -> Int32 {}
func Window.get_monitor_physical_width(monitor: Int32) -> Int32 {}
func Window.get_monitor_physical_height(monitor: Int32) -> Int32 {}
func Window.get_monitor_refresh_rate(monitor: Int32) -> Int32 {}
func Window.get_monitor_name(monitor: Int32) -> String {}

-- Clipboard (WIN-07)
--
-- `get_clipboard_text` and `get_clipboard_image` copy the data into
-- Iron-managed storage, so the returned values are stable across
-- subsequent raylib calls. `get_clipboard_image` may return an
-- Image with _data=0 / width=0 / height=0 if the system clipboard
-- contains no image вЂ” user code should check dimensions before use.
func Window.get_clipboard_text() -> String {}
func Window.set_clipboard_text(text: String) {}
func Window.get_clipboard_image() -> Image {}

-- Screenshot (WIN-09)
-- `take_screenshot` writes a PNG to `filename`. raylib infers format
-- from the extension вЂ” use `.png` for PNG, `.bmp` for BMP, etc.
-- `load_image_from_screen` returns the current framebuffer as a
-- CPU-side Image; must be called between Draw.begin/end once Phase
-- 63 lands those. Caller owns the returned Image.
func Window.take_screenshot(filename: String) {}
func Window.load_image_from_screen() -> Image {}

-- Config flags and trace log (WIN-10)
--
-- `set_config_flags` MUST be called BEFORE `Window.init`. raylib reads
-- these flags inside InitWindow to configure the GLFW window and GL
-- context. Calling set_config_flags after init is a no-op. Iron does
-- not enforce this вЂ” trust the user to follow the lifecycle.
func Window.set_config_flags(flags: ConfigFlags) {}
func Window.set_trace_log_level(level: TraceLogLevel) {}

-- Event waiting (WIN-08)
--
-- When event-waiting is ENABLED, raylib's main loop blocks in
-- EndDrawing waiting for user input rather than polling. This drops
-- CPU usage in idle apps but eliminates frame-based updates. Default
-- is disabled (active polling loop).
func Window.enable_event_waiting() {}
func Window.disable_event_waiting() {}

-- Cursor control (WIN-11)
--
-- `enable_cursor` unlocks the cursor (it moves freely over the window);
-- `disable_cursor` locks the cursor to window center (FPS-game mode).
-- `show_cursor` / `hide_cursor` control visibility without locking.
-- `set_mouse_cursor` picks a cursor shape from MouseCursor enum.
func Window.show_cursor() {}
func Window.hide_cursor() {}
func Window.is_cursor_hidden() -> Bool {}
func Window.enable_cursor() {}
func Window.disable_cursor() {}
func Window.is_cursor_on_screen() -> Bool {}
func Window.set_mouse_cursor(cursor: MouseCursor) {}

-- Frame loop (WIN-12)
--
-- `set_target_fps(60)` caps the frame rate; raylib internally calls
-- WaitTime to sleep the remainder of each frame. `get_fps` returns
-- the current measured rate. `get_frame_time` is the delta time of
-- the last frame in SECONDS as a Float32 (raylib C `float`). `get_time`
-- is the elapsed time since `Window.init` as a Float (raylib C `double`).
-- Note the Float32/Float split вЂ” frame_time is single-precision.
func Window.set_target_fps(fps: Int32) {}
func Window.get_fps() -> Int32 {}
func Window.get_frame_time() -> Float32 {}
func Window.get_time() -> Float {}

-- URL opener (WIN-13)
func Window.open_url(url: String) {}

-- Wait (FILE-07)
--
-- Halts program execution for the specified number of seconds. Takes
-- a Float (raylib C `double`) so sub-millisecond precision is available.
-- On very short waits, raylib may busy-wait rather than sleep.
func Window.wait_time(seconds: Float) {}

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- Input (Phase 62)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--
-- Phase 62 binds raylib's `rcore.c` input-section functions to five
-- namespace types: Keyboard (this plan), Mouse (62-02), Gamepad
-- (62-03), Touch / Gesture / file-drop (62-04). Every empty-body
-- stub below lowers to `Iron_<namespace>_<name>(...)` in C,
-- implemented by src/stdlib/iron_raylib.c. Same shim-only pattern
-- as Phase 61.
--
-- All enum parameters are typed Iron enums (KeyboardKey, MouseButton,
-- GamepadButton, GamepadAxis, MouseCursor, Gesture). The shim casts
-- them to / from raylib's `int` / `unsigned int` at the FFI boundary.

-- Keyboard (INPUT-01, INPUT-02, INPUT-03)
--
-- `is_pressed` fires once on the frame the key transitions upв†’down.
-- `is_pressed_repeat` fires on the OS key-repeat schedule (held key).
-- `is_down` is true while the key is held; `is_released` fires once
-- on the downв†’up transition; `is_up` is true while the key is NOT held.
--
-- `get_pressed` drains the key-press queue and returns the next
-- KeyboardKey, or `KeyboardKey.NULL` when the queue is empty. Call
-- it repeatedly until you get NULL to read every queued press.
--
-- `get_char_pressed` drains the unicode-codepoint queue (used for
-- text input) and returns Int32 codepoints вЂ” NOT a KeyboardKey
-- enum, because codepoints span the full Unicode range and have
-- no symbolic enum.
--
-- `set_exit_key` overrides raylib's default ESC-quits-the-app
-- behavior. Pass any KeyboardKey value, or pass `KeyboardKey.NULL`
-- to disable the exit key entirely.
func Keyboard.is_pressed(key: KeyboardKey) -> Bool {}
func Keyboard.is_pressed_repeat(key: KeyboardKey) -> Bool {}
func Keyboard.is_down(key: KeyboardKey) -> Bool {}
func Keyboard.is_released(key: KeyboardKey) -> Bool {}
func Keyboard.is_up(key: KeyboardKey) -> Bool {}
func Keyboard.get_pressed() -> KeyboardKey {}
func Keyboard.get_char_pressed() -> Int32 {}
func Keyboard.set_exit_key(key: KeyboardKey) {}

-- Mouse (INPUT-04, INPUT-05, INPUT-06, INPUT-07)
--
-- `is_button_pressed` / `_down` / `_released` / `_up` take a typed
-- MouseButton вЂ” left, right, middle, side, extra, forward, back.
--
-- `get_position` / `get_delta` / `get_wheel_move_v` return a Vector2
-- by value вЂ” first per-frame-called struct returns in the stdlib.
-- `get_x` / `get_y` return Int32 for quick axis reads; `get_wheel_move`
-- returns a Float32 combining both wheel axes (whichever is larger).
--
-- `set_position` / `set_offset` / `set_scale` override raylib's
-- internal mouse coordinate transform. `set_cursor` picks a shape
-- from MouseCursor (arrow, ibeam, crosshair, pointing_hand, resize_*,
-- not_allowed).
func Mouse.is_button_pressed(button: MouseButton) -> Bool {}
func Mouse.is_button_down(button: MouseButton) -> Bool {}
func Mouse.is_button_released(button: MouseButton) -> Bool {}
func Mouse.is_button_up(button: MouseButton) -> Bool {}
func Mouse.get_x() -> Int32 {}
func Mouse.get_y() -> Int32 {}
func Mouse.get_position() -> Vector2 {}
func Mouse.get_delta() -> Vector2 {}
func Mouse.set_position(x: Int32, y: Int32) {}
func Mouse.set_offset(offset_x: Int32, offset_y: Int32) {}
func Mouse.set_scale(scale_x: Float32, scale_y: Float32) {}
func Mouse.get_wheel_move() -> Float32 {}
func Mouse.get_wheel_move_v() -> Vector2 {}
func Mouse.set_cursor(cursor: MouseCursor) {}

-- Gamepad (INPUT-08, INPUT-09, INPUT-10)
--
-- `is_available` / `get_name` query connection state. Up to 4
-- gamepads are addressable via index 0..3.
--
-- `is_button_pressed` / `_down` / `_released` / `_up` take a
-- GamepadButton вЂ” 18 values covering face / trigger / middle /
-- thumb buttons. `get_button_pressed` drains the button-press
-- queue and returns a typed GamepadButton, or GamepadButton.unknown
-- when empty.
--
-- `get_axis_count` / `get_axis_movement` read analog axes вЂ” 6
-- values per gamepad (LeftX/Y, RightX/Y, LeftTrigger, RightTrigger).
-- Movement is Float32 in [-1.0, +1.0] for sticks, [0.0, 1.0] for
-- triggers.
--
-- `set_vibration` drives both motors with duration in seconds;
-- `set_mappings` installs a SDL_GameControllerDB-format mapping
-- string and returns the count of new mappings registered.
func Gamepad.is_available(gamepad: Int32) -> Bool {}
func Gamepad.get_name(gamepad: Int32) -> String {}
func Gamepad.is_button_pressed(gamepad: Int32, button: GamepadButton) -> Bool {}
func Gamepad.is_button_down(gamepad: Int32, button: GamepadButton) -> Bool {}
func Gamepad.is_button_released(gamepad: Int32, button: GamepadButton) -> Bool {}
func Gamepad.is_button_up(gamepad: Int32, button: GamepadButton) -> Bool {}
func Gamepad.get_button_pressed() -> GamepadButton {}
func Gamepad.get_axis_count(gamepad: Int32) -> Int32 {}
func Gamepad.get_axis_movement(gamepad: Int32, axis: GamepadAxis) -> Float32 {}
func Gamepad.set_mappings(mappings: String) -> Int32 {}
func Gamepad.set_vibration(gamepad: Int32, left_motor: Float32, right_motor: Float32, duration: Float32) {}

-- Touch (INPUT-11)
--
-- Raylib tracks up to N simultaneous touch points. `get_point_count`
-- returns the active count; indices 0..N-1 are valid for the other
-- accessors. `get_position(0)` / `get_x` / `get_y` cover the most
-- common single-touch case without requiring a loop.
func Touch.get_x() -> Int32 {}
func Touch.get_y() -> Int32 {}
func Touch.get_position(index: Int32) -> Vector2 {}
func Touch.get_point_id(index: Int32) -> Int32 {}
func Touch.get_point_count() -> Int32 {}

-- Gestures (INPUT-12) вЂ” namespace is PLURAL (see collision note on line ~941)
--
-- Raylib's gesture module sits on top of the touch module. Before
-- calling `is_detected` / `get_detected`, enable the gestures you
-- care about via `set_enabled(Gesture.tap)`. `set_enabled` and
-- `is_detected` both accept a typed Gesture enum. For multi-gesture
-- bitmasks, Iron's bitwise-OR on enum values (Phase 59) produces
-- another Gesture value вЂ” e.g., `Gesture.tap | Gesture.swipe_left`.
-- If Iron's type system requires an explicit enum construction for
-- the OR-result, Phase 73 API polish will smooth the ergonomics;
-- the parameter type stays `Gesture` regardless (per CONTEXT.md
-- decisions and the phase goal "typed Iron enum parameters вЂ” no
-- raw ints").
--
-- `get_detected` returns the most-recently-detected Gesture as a
-- typed enum вЂ” Gesture.none when no gesture is active.
--
-- Drag / pinch vectors are Vector2 (x/y deltas); angles are Float32
-- in degrees; hold duration is Float32 in seconds.
func Gestures.set_enabled(flags: Gesture) {}
func Gestures.is_detected(gesture: Gesture) -> Bool {}
func Gestures.get_detected() -> Gesture {}
func Gestures.get_hold_duration() -> Float32 {}
func Gestures.get_drag_vector() -> Vector2 {}
func Gestures.get_drag_angle() -> Float32 {}
func Gestures.get_pinch_vector() -> Vector2 {}
func Gestures.get_pinch_angle() -> Float32 {}

-- File drop (INPUT-13)
--
-- Dropped files land in an internal raylib queue. `is_dropped` is
-- true once after any drop event and stays true until the next
-- load/unload cycle. `load_dropped` returns a FilePathList the user
-- must pass to `unload_dropped` when done (Iron-side value-type,
-- but the backing paths array is owned by raylib's internal heap).
func Files.is_dropped() -> Bool {}
func Files.load_dropped() -> FilePathList {}
func Files.unload_dropped(list: FilePathList) {}

-- FilePathList accessors (INPUT-13 iteration clause)
--
-- Iterate a FilePathList in a typed Iron loop:
--   val files = Files.load_dropped()
--   var i = 0
--   while i < files.count() {
--       print(files.get(i))
--       i = i + 1
--   }
--   Files.unload_dropped(files)
--
-- `get(i)` bounds-checks against `count` on the C side and returns
-- an empty string for out-of-range indices.
func FilePathList.count() -> Int32 {}
func FilePathList.get(index: Int32) -> String {}

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- 2D Drawing (Phase 63)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--
-- Phase 63 binds raylib's `rshapes.c` + `rcore.c` draw-mode and
-- primitive-draw functions to the `Draw` namespace declared in
-- Plan 60-06. Every empty-body stub below lowers to
-- `Iron_draw_<name>(...)` in C, implemented by
-- src/stdlib/iron_raylib.c. Same shim-only pattern as Phase 61/62.
--
-- NAMING: the `draw_` prefix from raylib C names (DrawRectangle,
-- DrawCircle, ...) is DROPPED on the Iron side вЂ” the `Draw`
-- namespace already signals the intent. `Draw.rectangle`, not
-- `Draw.draw_rectangle`. The `_v` / `_ex` / `_pro` / `_lines`
-- variant suffixes are KEPT because they disambiguate shapes with
-- the same base name.
--
-- Plan 63-01 (this file): frame + 6 stack modes (DRAW2D-01..06).
-- Plans 63-02/03/04 extend with primitives, splines, and re-enable
-- consumer files.

-- Frame (DRAW2D-01)
--
-- `begin` / `end` bracket every draw. Raylib buffers draw calls
-- internally and flushes at `end`; skipping `end` produces a black
-- screen and eventual buffer exhaustion. Iron has no `defer` so
-- balance the pair by discipline.
func Draw.begin() {}
func Draw.end() {}

-- Clear (DRAW2D-02)
--
-- Clears the color buffer to the given Color. Call once at the top
-- of every frame, immediately after `Draw.begin()`.
func Draw.clear(color: Color) {}

-- 2D camera mode (DRAW2D-03)
--
-- `begin_mode_2d(camera)` pushes a Camera2D transform onto raylib's
-- modelview stack; every subsequent draw is affected by
-- camera.offset / camera.target / camera.rotation / camera.zoom
-- until the matching `end_mode_2d()`. `Camera` is Iron's name for
-- raylib's `Camera2D` type (Plan 60-04 decision).
func Draw.begin_mode_2d(camera: Camera) {}
func Draw.end_mode_2d() {}

-- Texture mode (DRAW2D-04)
--
-- `begin_texture_mode(target)` redirects all subsequent draws into
-- the given RenderTexture's framebuffer instead of the main screen.
-- Users load the RenderTexture via Phase 66 (TEX-09); Phase 63
-- exposes only the mode-stack bracket. Flip-Y is handled by raylib
-- internally for cross-target (native/web) consistency.
func Draw.begin_texture_mode(target: RenderTexture) {}
func Draw.end_texture_mode() {}

-- Shader + blend modes (DRAW2D-05)
--
-- `begin_shader_mode(shader)` pushes a GLSL shader onto the draw
-- stack; every subsequent fragment runs through it until
-- `end_shader_mode()`. Users load shaders via Phase 71 (SHADER-01).
--
-- `begin_blend_mode(mode)` selects one of the 8 BlendMode values
-- (ALPHA, ADDITIVE, MULTIPLIED, ADD_COLORS, SUBTRACT_COLORS,
-- ALPHA_PREMULTIPLY, CUSTOM, CUSTOM_SEPARATE). CUSTOM and
-- CUSTOM_SEPARATE require a prior `rlSetBlendFactors` setup вЂ” rlgl
-- is out of scope for v2.0.0-alpha (REQUIREMENTS.md), so prefer
-- the first 6 values in this milestone.
func Draw.begin_shader_mode(shader: Shader) {}
func Draw.end_shader_mode() {}
func Draw.begin_blend_mode(mode: BlendMode) {}
func Draw.end_blend_mode() {}

-- Scissor mode (DRAW2D-06)
--
-- `begin_scissor_mode(x, y, w, h)` clips every subsequent draw to
-- the given rectangle until `end_scissor_mode()`. Pixel-space
-- coordinates; origin is the top-left of the render target.
func Draw.begin_scissor_mode(x: Int32, y: Int32, w: Int32, h: Int32) {}
func Draw.end_scissor_mode() {}

-- Pixel primitives (DRAW2D-07)
--
-- Set one pixel to a color. `pixel` uses integer coordinates; `pixel_v`
-- uses a Vector2 (with Float32 components). Equivalent to DrawPixel /
-- DrawPixelV in raylib.
func Draw.pixel(x: Int32, y: Int32, color: Color) {}
func Draw.pixel_v(position: Vector2, color: Color) {}

-- Line primitives (DRAW2D-08)
--
-- `line` takes 4 integer endpoint coordinates; `line_v` takes two
-- Vector2 endpoints; `line_ex` adds a float thickness; `line_bezier`
-- draws a cubic-bezier-interpolated line between two endpoints.
--
-- NOTE: `DrawLineStrip(points, count, color)` вЂ” the Iron-side
-- `Draw.line_strip(points: [Vector2], ...)` вЂ” is DEFERRED to Plan
-- 63-04, which probes Iron's `[Vector2]` array ABI via a micro-
-- smoke-test before committing to a shim signature.
func Draw.line(x1: Int32, y1: Int32, x2: Int32, y2: Int32, color: Color) {}
func Draw.line_v(start: Vector2, end: Vector2, color: Color) {}
func Draw.line_ex(start: Vector2, end: Vector2, thick: Float32, color: Color) {}
func Draw.line_bezier(start: Vector2, end: Vector2, thick: Float32, color: Color) {}

-- Circle primitives (DRAW2D-09)
--
-- Seven variants:
--   `circle(cx, cy, r, color)`            вЂ” filled circle, Int32 center
--   `circle_sector(center, r, s, e, seg)` вЂ” filled pie slice, Vector2 center,
--                                           `s` / `e` are degrees, `seg` is
--                                           tessellation step count
--   `circle_sector_lines(...)`            вЂ” outline of the sector
--   `circle_gradient(cx, cy, r, i, o)`    вЂ” filled with radial gradient;
--                                           `i` is inner color, `o` is outer
--   `circle_v(center, r, color)`          вЂ” filled, Vector2 center
--   `circle_lines(cx, cy, r, color)`      вЂ” outline, Int32 center
--   `circle_lines_v(center, r, color)`    вЂ” outline, Vector2 center
func Draw.circle(cx: Int32, cy: Int32, r: Float32, color: Color) {}
func Draw.circle_sector(center: Vector2, r: Float32, start: Float32, end: Float32, segments: Int32, color: Color) {}
func Draw.circle_sector_lines(center: Vector2, r: Float32, start: Float32, end: Float32, segments: Int32, color: Color) {}
func Draw.circle_gradient(cx: Int32, cy: Int32, r: Float32, inner: Color, outer: Color) {}
func Draw.circle_v(center: Vector2, r: Float32, color: Color) {}
func Draw.circle_lines(cx: Int32, cy: Int32, r: Float32, color: Color) {}
func Draw.circle_lines_v(center: Vector2, r: Float32, color: Color) {}

-- Ellipse primitives (DRAW2D-10)
--
-- Both take Int32 center + Float32 horizontal/vertical radii.
-- `ellipse` is filled; `ellipse_lines` is outline.
func Draw.ellipse(cx: Int32, cy: Int32, rh: Float32, rv: Float32, color: Color) {}
func Draw.ellipse_lines(cx: Int32, cy: Int32, rh: Float32, rv: Float32, color: Color) {}

-- Ring primitives (DRAW2D-11)
--
-- Annulus with optional sector. Parameters: Vector2 center,
-- inner radius, outer radius, start/end angles (degrees), segment
-- count, color. Ring with start=0, end=360 is a full annulus;
-- partial angles produce ring-sectors. `ring_lines` is the outline.
func Draw.ring(center: Vector2, inner: Float32, outer: Float32, start: Float32, end: Float32, segments: Int32, color: Color) {}
func Draw.ring_lines(center: Vector2, inner: Float32, outer: Float32, start: Float32, end: Float32, segments: Int32, color: Color) {}

-- Rectangle primitives (DRAW2D-12)
--
-- Twelve variants covering every DrawRectangle* raylib exposes.
-- `rectangle` takes Int32 position + Int32 size; `rectangle_v` takes
-- two Vector2 (position + size); `rectangle_rec` takes a Rectangle
-- value (Float32 x/y/w/h); `rectangle_pro` adds origin + rotation.
-- Gradients: `gradient_v` (topв†’bottom), `gradient_h` (leftв†’right),
-- `gradient_ex` (4 corner colors with Rectangle). Outlines:
-- `lines` (Int32), `lines_ex` (Rectangle + thickness). Rounded:
-- `rounded` (fill), `rounded_lines` (outline at full width),
-- `rounded_lines_ex` (outline with custom thickness).
func Draw.rectangle(x: Int32, y: Int32, w: Int32, h: Int32, color: Color) {}
func Draw.rectangle_v(position: Vector2, size: Vector2, color: Color) {}
func Draw.rectangle_rec(rec: Rectangle, color: Color) {}
func Draw.rectangle_pro(rec: Rectangle, origin: Vector2, rotation: Float32, color: Color) {}
func Draw.rectangle_gradient_v(x: Int32, y: Int32, w: Int32, h: Int32, top: Color, bottom: Color) {}
func Draw.rectangle_gradient_h(x: Int32, y: Int32, w: Int32, h: Int32, left: Color, right: Color) {}
func Draw.rectangle_gradient_ex(rec: Rectangle, tl: Color, bl: Color, tr: Color, br: Color) {}
func Draw.rectangle_lines(x: Int32, y: Int32, w: Int32, h: Int32, color: Color) {}
func Draw.rectangle_lines_ex(rec: Rectangle, thick: Float32, color: Color) {}
func Draw.rectangle_rounded(rec: Rectangle, roundness: Float32, segments: Int32, color: Color) {}
func Draw.rectangle_rounded_lines(rec: Rectangle, roundness: Float32, segments: Int32, color: Color) {}
func Draw.rectangle_rounded_lines_ex(rec: Rectangle, roundness: Float32, segments: Int32, thick: Float32, color: Color) {}

-- Triangle primitives (DRAW2D-13)
--
-- Two fixed-point variants вЂ” `triangle` fills, `triangle_lines`
-- outlines. Both take 3 Vector2 vertices + Color. Vertex order
-- matters for raylib's winding: raylib uses counter-clockwise
-- culling by default, so vertices must be in CCW order to be
-- visible.
--
-- `triangle_fan` and `triangle_strip` (array variants) are declared
-- below; Plan 63-03 Task 1 array-ABI probe confirmed ironc lowers
-- `[Vector2]` parameters to `Iron_List_Iron_Vector2` struct-by-value
-- (items/count/capacity wrapper). The shim forwards `points.items`
-- to raylib as `const Vector2 *`.
func Draw.triangle(v1: Vector2, v2: Vector2, v3: Vector2, color: Color) {}
func Draw.triangle_lines(v1: Vector2, v2: Vector2, v3: Vector2, color: Color) {}

-- Polygon primitives (DRAW2D-14)
--
-- Regular polygons (equilateral). Parameters: Vector2 center,
-- Int32 sides (3 = triangle, 4 = square, 6 = hexagon, ...),
-- Float32 radius (to vertices), Float32 rotation (degrees).
-- `poly_lines_ex` adds thickness.
func Draw.poly(center: Vector2, sides: Int32, r: Float32, rotation: Float32, color: Color) {}
func Draw.poly_lines(center: Vector2, sides: Int32, r: Float32, rotation: Float32, color: Color) {}
func Draw.poly_lines_ex(center: Vector2, sides: Int32, r: Float32, rotation: Float32, thick: Float32, color: Color) {}

-- Triangle array variants (DRAW2D-13 вЂ” array ABI validated by Plan 63-03 Task 1)
--
-- `triangle_fan(points, count, color)` draws a triangle fan from
-- the first point to every subsequent pair; `triangle_strip` draws
-- consecutive-3-point triangles sharing edges. Both take a
-- [Vector2] array and a separate count (redundant with array length
-- but matches raylib's C signature). The shim casts Iron's array
-- representation (Iron_List_Iron_Vector2.items) to `const Vector2 *`
-- at the FFI boundary.
func Draw.triangle_fan(points: [Vector2], count: Int32, color: Color) {}
func Draw.triangle_strip(points: [Vector2], count: Int32, color: Color) {}

-- Spline segment primitives (DRAW2D-15 вЂ” fixed-point-count variants)
--
-- Five spline families вЂ” linear (2 control pts per segment), basis
-- (4), catmull_rom (4), bezier_quadratic (3 = p1 + c2 control + p3),
-- bezier_cubic (4 = p1 + c2 + c3 control + p4). `thick` is line
-- thickness in pixels; `color` is the stroke color.
--
-- Use these for single-segment draws. For continuous splines through
-- multiple control points, use the whole-spline variants below
-- (Draw.spline_linear / spline_basis / ... вЂ” pending array ABI).
func Draw.spline_segment_linear(p1: Vector2, p2: Vector2, thick: Float32, color: Color) {}
func Draw.spline_segment_basis(p1: Vector2, p2: Vector2, p3: Vector2, p4: Vector2, thick: Float32, color: Color) {}
func Draw.spline_segment_catmull_rom(p1: Vector2, p2: Vector2, p3: Vector2, p4: Vector2, thick: Float32, color: Color) {}
func Draw.spline_segment_bezier_quadratic(p1: Vector2, c2: Vector2, p3: Vector2, thick: Float32, color: Color) {}
func Draw.spline_segment_bezier_cubic(p1: Vector2, c2: Vector2, c3: Vector2, p4: Vector2, thick: Float32, color: Color) {}

-- Spline evaluators (DRAW2D-16)
--
-- Return the Vector2 at parameter t on the named spline curve.
-- t в€€ [0.0, 1.0] traces the curve from first to last control point;
-- values outside the range extrapolate.
--
-- IMPORTANT: `t` MUST be Float32 on the Iron side. Iron's default
-- Float is double; raylib expects `float`. Users MUST write
-- `Float32(0.5)` at call sites вЂ” not a bare `0.5` literal (which
-- is Float=double and would truncate silently at the FFI boundary).
--
-- Iron method names normalize raylib's C-name `BezierQuad` to
-- `bezier_quadratic` for symmetry with the draw side's
-- `DrawSplineBezierQuadratic` (and the segment evaluator
-- `spline_segment_bezier_quadratic` above).
func Draw.get_spline_point_linear(start: Vector2, end: Vector2, t: Float32) -> Vector2 {}
func Draw.get_spline_point_basis(p1: Vector2, p2: Vector2, p3: Vector2, p4: Vector2, t: Float32) -> Vector2 {}
func Draw.get_spline_point_catmull_rom(p1: Vector2, p2: Vector2, p3: Vector2, p4: Vector2, t: Float32) -> Vector2 {}
func Draw.get_spline_point_bezier_quadratic(p1: Vector2, c2: Vector2, p3: Vector2, t: Float32) -> Vector2 {}
func Draw.get_spline_point_bezier_cubic(p1: Vector2, c2: Vector2, c3: Vector2, p4: Vector2, t: Float32) -> Vector2 {}

-- Whole-spline primitives (DRAW2D-15 вЂ” array variants) and deferred
-- DrawLineStrip (DRAW2D-08 last variant).
--
-- Draw a continuous smooth curve through an array of Vector2 control
-- points. Raylib tessellates the curve internally. Point count
-- minimums vary by spline type:
--   spline_linear         : min 2 points (polyline)
--   spline_basis          : min 4 points
--   spline_catmull_rom    : min 4 points
--   spline_bezier_quadratic : min 3 points; pattern [p1, c2, p3, c4, p5, c6, ...]
--                           (alternating anchor / control points)
--   spline_bezier_cubic   : min 4 points; pattern [p1, c2, c3, p4, c5, c6, p7, ...]
--                           (anchor + 2 controls + next anchor, repeating)
--
-- `count` must equal the array length; mismatch causes raylib to read
-- past the array. ABI confirmed by Plan 63-03 Task 1 probe вЂ” `[Vector2]`
-- lowers to Iron_List_Iron_Vector2 struct-by-value at the FFI boundary.
func Draw.line_strip(points: [Vector2], count: Int32, color: Color) {}
func Draw.spline_linear(points: [Vector2], count: Int32, thick: Float32, color: Color) {}
func Draw.spline_basis(points: [Vector2], count: Int32, thick: Float32, color: Color) {}
func Draw.spline_catmull_rom(points: [Vector2], count: Int32, thick: Float32, color: Color) {}
func Draw.spline_bezier_quadratic(points: [Vector2], count: Int32, thick: Float32, color: Color) {}
func Draw.spline_bezier_cubic(points: [Vector2], count: Int32, thick: Float32, color: Color) {}

-- в”Ђв”Ђ Phase 67 extension: default-font draws (TEXT-07, TEXT-08 default)
--
-- Render raylib's FPS overlay (top-left unless positioned) and
-- default-font text. Both read raylib's embedded default atlas, which
-- is populated by InitWindow via rtext.c:LoadFontDefault.
--
-- Pitfall 1 (Plan 67-RESEARCH): these REQUIRE Window.init() first;
-- calling them before an OpenGL context + default font are live
-- dereferences a null atlas pointer. For custom-font draws use
-- Font.draw_ex / Font.draw_pro below.
func Draw.fps(posX: Int32, posY: Int32) {}
func Draw.text(text: String, posX: Int32, posY: Int32, fontSize: Int32, color: Color) {}

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- Collision (Phase 64)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--
-- 2D (COLL-01) вЂ” 11 functions across Rectangle / Vector2 / Collision
-- receivers. Methods on data-carrying objects (Rectangle, Vector2)
-- dispatch via Iron_<lowercased_type>_<method> mangling per
-- src/hir/hir_to_lir.c:1096-1297. Collision.* namespace holds the
-- 4 pair-based tests with no natural receiver.

-- Rectangle receiver (4 functions). Receiver param is named `rect`
-- per iron_net.iron convention (TcpSocket uses `s`, TcpListener uses
-- `l`); `self` is a reserved word in Iron's parser.
func Rectangle.collides(rect: Rectangle, other: Rectangle) -> Bool {}
func Rectangle.intersection(rect: Rectangle, other: Rectangle) -> Rectangle {}
func Rectangle.contains_point(rect: Rectangle, point: Vector2) -> Bool {}
func Rectangle.collides_circle(rect: Rectangle, center: Vector2, radius: Float32) -> Bool {}

-- Vector2 receiver (3 functions). Receiver param is named `point`
-- (idiomatic for a point-in-shape query).
func Vector2.inside_triangle(point: Vector2, p1: Vector2, p2: Vector2, p3: Vector2) -> Bool {}
func Vector2.inside_polygon(point: Vector2, points: [Vector2]) -> Bool {}
func Vector2.on_line(point: Vector2, p1: Vector2, p2: Vector2, threshold: Int32) -> Bool {}

-- Collision namespace (4 pair-based 2D tests)
func Collision.circles(c1: Vector2, r1: Float32, c2: Vector2, r2: Float32) -> Bool {}
func Collision.circle_line(center: Vector2, radius: Float32, p1: Vector2, p2: Vector2) -> Bool {}
func Collision.point_circle(point: Vector2, center: Vector2, radius: Float32) -> Bool {}
func Collision.lines(start_a: Vector2, end_a: Vector2, start_b: Vector2, end_b: Vector2) -> (Bool, Vector2) {}

-- 3D (COLL-02) вЂ” 8 functions across BoundingBox / Ray / Collision
-- receivers. Ray.hit_* returns RayCollision by value (32-byte struct,
-- first outside spline evaluator Vector2 returns). Ray.hit_mesh is
-- the first Mesh pass-by-value (120 B) + Matrix pass-by-value (64 B)
-- through the FFI вЂ” layout pinned by Phase 60-04 _Static_assert grid.
-- Receiver params are named `box` / `ray` per iron_net convention;
-- `self` is a reserved word in Iron's parser (see 64-01 Rule 1 fix).

-- BoundingBox receiver (2 functions)
func BoundingBox.collides(box: BoundingBox, other: BoundingBox) -> Bool {}
func BoundingBox.collides_sphere(box: BoundingBox, center: Vector3, radius: Float32) -> Bool {}

-- Ray receiver (5 functions)
func Ray.hit_sphere(ray: Ray, center: Vector3, radius: Float32) -> RayCollision {}
func Ray.hit_box(ray: Ray, box: BoundingBox) -> RayCollision {}
func Ray.hit_mesh(ray: Ray, mesh: Mesh, transform: Matrix) -> RayCollision {}
func Ray.hit_triangle(ray: Ray, p1: Vector3, p2: Vector3, p3: Vector3) -> RayCollision {}
func Ray.hit_quad(ray: Ray, p1: Vector3, p2: Vector3, p3: Vector3, p4: Vector3) -> RayCollision {}

-- Collision namespace (1 pair-based 3D test)
func Collision.spheres(c1: Vector3, r1: Float32, c2: Vector3, r2: Float32) -> Bool {}

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
-- Phase 68 вЂ” Audio System (raudio bindings)
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

-- в”Ђв”Ђ AUDIO-01 device lifecycle (5 methods, freestanding on Audio.*) в”Ђ
-- Matches Phase 61 Window.* precedent. raylib's _device suffix is
-- dropped вЂ” the Audio namespace already implies device scope.
--
-- Pitfall: InitAudioDevice logs a TRACELOG warning on backend failure
-- but does NOT crash. Callers should guard play/update calls with
-- Audio.is_ready() for graceful headless / CI degradation.
func Audio.init() {}
func Audio.close() {}
func Audio.is_ready() -> Bool {}
func Audio.set_master_volume(volume: Float32) {}
func Audio.get_master_volume() -> Float32 {}
