func Image.alpha_premultiply(img: Image) -> Image {}
func Image.blur_gaussian(img: Image, blur_size: Int32) -> Image {}
func Image.resize(img: Image, new_width: Int32, new_height: Int32) -> Image {}
func Image.resize_nn(img: Image, new_width: Int32, new_height: Int32) -> Image {}
func Image.resize_canvas(img: Image, new_width: Int32, new_height: Int32, offset_x: Int32, offset_y: Int32, fill: Color) -> Image {}
func Image.mipmaps(img: Image) -> Image {}
func Image.dither(img: Image, r_bpp: Int32, g_bpp: Int32, b_bpp: Int32, a_bpp: Int32) -> Image {}
func Image.flip_vertical(img: Image) -> Image {}
func Image.flip_horizontal(img: Image) -> Image {}
func Image.rotate(img: Image, degrees: Int32) -> Image {}
func Image.rotate_cw(img: Image) -> Image {}
func Image.rotate_ccw(img: Image) -> Image {}
func Image.color_tint(img: Image, color: Color) -> Image {}
func Image.color_invert(img: Image) -> Image {}
func Image.color_grayscale(img: Image) -> Image {}
func Image.color_contrast(img: Image, contrast: Float32) -> Image {}
