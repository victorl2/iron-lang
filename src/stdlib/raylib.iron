func Image.color_replace(img: Image, color: Color, replace: Color) -> Image {}

-- в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
-- Image CPU draw (Plan 66-03 вЂ” TEX-07, 21 bindings)
-- в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
--
-- Chain-style CPU-side image composition. Every method takes Image by
-- value, returns a fresh Image by value. Raylib mutates an internal
-- `dst` copy; the shim memcpys it back out as the return value.
--
--   canvas
--     .clear_background(BLACK)
--     .draw_rectangle(8, 8, 48, 16, RED)
--     .draw_text("hello", 12, 12, 10, WHITE)
--
-- `draw_text` uses raylib's default font вЂ” requires Window.init() to
-- have loaded it first (Pitfall 4).
--
-- `draw_triangle_fan` / `draw_triangle_strip` reuse the Iron_List_Iron_Vector2
-- by-value ABI proven in Phase 63-03 (triangle_fan/strip / line_strip).
--
-- ImageDrawTextEx: Phase 66 deferral CLOSED in Phase 67 Plan 01 Task 2 вЂ”
-- see Image.draw_text_ex in the Phase 67 section below.

func Image.clear_background(img: Image, color: Color) -> Image {}
func Image.draw_pixel(img: Image, pos_x: Int32, pos_y: Int32, color: Color) -> Image {}
func Image.draw_pixel_v(img: Image, position: Vector2, color: Color) -> Image {}
func Image.draw_line(img: Image, start_x: Int32, start_y: Int32, end_x: Int32, end_y: Int32, color: Color) -> Image {}
func Image.draw_line_v(img: Image, start: Vector2, finish: Vector2, color: Color) -> Image {}
func Image.draw_line_ex(img: Image, start: Vector2, finish: Vector2, thick: Int32, color: Color) -> Image {}
func Image.draw_circle(img: Image, center_x: Int32, center_y: Int32, radius: Int32, color: Color) -> Image {}
func Image.draw_circle_v(img: Image, center: Vector2, radius: Int32, color: Color) -> Image {}
func Image.draw_circle_lines(img: Image, center_x: Int32, center_y: Int32, radius: Int32, color: Color) -> Image {}
func Image.draw_circle_lines_v(img: Image, center: Vector2, radius: Int32, color: Color) -> Image {}
func Image.draw_rectangle(img: Image, pos_x: Int32, pos_y: Int32, width: Int32, height: Int32, color: Color) -> Image {}
func Image.draw_rectangle_v(img: Image, position: Vector2, size: Vector2, color: Color) -> Image {}
func Image.draw_rectangle_rec(img: Image, rec: Rectangle, color: Color) -> Image {}
func Image.draw_rectangle_lines(img: Image, rec: Rectangle, thick: Int32, color: Color) -> Image {}
func Image.draw_triangle(img: Image, v1: Vector2, v2: Vector2, v3: Vector2, color: Color) -> Image {}
func Image.draw_triangle_ex(img: Image, v1: Vector2, v2: Vector2, v3: Vector2, c1: Color, c2: Color, c3: Color) -> Image {}
func Image.draw_triangle_lines(img: Image, v1: Vector2, v2: Vector2, v3: Vector2, color: Color) -> Image {}
func Image.draw_triangle_fan(img: Image, points: [Vector2], point_count: Int32, color: Color) -> Image {}
func Image.draw_triangle_strip(img: Image, points: [Vector2], point_count: Int32, color: Color) -> Image {}
func Image.draw(img: Image, src: Image, src_rec: Rectangle, dst_rec: Rectangle, tint: Color) -> Image {}
func Image.draw_text(img: Image, text: String, pos_x: Int32, pos_y: Int32, font_size: Int32, color: Color) -> Image {}

-- Phase 66 Font-dependent deferrals closed in Phase 67 Plan 01 Task 2
-- (TEX-05 / TEX-07). ImageTextEx allocates a fresh Image rendered with
-- the given Font. ImageDrawTextEx mutates an existing Image in place
-- (Phase 66-03 Pattern 2 mutating-return-by-value). Font lifetime MUST
-- outlive the call вЂ” raylib reads Font._recs / _glyphs internally.
func Image.text_ex(font: Font, text: String, fontSize: Float32, spacing: Float32, tint: Color) -> Image {}
func Image.draw_text_ex(img: Image, font: Font, text: String, position: Vector2, fontSize: Float32, spacing: Float32, tint: Color) -> Image {}

-- Texture + RenderTexture load/update/config (Plan 66-04 вЂ” TEX-08/09/10/11, 12 bindings)
--
-- First Texture-by-value INPUT at scale in config methods; first
-- RenderTexture-by-value RETURN (44 B, under Phase 64's 120 B ceiling).
-- Opaque void* args via Int в†’ (void *)(intptr_t) cast (Pattern 4 from
-- Plan 66-01 Color.from_pixel_data probe). TextureCubemap and
-- RenderTexture2D are raylib typedef aliases of Texture / RenderTexture
-- so the Iron mirror is shared across load_cubemap and RenderTexture.

