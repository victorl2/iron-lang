-- list.iron -- Collection methods on arrays
-- These are extension method declarations for the type checker.
-- Actual implementations are provided by the C runtime (iron_collections.c).
-- Phase 49 (Loop Fusion) will optimize chained calls into single-pass loops.

func [T].map(f: func(T) -> T) -> [T] {}
func [T].filter(f: func(T) -> Bool) -> [T] {}
func [T].reduce(init: T, f: func(T, T) -> T) -> T {}
func [T].forEach(f: func(T)) {}
func [T].sum() -> T {}
